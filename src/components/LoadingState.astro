---
interface Props {
  message?: string;
  variant?: 'stitch' | 'progress';
}

const { message = '', variant } = Astro.props;
const resolvedVariant = variant ?? (message ? 'progress' : 'stitch');
---

<div class="loading-state" data-loading-state data-variant={resolvedVariant} aria-live="polite" aria-busy="true">
  <svg class="loading-stitch" viewBox="0 0 640 28" role="img" aria-label="Loading">
    <path d="M8 14 H632" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="6 10" />
  </svg>

  <div class="loading-progress" role="status">
    <div class="loading-progress-track" aria-hidden="true">
      <span></span>
    </div>
    <p data-loading-message>{message}</p>
    <div class="loading-skeleton" aria-hidden="true">
      <span style="width:85%"></span>
      <span style="width:60%"></span>
      <span style="width:72%"></span>
    </div>
  </div>
</div>

<style>
  .loading-state {
    width: 100%;
    color: var(--muted);
    font-family: var(--font-body);
  }

  .loading-state[data-variant="stitch"] .loading-progress,
  .loading-state[data-variant="progress"] .loading-stitch {
    display: none;
  }

  .loading-stitch {
    width: 100%;
    height: 44px;
    display: block;
    overflow: visible;
  }

  .loading-stitch path {
    animation: stitch-dash 1.4s ease-in-out infinite;
  }

  .loading-progress-track {
    position: relative;
    width: 100%;
    height: 2px;
    background: var(--border);
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .loading-progress-track span {
    position: absolute;
    inset: 0 auto 0 0;
    width: 42%;
    background: currentColor;
    animation: progress-sweep 1.4s ease-in-out infinite;
  }

  .loading-progress p {
    margin: 0 0 1rem;
    color: var(--muted);
    font-size: 0.75rem;
    line-height: 1.6;
  }

  .loading-skeleton {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .loading-skeleton span {
    display: block;
    height: 0.65rem;
    background: var(--border);
    animation: skeleton-pulse 1.4s ease-in-out infinite;
  }

  .loading-skeleton span:nth-child(2) { animation-delay: 0.12s; }
  .loading-skeleton span:nth-child(3) { animation-delay: 0.24s; }

  @keyframes stitch-dash {
    0%,
    100% { stroke-dashoffset: 60; }
    50% { stroke-dashoffset: 0; }
  }

  @keyframes progress-sweep {
    0% { transform: translateX(-110%); }
    100% { transform: translateX(250%); }
  }

  @keyframes skeleton-pulse {
    0%,
    100% { opacity: 0.28; }
    50% { opacity: 0.72; }
  }

  @media (prefers-reduced-motion: reduce) {
    .loading-stitch path,
    .loading-progress-track span,
    .loading-skeleton span {
      animation: none;
    }
  }
</style>
