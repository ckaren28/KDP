---
interface Props {
  images: { src: string; alt: string }[];
  id?: string;
}

const { images, id = `slider-${Math.random().toString(36).slice(2, 7)}` } = Astro.props;
---

<div class="img-slider" id={id} data-count={images.length}>
  <div class="img-slider__track">
    {images.map((img) => (
      <div class="img-slider__slide">
        <img src={img.src} alt={img.alt} />
      </div>
    ))}
  </div>

  {images.length > 1 && (
    <>
      <button class="img-slider__btn img-slider__btn--prev" aria-label="Previous image">←</button>
      <button class="img-slider__btn img-slider__btn--next" aria-label="Next image">→</button>
      <div class="img-slider__dots">
        {images.map((_, i) => (
          <button
            class={`img-slider__dot${i === 0 ? ' img-slider__dot--active' : ''}`}
            aria-label={`Go to image ${i + 1}`}
            data-index={i}
          />
        ))}
      </div>
    </>
  )}
</div>

<style>
  .img-slider {
    position: relative;
    overflow: hidden;
    margin: 2rem 0;
    background: var(--border);
  }

  .img-slider__track {
    display: flex;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .img-slider__slide {
    min-width: 100%;
    flex-shrink: 0;
  }

  .img-slider__slide img {
    width: 100%;
    height: 480px;
    object-fit: contain;
    display: block;
    margin: 0;
  }

  .img-slider__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(237, 229, 208, 0.85);
    border: none;
    color: var(--black);
    font-size: 1rem;
    width: 40px;
    height: 40px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 2;
    /* offset the margin buttons sometimes inherit from prose */
    margin: 0;
    padding: 0;
  }
  .img-slider__btn:hover {
    background: rgba(237, 229, 208, 1);
  }
  .img-slider__btn--prev { left: 12px; }
  .img-slider__btn--next { right: 12px; }

  .img-slider__dots {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 2;
  }

  .img-slider__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: 1px solid rgba(237, 229, 208, 0.6);
    background: transparent;
    cursor: pointer;
    padding: 0;
    margin: 0;
    transition: background 0.2s;
  }
  .img-slider__dot--active {
    background: rgba(237, 229, 208, 0.95);
    border-color: rgba(237, 229, 208, 0.95);
  }

  @media (max-width: 600px) {
    .img-slider__slide img { height: 280px; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.img-slider').forEach(slider => {
    const track  = slider.querySelector<HTMLElement>('.img-slider__track')!;
    const dots   = slider.querySelectorAll<HTMLButtonElement>('.img-slider__dot');
    const count  = parseInt(slider.dataset.count ?? '1', 10);
    let current  = 0;
    let startX   = 0;
    let dragging = false;

    function goTo(idx: number) {
      current = (idx + count) % count;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => d.classList.toggle('img-slider__dot--active', i === current));
    }

    slider.querySelector('.img-slider__btn--prev')?.addEventListener('click', () => goTo(current - 1));
    slider.querySelector('.img-slider__btn--next')?.addEventListener('click', () => goTo(current + 1));
    dots.forEach(dot => dot.addEventListener('click', () => goTo(Number(dot.dataset.index))));

    // Touch swipe
    track.addEventListener('touchstart', e => { startX = e.touches[0].clientX; dragging = true; }, { passive: true });
    track.addEventListener('touchend', e => {
      if (!dragging) return;
      const dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 40) goTo(dx < 0 ? current + 1 : current - 1);
      dragging = false;
    });
  });
</script>
