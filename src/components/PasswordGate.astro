---
interface Props {
  slug: string;
}
const { slug } = Astro.props;
---

<div id="pw-gate">
  <p class="pw-label">This project is password protected.</p>
  <form id="pw-form">
    <input
      id="pw-input"
      type="password"
      placeholder="Password"
      autocomplete="current-password"
      aria-label="Password"
    />
    <button type="submit">Enter</button>
    <p id="pw-error" class="pw-error" aria-live="polite"></p>
  </form>
</div>

<style>
  #pw-gate {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 3rem 1rem;
  }

  .pw-label {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--muted);
    margin: 0;
  }

  #pw-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    max-width: 280px;
  }

  #pw-input {
    width: 100%;
    padding: 0.6rem 0.8rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--black);
    background: var(--off-white);
    border: 1px solid var(--border);
    border-radius: 2px;
    outline: none;
    box-sizing: border-box;
  }

  #pw-input:focus {
    border-color: var(--muted);
  }

  button[type="submit"] {
    width: 100%;
    padding: 0.6rem 1.2rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--off-white);
    background: var(--black);
    border: none;
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.15s;
  }

  button[type="submit"]:hover {
    background: var(--sienna);
  }

  .pw-error {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--sienna);
    margin: 0;
    min-height: 1.2em;
  }
</style>

<script define:vars={{ slug }}>
  const storageKey = `pw-gate-${slug}`;

  function revealContent() {
    const gate = document.getElementById('pw-gate');
    const content = document.getElementById('gated-content');
    if (gate) gate.style.display = 'none';
    if (content) content.style.display = '';
  }

  if (sessionStorage.getItem(storageKey) === 'granted') {
    revealContent();
  }

  const form = document.getElementById('pw-form');
  const input = document.getElementById('pw-input');
  const errorEl = document.getElementById('pw-error');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errorEl) errorEl.textContent = '';

      const password = input?.value ?? '';
      if (!password) return;

      try {
        const res = await fetch('/.netlify/functions/verify-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password }),
        });
        const data = await res.json();

        if (data.ok) {
          sessionStorage.setItem(storageKey, 'granted');
          revealContent();
        } else {
          if (errorEl) errorEl.textContent = 'Incorrect password.';
          if (input) input.value = '';
        }
      } catch {
        if (errorEl) errorEl.textContent = 'Something went wrong. Please try again.';
      }
    });
  }
</script>
