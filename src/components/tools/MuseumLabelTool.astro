---
import styles from '../../pages/projects/museum-label-generator.module.css';
const s = styles;
import g from './MuseumLabelTool.module.css';
import LoadingState from '../LoadingState.astro';
---

<!-- ── TOOL GRID: form + output ── -->
<div class={s['tool-grid']}>

  <!-- FORM PANEL -->
  <div class={s['panel']}>
    <div class={s['workshop-row']}>
      <label>
        <input id="mlg-workshop" type="checkbox" />
        Workshop mode
      </label>
    </div>

    <div id="mlg-presets" class={s['presets-wrap']} style="display:none">
      <div class={s['presets-label']}>Example inputs</div>
      <div class={s['presets-list']}>
        <button data-preset="abstract" type="button" class={s['preset-btn']}>Abstract painting</button>
        <button data-preset="provenance" type="button" class={s['preset-btn']}>Archive object</button>
        <button data-preset="photo" type="button" class={s['preset-btn']}>Contemporary photo</button>
        <button data-preset="textile" type="button" class={s['preset-btn']}>Archive fashion object</button>
      </div>
    </div>

    <div class={s['form-row']}>
      <div class={s['form-field']}>
        <label for="mlg-title">Title (optional)</label>
        <input id="mlg-title" type="text" placeholder="Untitled (Blue Study)" />
      </div>
      <div class={s['form-field']}>
        <label for="mlg-artist">Artist (optional)</label>
        <input id="mlg-artist" type="text" placeholder="Unknown" />
      </div>
    </div>

    <div class={s['form-row']}>
      <div class={s['form-field']}>
        <label for="mlg-year">Year (optional)</label>
        <input id="mlg-year" type="text" placeholder="1970s (approx.)" />
      </div>
      <div class={s['form-field']}>
        <label for="mlg-medium">Medium / Materials (optional)</label>
        <input id="mlg-medium" type="text" placeholder="Cotton, linen, dye" />
      </div>
    </div>

    <div class={s['form-field']} style="margin-bottom:0.25rem">
      <label for="mlg-description">Source description (required)</label>
      <textarea id="mlg-description" placeholder="Describe what the visitor sees, any known context, and what you want to emphasize..."></textarea>
      <span class={s['form-hint']}>Minimum: ~30 characters</span>
    </div>

    <div class={s['form-options']}>
      <div class={s['form-field']} style="margin:0">
        <label for="mlg-tone" style="text-transform:uppercase;letter-spacing:0.1em;font-size:0.68rem">Tone</label>
        <select id="mlg-tone">
          <option value="neutral" selected>Neutral</option>
          <option value="warm">Warm</option>
          <option value="playful">Playful</option>
          <option value="academic">Academic</option>
        </select>
      </div>
      <label style="font-family:var(--font-body);font-size:0.75rem;color:var(--text-body);display:flex;align-items:center;gap:0.5rem;cursor:pointer">
        <input id="mlg-stayclose" type="checkbox" checked />
        Stay close to source text
      </label>
    </div>

    <button id="mlg-generate" class={s['btn-generate']} disabled type="button">Generate labels</button>

    <div id="mlg-error" class={s['error-box']} style="display:none"></div>

    <div id="mlg-facilitator" class={s['facilitator-box']} style="display:none">
      <div class={s['facilitator-title']}>Facilitator notes</div>
      <ol>
        <li>Choose an example (or paste your own description).</li>
        <li>Generate twice: with <em>Stay close</em> ON, then OFF.</li>
        <li>Compare assumptions, tone, and accessibility. What needs human editing?</li>
      </ol>
    </div>
  </div>

  <!-- OUTPUT PANEL -->
  <div class={s['panel']}>
    <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:1.5rem">
      <div>
        <div class={s['panel-title']}>Output</div>
        <div class={s['panel-subtitle']}>Copy individual sections for drafts and iteration.</div>
      </div>
      <button id="mlg-toggle-details" type="button" class={s['btn-toggle-details']}>Show prompt &amp; architecture</button>
    </div>

    <div id="mlg-empty" class={s['output-empty']}>Generate to see wall label drafts, alt text, and curator notes here.</div>
    <div id="mlg-loading" class={s['loading-wrap']} style="display:none">
      <LoadingState message="Generating interpretive label drafts..." />
    </div>

    <div id="mlg-output" style="display:none">
      <div class={s['output-section']}>
        <div class={s['output-section-header']}>
          <span class={s['output-section-title']}>Wall label (50–70 words)</span>
          <button data-copy="wall_label" type="button" class="btn-copy">Copy</button>
        </div>
        <p data-field="wall_label" class="output-text"></p>
      </div>

      <div class={s['output-section']}>
        <div class={s['output-section-header']}>
          <span class={s['output-section-title']}>Extended label (150–200 words)</span>
          <button data-copy="extended_label" type="button" class="btn-copy">Copy</button>
        </div>
        <p data-field="extended_label" class="output-text"></p>
      </div>

      <div class={s['output-section']}>
        <div class={s['output-section-header']}>
          <span class={s['output-section-title']}>Kids label</span>
          <button data-copy="kids_label" type="button" class="btn-copy">Copy</button>
        </div>
        <p data-field="kids_label" class="output-text"></p>
      </div>

      <div class={s['output-section']}>
        <div class={s['output-section-header']}>
          <span class={s['output-section-title']}>Audio guide script</span>
          <button data-copy="audio_guide_script" type="button" class="btn-copy">Copy</button>
        </div>
        <p data-field="audio_guide_script" class="output-text"></p>
      </div>

      <div class={s['output-section']}>
        <div class={s['output-section-header']}>
          <span class={s['output-section-title']}>Alt text</span>
          <button data-copy="alt_text" type="button" class="btn-copy">Copy</button>
        </div>
        <p data-field="alt_text" class="output-text"></p>
      </div>

      <div class={s['output-section']}>
        <div class={s['output-section-header']}>
          <span class={s['output-section-title']}>Curator notes</span>
        </div>
        <ul id="mlg-curator-notes" class={s['curator-notes-list']}></ul>
      </div>

      <div class={s['output-section']} style="border-bottom:none">
        <div class={s['output-section-header']}>
          <span class={s['output-section-title']}>Variations (alternate wall labels)</span>
        </div>
        <div id="mlg-variations"></div>
      </div>

      <div id="mlg-discussion" class={s['discussion-box']} style="display:none">
        <div class={s['discussion-title']}>Discussion prompts</div>
        <ul>
          <li>What information did the model assume that wasn't in the source text?</li>
          <li>Which version best respects the artist and audience?</li>
          <li>What would you edit for clarity, accuracy, or cultural context?</li>
          <li>What should never be automated in this workflow?</li>
        </ul>
      </div>
    </div>

    <div id="mlg-details" class={s['details-box']} style="display:none">
      <div class={s['details-title']}>Prompt &amp; architecture</div>
      <div class={s['details-sub']}>System prompt</div>
      <pre class={s['details-pre']} id="mlg-system"></pre>
      <div class={s['details-sub']}>User prompt template</div>
      <pre class={s['details-pre']} id="mlg-user"></pre>
      <div class={s['details-sub']}>Architecture</div>
      <pre class={s['details-pre']}>User input → Browser UI
      ↓
Netlify Function (secure)
      ↓
Anthropic API → JSON
      ↓
Render cards + copy tools</pre>
    </div>
  </div>

</div>

<!-- ── GALLERY SECTION ── -->
<section class={g['gallery-section']} data-your-artwork-section>
  <div class={g['gallery-inner']}>

    <h3 class={g['gallery-heading']}>See it in context</h3>

    <div class={g['gallery-light-wrap']}>
      <button type="button" id="galleryLightBtn" class={g['gallery-light-btn']} aria-label="Toggle spotlight mode">
        <svg class={g['gallery-light-svg']} viewBox="0 0 80 70" width="80" height="70" aria-hidden="true">
          <rect x="22" y="0" width="36" height="14" rx="3" fill="currentColor"/>
          <polygon points="26,14 54,14 68,62 12,62" fill="currentColor" opacity="0.18"/>
          <ellipse cx="40" cy="14" rx="11" ry="4" fill="currentColor" opacity="0.45"/>
        </svg>
      </button>
    </div>

    <div class={g['gallery-artwork-wrap']}>
      <div class={g['gallery-upload-zone']} id="uploadArea">
        <input type="file" id="artworkUpload" accept="image/jpeg,image/png,image/gif,image/webp" />
        <div class={g['gallery-upload-placeholder']} id="uploadPlaceholder">
          <div class={g['gallery-upload-icon']}>⊕</div>
          <p class={g['gallery-upload-label']}>Upload your artwork</p>
        </div>
        <img class={g['gallery-upload-preview']} id="uploadedPreview" src="" alt="Your uploaded artwork" style="display:none" />
      </div>
    </div>

    <div class={g['gallery-label-wrap']}>
      <div class={s['wall-label-card']} style="max-width:300px">
        <span class={s['wlc-eyebrow']}>Wall Label</span>
        <div class={s['wlc-title']} id="user-wlc-title">Untitled</div>
        <div class={s['wlc-meta']} id="user-wlc-meta">Artist unknown · Date unknown</div>
        <p class={s['wlc-body']} data-placeholder id="user-wlc-body">Generate a label above to see your draft here.</p>
      </div>
    </div>

  </div>
</section>

<script>
import { init as initGenerator } from './labelGenerator';
import { init as initSpotlight } from './gallerySpotlight';
initGenerator();
initSpotlight();
</script>
