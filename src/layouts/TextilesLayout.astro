---
import MainLayout from "./MainLayout.astro";
import styles from "./textiles-layout.module.css";
const s = styles;

interface Props {
  title: string;
  description: string;
  track: "fashion" | "textiles";
  tags: string[];
  filterable?: boolean;
}

const {
  title,
  description,
  track,
  tags = [],
  filterable = false,
} = Astro.props;

const backHref =
  track === "fashion" ? "/projects/fashion" : "/projects/textiles";
const backLabel = track === "fashion" ? "← Fashion" : "← Textile Practice";
const trackLabel = track === "fashion" ? "Fashion" : "Textile Practice";
---

<MainLayout title={`${title} — Karen Dettmar`}>
  <div class={s["page"]}>

    <nav class={s["back-nav"]}>
      <a href={backHref}>{backLabel}</a>
    </nav>

    <header class={s["page-header"]}>
      <span class={s["page-label"]}>{trackLabel}</span>
      <h1 class={s["page-title"]}>{title}</h1>
      <p class={s["page-desc"]}>{description}</p>
      {
        tags.length > 0 && (
          <div class={s["tags"]}>
            {filterable
              ? tags.map((tag, i) => (
                  <button
                    class={s["tag"]}
                    data-textile-filter={tag.toLowerCase()}
                    {...(i === 0 ? { "data-active": "" } : {})}
                  >
                    {tag}
                  </button>
                ))
              : tags.map((tag) => (
                  <span class={s["tag"]}>{tag}</span>
                ))}
          </div>
        )
      }
    </header>

    <div class={s["prose"]}>
      <slot />
    </div>

    <!-- Lightbox overlay for image zoom -->
    <div class={s["lightbox"]} id="prose-lightbox">
      <button class={s["lightbox-close"]} id="proseLightboxClose">Close ×</button>
      <img id="proseLightboxImg" src="" alt="" />
    </div>

    <div class={s["footer-nav"]}>
      <a href={backHref}>{backLabel}</a>
    </div>
  </div>

<script>
  // ── DRIP SCROLL ──
  const drip = document.getElementById('marbling-drip');
  if (drip) {
    window.addEventListener('scroll', () => {
      const ratio = Math.min(window.scrollY / 300, 1);
      drip.style.opacity = String(1 - ratio);
      drip.style.transform = `translateY(${ratio * 60}px)`;
    });
  }

  // ── LIGHTBOX for image grids ──
  const lightbox = document.getElementById('prose-lightbox') as HTMLElement | null;
  const lbImg = document.getElementById('proseLightboxImg') as HTMLImageElement | null;

  function openLightbox(src: string, alt: string) {
    if (!lightbox || !lbImg) return;
    lbImg.src = src;
    lbImg.alt = alt;
    lightbox.dataset.open = '';
  }
  function closeLightbox() {
    lightbox?.removeAttribute('data-open');
  }

  document.querySelectorAll<HTMLImageElement>('.image-grid--flats img, .results-grid img, .image-grid--process img').forEach(img => {
    img.style.cursor = 'zoom-in';
    img.addEventListener('click', () => openLightbox(img.src, img.alt));
  });

  document.getElementById('proseLightboxClose')?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
</script>
</MainLayout>
