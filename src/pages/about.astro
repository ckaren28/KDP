<script>
  // ── ANIMATION RESTART ON HOVER (tiles with data-anim) ──
  document.querySelectorAll<HTMLElement>('.otc-tile[data-anim]').forEach(tile => {
    tile.addEventListener('mouseenter', () => {
      tile.classList.remove('playing');
      void tile.offsetHeight; // force reflow to restart animations
      tile.classList.add('playing');
    });
    tile.addEventListener('mouseleave', () => {
      tile.classList.remove('playing');
    });
  });

  // ── STEAM TILE: play/pause on hover ──
  const steamTile = document.querySelector<HTMLElement>('.otc-tile--steam');
  steamTile?.addEventListener('mouseenter', () => steamTile.classList.add('playing'));
  steamTile?.addEventListener('mouseleave', () => steamTile.classList.remove('playing'));

  // ── IMAGE PUZZLE ──
  const N = 3;
  const PUZZLE_IMG = '/images/about/puzzle-textile.jpg';
  const puzzleWrap      = document.getElementById('puzzleTileWrap');
  const puzzleContainer = document.getElementById('puzzleContainer');
  // piecePos[i] = grid position (0–8) of piece i (pieces 0–7; piece 8 is conceptually the empty)
  let piecePos: number[] = [0, 1, 2, 3, 4, 5, 6, 7];
  let emptyPos = 8;
  let puzShuffled = false;
  const pieceDivs: HTMLDivElement[] = [];

  function getRC(pos: number) {
    return { r: Math.floor(pos / N), c: pos % N };
  }

  function renderPieces() {
    pieceDivs.forEach((div, i) => {
      const { r, c } = getRC(piecePos[i]);
      div.style.left = (c * 100 / N) + '%';
      div.style.top  = (r * 100 / N) + '%';
    });
    const emptyEl = document.getElementById('puzzleEmpty');
    if (emptyEl) {
      const { r, c } = getRC(emptyPos);
      emptyEl.style.left = (c * 100 / N) + '%';
      emptyEl.style.top  = (r * 100 / N) + '%';
    }
  }

  function tryMove(pieceIdx: number) {
    const pos = piecePos[pieceIdx];
    const { r: pr, c: pc } = getRC(pos);
    const { r: er, c: ec } = getRC(emptyPos);
    if (Math.abs(pr - er) + Math.abs(pc - ec) === 1) {
      piecePos[pieceIdx] = emptyPos;
      emptyPos = pos;
      renderPieces();
    }
  }

  function shufflePuzzle() {
    for (let s = 0; s < 200; s++) {
      const { r: er, c: ec } = getRC(emptyPos);
      const nbrs: number[] = [];
      if (er > 0)     nbrs.push(emptyPos - N);
      if (er < N - 1) nbrs.push(emptyPos + N);
      if (ec > 0)     nbrs.push(emptyPos - 1);
      if (ec < N - 1) nbrs.push(emptyPos + 1);
      const target = nbrs[Math.floor(Math.random() * nbrs.length)];
      const pi = piecePos.indexOf(target);
      if (pi !== -1) {
        piecePos[pi] = emptyPos;
        emptyPos = target;
      }
    }
    renderPieces();
  }

  if (puzzleContainer) {
    // Empty-slot pulse div
    const emptyEl = document.createElement('div');
    emptyEl.id = 'puzzleEmpty';
    emptyEl.className = 'puzzle-empty';
    puzzleContainer.appendChild(emptyEl);

    // Create 8 piece divs
    for (let i = 0; i < 8; i++) {
      const div = document.createElement('div');
      div.className = 'puzzle-piece';
      const imgC = i % N;
      const imgR = Math.floor(i / N);
      div.style.backgroundImage   = `url('${PUZZLE_IMG}')`;
      div.style.backgroundSize    = '300% 300%';
      div.style.backgroundPosition = `${imgC * 50}% ${imgR * 50}%`;
      div.addEventListener('click', () => tryMove(i));
      pieceDivs.push(div);
      puzzleContainer.appendChild(div);
    }
    renderPieces();
  }

  puzzleWrap?.addEventListener('mouseenter', () => {
    if (!puzShuffled) { puzShuffled = true; shufflePuzzle(); }
  });

  // ── TRIPLE-CLICK EASTER EGG ──
  const eggNote = document.getElementById('eggNote');
  let eggClicks = 0;
  let eggLastT  = 0;
  let eggTimer: ReturnType<typeof setTimeout> | null = null;

  const themeToggle = document.getElementById('themeToggle');
  themeToggle?.addEventListener('click', () => {
    const now = Date.now();
    if (now - eggLastT > 800) eggClicks = 0;
    eggClicks++;
    eggLastT = now;

    if (eggClicks >= 3 && eggNote) {
      eggClicks = 0;
      localStorage.setItem('easter1', '1');
      if (eggTimer) clearTimeout(eggTimer);
      eggNote.classList.remove('egg-hiding');
      eggNote.classList.add('egg-visible');
      eggTimer = setTimeout(() => {
        eggNote.classList.add('egg-hiding');
        eggNote.addEventListener('transitionend', () => {
          eggNote.classList.remove('egg-visible', 'egg-hiding');
        }, { once: true });
      }, 4000);
    }
  });
</script>

<style>
  .about-wrapper {
    max-width: 860px;
    margin: 0 auto;
    padding: 140px 48px 100px;
  }

  /* ── HEADER ── */
  .about-header {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .about-title {
    font-family: var(--font-display);
    font-size: clamp(52px, 9vw, 108px);
    font-weight: 300;
    line-height: 0.9;
    letter-spacing: -0.02em;
    margin-top: 12px;
  }

  .about-title em {
    font-style: italic;
    color: var(--sienna);
  }

  /* ── BIO ── */
  .bio {
    margin-bottom: 80px;
  }

  .bio p {
    font-size: 15px;
    line-height: 1.88;
    color: var(--text-body);
    font-weight: 300;
    max-width: 640px;
  }

  /* ── DISCIPLINES ── */
  .disciplines {
    margin-bottom: 80px;
    border-top: 1px solid var(--border);
    padding-top: 40px;
  }

  .section-label {
    display: block;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 32px;
  }

  .disc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .disc-cell {
    padding: 32px 0;
    border-bottom: 1px solid var(--border);
  }

  .disc-cell:nth-child(odd)  { padding-right: 48px; border-right: 1px solid var(--border); }
  .disc-cell:nth-child(even) { padding-left: 48px; }

  .disc-num {
    display: block;
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-bottom: 10px;
  }

  .disc-name {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.8vw, 34px);
    font-weight: 300;
    letter-spacing: -0.01em;
    color: var(--black);
    margin-bottom: 8px;
    line-height: 1.1;
  }

  .disc-desc {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--muted);
    line-height: 1.6;
    letter-spacing: 0.02em;
    font-weight: 300;
  }

  /* ── OFF THE CLOCK ── */
  .otc-section {
    margin-bottom: 80px;
    border-top: 1px solid var(--border);
    padding-top: 40px;
  }

  .otc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .otc-tile {
    aspect-ratio: 1 / 1;
    background: var(--warm-white);
    position: relative;
    overflow: hidden;
    cursor: none;
    transition: background 0.4s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  .otc-tile:hover {
    background: var(--off-white);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(44, 26, 14, 0.10);
    z-index: 1;
  }

  html[data-theme="dark"] .otc-tile         { background: var(--warm-white); }
  html[data-theme="dark"] .otc-tile:hover   { background: #2a1c12; }

  /* Reveal layer: hidden by default, shown on .playing or :hover */
  .otc-reveal {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .otc-tile.playing .otc-reveal,
  .otc-tile:hover .otc-reveal  { opacity: 1; }

  /* Caption */
  .otc-caption {
    position: absolute;
    bottom: 12px;
    left: 12px;
    right: 12px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.08em;
    line-height: 1.3;
    color: var(--text-body);
    opacity: 0;
    transition: opacity 0.3s ease 0.15s;
    pointer-events: none;
  }

  .otc-tile.playing .otc-caption,
  .otc-tile:hover .otc-caption  { opacity: 1; }

  /* SVG fills the reveal area */
  .tile-svg {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  /* ── TILE 1: SUBWAY LINES ── */
  .sv-line {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
  }
  .sv-dot {
    opacity: 0;
    transform-origin: center;
    transform: scale(0.2);
  }

  .otc-tile.playing .sv-line {
    animation: drawLine 0.55s ease forwards;
  }
  .otc-tile.playing .sv-dot {
    animation: dotPop 0.3s ease forwards;
  }

  /* ── TILE 2: FIGURES ── */
  .fig-line {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .otc-tile.playing .fig-line {
    animation: drawPath 0.35s ease forwards;
  }

  /* ── TILE 4: GARMENT ── */
  .g-line, .g-mesh {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .otc-tile.playing .g-line {
    animation: drawPath 0.5s ease forwards;
  }
  .otc-tile.playing .g-mesh {
    animation: drawPath 0.4s ease forwards;
    opacity: 0.45;
  }

  /* Slow sway only while playing */
  .garment-svg {
    transform-origin: center;
    transform-style: preserve-3d;
  }
  .otc-tile.playing .garment-svg {
    animation: garmentSway 3s ease-in-out infinite alternate;
  }

  /* ── TILE 6: STEAM POT ── */
  .steam {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: steamRise 2s ease-in infinite;
    animation-play-state: paused;
  }
  .steam-1 { animation-delay: 0s; }
  .steam-2 { animation-delay: 0.55s; }
  .steam-3 { animation-delay: 1.1s; }

  .otc-tile--steam.playing .steam {
    animation-play-state: running;
  }

  .pot-body {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .otc-tile--steam.playing .pot-body {
    animation: drawPath 0.5s ease forwards;
  }

  /* ── TILE 7: KNIT ── */
  .knit-row path {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
  }
  .otc-tile.playing .knit-row path {
    animation: drawPath 0.5s ease forwards;
    animation-delay: var(--row-delay);
  }

  /* ── TILE 8: SWATCHES ── */
  .otc-reveal--swatches { padding: 20px; }

  .swatch-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: repeat(3, 1fr);
    gap: 6px;
    width: 100%;
    height: 100%;
  }

  .swatch {
    opacity: 0;
    transform: scale(0.8);
    transition: none;
  }

  .otc-tile--swatches:hover .swatch {
    animation: swatchIn 0.35s ease forwards;
  }

  /* ── IMAGE TILES ── */
  .otc-tile--img .otc-reveal { padding: 0; }
  .otc-reveal--img { overflow: hidden; }

  .tile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.04);
    transition: transform 0.5s ease;
  }

  .otc-tile--img:hover .tile-img { transform: scale(1.0); }

  /* ── PUZZLE TILE ── */
  .otc-tile--puzzle {
    cursor: default;
    padding: 0;
    overflow: hidden;
  }
  /* No hover lift / translate on puzzle tile */
  .otc-tile--puzzle:hover {
    transform: none;
    box-shadow: none;
  }

  .puzzle-container {
    position: absolute;
    inset: 0;
  }

  .puzzle-piece {
    position: absolute;
    width: calc(100% / 3);
    height: calc(100% / 3);
    background-repeat: no-repeat;
    cursor: none;
    transition: left 0.25s ease, top 0.25s ease;
    box-sizing: border-box;
    border: 0.5px solid rgba(44, 26, 14, 0.08);
  }

  .puzzle-piece:hover {
    filter: brightness(1.06);
    z-index: 1;
  }

  .puzzle-empty {
    position: absolute;
    width: calc(100% / 3);
    height: calc(100% / 3);
    background: var(--warm-white);
    transition: left 0.25s ease, top 0.25s ease;
    animation: pulseEmpty 2.5s ease-in-out infinite;
  }

  html[data-theme="dark"] .puzzle-empty { background: #241810; }

  /* ── EASTER EGG ── */
  .egg-note {
    position: fixed;
    top: 80px;
    right: 48px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    font-weight: 300;
    color: var(--muted);
    max-width: 280px;
    text-align: right;
    pointer-events: none;
    opacity: 0;
    transform: translateY(-6px);
    z-index: 200;
  }

  .egg-note.egg-visible {
    animation: eggIn 0.5s ease forwards;
  }

  .egg-note.egg-hiding {
    animation: eggOut 0.5s ease forwards;
  }

  /* ── KEYFRAMES ── */
  @keyframes drawLine {
    from { stroke-dashoffset: 1; }
    to   { stroke-dashoffset: 0; }
  }

  @keyframes drawPath {
    from { stroke-dashoffset: 100; }
    to   { stroke-dashoffset: 0;   }
  }

  @keyframes dotPop {
    from { opacity: 0; transform: scale(0.2); }
    to   { opacity: 1; transform: scale(1);   }
  }

  @keyframes garmentSway {
    from { transform: perspective(300px) rotateY(-12deg); }
    to   { transform: perspective(300px) rotateY(12deg);  }
  }

  @keyframes steamRise {
    0%   { stroke-dashoffset: 0;   opacity: 0.75; transform: translateY(0);     }
    100% { stroke-dashoffset: -30; opacity: 0;    transform: translateY(-14px); }
  }

  @keyframes swatchIn {
    from { opacity: 0; transform: scale(0.8); }
    to   { opacity: 1; transform: scale(1);   }
  }

  @keyframes pulseEmpty {
    0%, 100% { opacity: 0.4; }
    50%       { opacity: 0.75; }
  }

  @keyframes eggIn {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0);    }
  }

  @keyframes eggOut {
    from { opacity: 1; transform: translateY(0);    }
    to   { opacity: 0; transform: translateY(-6px); }
  }

  /* ── CONTACT ── */
  .contact {
    border-top: 1px solid var(--border);
    padding-top: 40px;
  }

  .contact-list {
    display: flex;
    flex-direction: column;
  }

  .contact-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 22px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--black);
    transition: padding-left 0.3s ease;
    cursor: none;
  }

  .contact-row:hover { padding-left: 8px; }

  .contact-label {
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    width: 80px;
    flex-shrink: 0;
  }

  .contact-value {
    font-family: var(--font-display);
    font-size: clamp(18px, 2.2vw, 26px);
    font-weight: 300;
    font-style: italic;
    transition: color 0.3s ease;
  }

  .contact-row:hover .contact-value { color: var(--sienna); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .about-wrapper { padding: 120px 28px 72px; }
    .disc-grid { grid-template-columns: 1fr; }
    .disc-cell { padding-right: 0 !important; padding-left: 0 !important; border-right: none !important; }
    .contact-value { font-size: 16px; }
    .egg-note { right: 24px; }
  }

  @media (max-width: 640px) {
    .otc-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
