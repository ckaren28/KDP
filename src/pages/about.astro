---
import MainLayout from '../layouts/MainLayout.astro';
import styles from './about.module.css';
const s = styles;
---

<MainLayout title="About — Karen Dettmar">
  <div class={s['about-wrapper']}>

    <!-- Header: name headline only -->
    <div class={`${s['about-header']} reveal`}>
      <h1 class={s['about-title']}>Karen <em>Dettmar</em></h1>
    </div>

    <!-- Bio paragraph -->
    <div class={`${s['bio']} reveal`}>
      <p>
        Equally comfortable draping a dress form and architecting a React component,  I work at the edge of two disciplines that are rarely in the same room.
        My goal is to close that gap; making technology feel considered and making fashion feel intelligent.
      </p>
    </div>

    <!-- Disciplines -->
    <div class={`${s['disciplines']} reveal`}>
      <span class={s['section-label']}>What I do</span>
      <div class={s['disc-grid']}>
        <div class={s['disc-cell']}>
          <span class={s['disc-num']}>01</span>
          <h3 class={s['disc-name']}>Fashion Design</h3>
          <p class={s['disc-desc']}>Draping, construction, CAD, technical flats</p>
        </div>
        <div class={s['disc-cell']}>
          <span class={s['disc-num']}>02</span>
          <h3 class={s['disc-name']}>Creative Technology</h3>
          <p class={s['disc-desc']}>Interactive demos, prototypes, AI tools</p>
        </div>
        <div class={s['disc-cell']}>
          <span class={s['disc-num']}>03</span>
          <h3 class={s['disc-name']}>Front-End Development</h3>
          <p class={s['disc-desc']}>React, Astro, TypeScript, APIs</p>
        </div>
        <div class={s['disc-cell']}>
          <span class={s['disc-num']}>04</span>
          <h3 class={s['disc-name']}>Workshop Facilitation</h3>
          <p class={s['disc-desc']}>Community, education, technical storytelling</p>
        </div>
      </div>
    </div>

