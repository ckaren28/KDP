  </div><!-- /about-wrapper -->

  <!-- Easter egg: floating note (fixed, top-right) -->
  <div class={s['egg-note']} id="eggNote" aria-hidden="true">
    Still here? I'm probably making something.
  </div>

</MainLayout>

<script>
  // ── TRIPLE-CLICK EASTER EGG ──
  const eggNote = document.getElementById('eggNote');
  let eggClicks = 0;
  let eggLastT  = 0;
  let eggTimer: ReturnType<typeof setTimeout> | null = null;

  const themeToggle = document.getElementById('themeToggle');
  themeToggle?.addEventListener('click', () => {
    const now = Date.now();
    if (now - eggLastT > 800) eggClicks = 0;
    eggClicks++;
    eggLastT = now;

    if (eggClicks >= 3 && eggNote) {
      eggClicks = 0;
      localStorage.setItem('easter1', '1');
      if (eggTimer) clearTimeout(eggTimer);
      eggNote.removeAttribute('data-hiding');
      eggNote.setAttribute('data-visible', '');
      eggTimer = setTimeout(() => {
        eggNote.setAttribute('data-hiding', '');
        eggNote.addEventListener('animationend', () => {
          eggNote.removeAttribute('data-visible');
          eggNote.removeAttribute('data-hiding');
        }, { once: true });
      }, 4000);
    }
  });
</script>
