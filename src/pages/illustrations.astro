---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import IllustrationGallery from '../components/IllustrationGallery';

const illustrations = await getCollection('illustrations');
const sortedIllustrations = illustrations.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const illustrationsData = sortedIllustrations.map(ill => ({
  title: ill.data.title,
  image: ill.data.image,
  tags: ill.data.tags,
  description: ill.data.description,
}));
---

<MainLayout title="Illustrations — Karen Dettmar">
  <div class="page-container">

    <span class="page-eyebrow">Visual Work</span>
    <h1 class="page-title">Fashion <em>Illustrations</em></h1>

    <IllustrationGallery illustrations={illustrationsData} client:load />

  </div>
</MainLayout>
