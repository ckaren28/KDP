---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Weaving — Karen Dettmar">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .project-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 120px 2rem 8rem;
      font-family: var(--font-display);
      color: var(--black);
    }

    .back-nav {
      padding: 2.5rem 0 4rem;
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .back-nav a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .back-nav a:hover { color: var(--black); }

    .page-header {
      margin-bottom: 5rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--border);
    }

    .page-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
      display: block;
    }

    .page-title {
      font-size: clamp(3rem, 7vw, 5.5rem);
      font-weight: 300;
      line-height: 0.95;
      letter-spacing: -0.02em;
      font-style: italic;
      margin-bottom: 2rem;
    }

    .page-desc {
      font-family: var(--font-body);
      font-size: 0.9rem;
      line-height: 1.75;
      color: var(--text-body);
      max-width: 52ch;
      font-weight: 300;
    }

    .meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 3rem;
      margin-bottom: 5rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--border);
    }

    .meta-label {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.5rem;
      display: block;
    }

    .meta-value {
      font-family: var(--font-body);
      font-size: 0.85rem;
      color: var(--text-body);
      font-weight: 300;
    }

    .image-full {
      width: 100%;
      cursor: zoom-in;
      overflow: hidden;
    }

    .image-full img {
      width: 100%;
      display: block;
      transition: opacity 0.3s ease, transform 0.7s cubic-bezier(0.16,1,0.3,1);
    }
    .image-full:hover img { opacity: 0.9; transform: scale(1.01); }

    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(24,16,10,0.96);
      z-index: 500;
      align-items: center;
      justify-content: center;
      padding: 32px;
      cursor: zoom-out;
    }
    .lightbox.open { display: flex; }
    .lightbox img {
      max-width: 100%;
      max-height: 92vh;
      object-fit: contain;
      display: block;
      cursor: default;
    }
    .lightbox-close {
      position: absolute;
      top: 24px; right: 32px;
      background: none; border: none;
      color: rgba(237,229,208,0.5);
      font-size: 11px; letter-spacing: 0.16em;
      text-transform: uppercase;
      cursor: pointer;
      font-family: var(--font-body);
      transition: color 0.2s;
    }
    .lightbox-close:hover { color: rgba(237,229,208,1); }

    .next-project {
      margin-top: 8rem;
      padding-top: 3rem;
      border-top: 1px solid var(--border);
      display: flex;
      gap: 3rem;
    }
    .next-all {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .next-all:hover { color: var(--black); }
  </style>

  <div class="project-page">

    <nav class="back-nav">
      <a href="/projects/textiles">← Textile Practice</a>
    </nav>

    <header class="page-header">
      <span class="page-label">Textile Practice · Fiber · Structure</span>
      <h1 class="page-title">Weaving</h1>
      <p class="page-desc">
        Hand-woven textile exploring warp and weft structure. Materials sourced from a local weaving studio in the Upper East Side — old yarn and felting scraps purchased directly from the studio's remnant supply. Working with pre-loved materials introduced an element of chance: the color palette and texture were determined by what was available, making the sourcing as much a part of the process as the weaving itself.
      </p>
    </header>

    <div class="meta-row">
      <div class="meta-item">
        <span class="meta-label">Practice</span>
        <span class="meta-value">Textile Practice · Parsons, 2025</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Materials</span>
        <span class="meta-value">Reclaimed yarn · Felting scraps</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Source</span>
        <span class="meta-value">Local weaving studio, Upper East Side</span>
      </div>
    </div>

    <div class="image-full lightbox-trigger" data-src="/images/weaving/weaving.JPG" data-alt="Woven sample using reclaimed yarn and felting scraps">
      <img src="/images/weaving/weaving.JPG" alt="Woven sample using reclaimed yarn and felting scraps" />
    </div>

    <div class="next-project">
      <a href="/projects/textiles" class="next-all">← Textile Practice</a>
      <a href="/projects/fashion" class="next-all">All Fashion →</a>
    </div>

  </div>

  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightboxClose">Close ×</button>
    <img id="lightboxImg" src="" alt="" />
  </div>

  <script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement | null;

    document.querySelectorAll('.lightbox-trigger').forEach(el => {
      el.addEventListener('click', () => {
        if (!lightbox || !lightboxImg) return;
        lightboxImg.src = (el as HTMLElement).dataset.src || '';
        lightboxImg.alt = (el as HTMLElement).dataset.alt || '';
        lightbox.classList.add('open');
      });
    });

    function closeLightbox() { lightbox?.classList.remove('open'); }
    document.getElementById('lightboxClose')?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
  </script>

</MainLayout>
