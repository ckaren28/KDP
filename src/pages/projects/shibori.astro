---
import MainLayout from '../../layouts/MainLayout.astro';

const finals: { src: string; alt: string; caption?: string }[] = [
  { src: '/images/shibori/Shibori1.jpg', alt: 'Shibori — result 1' },
  { src: '/images/shibori/Shibori2.jpg', alt: 'Shibori — result 2' },
  { src: '/images/shibori/Shibori3.jpg', alt: 'Shibori — result 3' },
  { src: '/images/shibori/Shibori4.jpg', alt: 'Shibori — result 4' },
  { src: '/images/shibori/Shibori5.jpg', alt: 'Shibori — result 5' },
  { src: '/images/shibori/Shibori6.jpg', alt: 'Shibori — result 6' },
  { src: '/images/shibori/Shibori7.jpg', alt: 'Shibori — result 7' },
];

const process: { src: string; alt: string; caption?: string }[] = [
   { src: '/images/shibori/shibori-process-binding.png', alt: 'binding process', caption: 'Binding cloth' },
  { src: '/images/shibori/indigo-dying-process.gif', alt: 'Indigo dyeing process', caption: 'Indigo Dye Bath' },
  { src: '/images/shibori/Shibori-process1.JPG', alt: 'Shibori process — dye bath', caption: 'Oxidation' },
  { src: '/images/shibori/Shibori-process2.JPG', alt: 'Shibori process — reveal', caption: 'Unfolding the resist' },
];
---

<MainLayout title="Shibori — Karen Dettmar">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .project-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 120px 2rem 8rem;
      font-family: var(--font-display);
      color: var(--black);
    }

    .back-nav {
      padding: 2.5rem 0 4rem;
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .back-nav a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .back-nav a:hover { color: var(--black); }

    .page-header {
      margin-bottom: 5rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--border);
    }

    .page-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
      display: block;
    }

    .page-title {
      font-size: clamp(3rem, 7vw, 5.5rem);
      font-weight: 300;
      line-height: 0.95;
      letter-spacing: -0.02em;
      font-style: italic;
      margin-bottom: 2rem;
    }

    .page-desc {
      font-family: var(--font-body);
      font-size: 0.9rem;
      line-height: 1.75;
      color: var(--text-body);
      max-width: 52ch;
      font-weight: 300;
    }

    .meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 3rem;
      margin-bottom: 5rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--border);
    }

    .meta-label {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.5rem;
      display: block;
    }

    .meta-value {
      font-family: var(--font-body);
      font-size: 0.85rem;
      color: var(--text-body);
      font-weight: 300;
    }

    /* ── MAIN GALLERY — masonry 2 col ── */
    .image-grid {
      columns: 2;
      column-gap: 4px;
      margin-bottom: 6rem;
    }

    .image-item {
      break-inside: avoid;
      margin-bottom: 4px;
      position: relative;
      cursor: zoom-in;
      overflow: hidden;
    }

    .image-item img {
      width: 100%;
      display: block;
      object-fit: cover;
      transition: opacity 0.3s ease, transform 0.7s cubic-bezier(0.16,1,0.3,1);
    }
    .image-item:hover img { opacity: 0.9; transform: scale(1.01); }

    .image-caption {
      font-family: var(--font-body);
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      color: var(--muted);
      text-transform: uppercase;
      padding: 8px 0 0;
    }

    /* ── PROCESS SECTION ── */
    .section-label {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 2rem;
      padding-top: 4rem;
      border-top: 1px solid var(--border);
    }

    .process-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 4px;
      max-width: 100%;
    }

    .process-grid .image-item {
      margin-bottom: 0;
    }

    .process-grid .image-item img {
      height: 260px;
      width: 100%;
      object-fit: cover;
      display: block;
    }

    /* ── LIGHTBOX ── */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(10,18,30,0.97);
      z-index: 500;
      align-items: center;
      justify-content: center;
      padding: 32px;
      cursor: zoom-out;
    }
    .lightbox.open { display: flex; }
    .lightbox img {
      max-width: 100%;
      max-height: 92vh;
      object-fit: contain;
      display: block;
      cursor: default;
    }
    .lightbox-close {
      position: absolute;
      top: 24px; right: 32px;
      background: none; border: none;
      color: rgba(200,210,230,0.5);
      font-size: 11px; letter-spacing: 0.16em;
      text-transform: uppercase;
      cursor: pointer;
      font-family: var(--font-body);
      transition: color 0.2s;
    }
    .lightbox-close:hover { color: rgba(200,210,230,1); }

    /* ── PROJECT NAV ── */
    .project-nav {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-top: 6rem;
      margin-bottom: 2rem;
    }
    .project-nav-link {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .project-nav-link:hover { color: var(--black); }

    /* ── FOOTER NAV ── */
    .next-project {
      margin-top: 0;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }
    .next-all {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .next-all:hover { color: var(--black); }

    @media (max-width: 768px) {
      .image-grid { columns: 1; }
      .process-grid { columns: 1; }
      .meta-row { gap: 2rem; }
    }
  </style>

  <div class="project-page">

    <nav class="back-nav">
      <a href="/projects/textiles">← Textile Practice</a>
    </nav>

    <header class="page-header">
      <span class="page-label">Textile Practice · Dyeing · Resist</span>
      <h1 class="page-title">Shibori</h1>
      <p class="page-desc">
        Indigo shibori resist dyeing on cotton. Itajime, arashi, and kumo techniques explored across a series of scarves. Each fold becomes a blueprint. The dye reads the pressure, the cloth holds the pattern after the resist is removed.
      </p>
    </header>

    <div class="meta-row">
      <div class="meta-item">
        <span class="meta-label">Fiber</span>
        <span class="meta-value">Cotton</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Dye</span>
        <span class="meta-value">Natural indigo vat</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Technique</span>
        <span class="meta-value">Itajime · Arashi · Resist binding</span>
      </div>
    </div>

    <p class="section-label">Process</p>

    <div class="process-grid">
      {process.map((img) => (
        <div class="image-item lightbox-trigger" data-src={img.src} data-alt={img.alt}>
          <img src={img.src} alt={img.alt} loading="lazy" />
          {img.caption && <p class="image-caption">{img.caption}</p>}
        </div>
      ))}
    </div>

    <p class="section-label">Results</p>

    <div class="image-grid">
      {finals.map((img) => (
        <div class="image-item lightbox-trigger" data-src={img.src} data-alt={img.alt}>
          <img src={img.src} alt={img.alt} loading="lazy" />
          {img.caption && <p class="image-caption">{img.caption}</p>}
        </div>
      ))}
    </div>

    <div class="project-nav">
      <span></span>
      <a href="/projects/marbling" class="project-nav-link">Marbling →</a>
    </div>
    <div class="next-project">
      <a href="/projects/textiles" class="next-all">← Textile Practice</a>
    </div>

  </div>

  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightboxClose">Close ×</button>
    <img id="lightboxImg" src="" alt="" />
  </div>

  <script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement | null;

    document.querySelectorAll('.lightbox-trigger').forEach(el => {
      el.addEventListener('click', () => {
        if (!lightbox || !lightboxImg) return;
        lightboxImg.src = (el as HTMLElement).dataset.src || '';
        lightboxImg.alt = (el as HTMLElement).dataset.alt || '';
        lightbox.classList.add('open');
      });
    });

    function closeLightbox() { lightbox?.classList.remove('open'); }
    document.getElementById('lightboxClose')?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
  </script>

</MainLayout>
