---
import MainLayout from '../../layouts/MainLayout.astro';

const process: { src: string; alt: string; caption?: string }[] = [
  { src: '/images/marbling/Marbling-process1.JPG', alt: 'Marbling process — laying dye on size', caption: 'Laying dye on carrageenan size' },
  { src: '/images/marbling/marbling-process0.JPG', alt: 'Marbling process — raking pattern', caption: 'Raking the pattern' },
];

const finals: { src: string; alt: string; caption?: string }[] = [
  { src: '/images/marbling/marblingfinal1.JPG', alt: 'Marbled fabric — violet, gold, and orange swirls' },
  { src: '/images/marbling/marbling-final2.JPG', alt: 'Marbled fabric — second sample' },
];
---

<MainLayout title="Marbling — Karen Dettmar">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── MARBLING PALETTE — fixed light theme regardless of OS dark mode ── */
    .marbling-page {
      --m-purple:  #6B55A2;
      --m-gold:    #C8961C;
      --m-orange:  #C4773E;
      --m-teal:    #7AAEB4;
      --m-cream:   #F7F3E8;
      --m-border:  rgba(107, 85, 162, 0.18);
      --m-muted:   #7A6E8A;
      --m-text:    #1A1208;
    }

    .marbling-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 120px 2rem 8rem;
      font-family: var(--font-display);
      color: #1A1208;
      background: #F7F3E8;
      min-height: 100vh;
    }

    /* Override global bg for this page */
    body:has(.marbling-page) {
      background: #F7F3E8;
    }

    .back-nav {
      padding: 2.5rem 0 4rem;
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .back-nav a { color: var(--m-muted); text-decoration: none; transition: color 0.2s; }
    .back-nav a:hover { color: var(--m-purple); }

    .page-header {
      margin-bottom: 5rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--m-border);
    }

    .page-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--m-muted);
      margin-bottom: 1.5rem;
      display: block;
    }

    .page-title {
      font-size: clamp(3rem, 7vw, 5.5rem);
      font-weight: 300;
      line-height: 0.95;
      letter-spacing: -0.02em;
      font-style: italic;
      margin-bottom: 2rem;
      color: #1A1208;
    }

    .page-title span { color: var(--m-purple); }

    .page-desc {
      font-family: var(--font-body);
      font-size: 0.9rem;
      line-height: 1.75;
      color: #3D3020;
      max-width: 52ch;
      font-weight: 300;
    }

    .meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 3rem;
      margin-bottom: 5rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--m-border);
    }

    .meta-label {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--m-muted);
      margin-bottom: 0.5rem;
      display: block;
    }

    .meta-value {
      font-family: var(--font-body);
      font-size: 0.85rem;
      color: #3D3020;
      font-weight: 300;
    }

    /* ── COLOR SWATCHES ── */
    .palette-row {
      display: flex;
      gap: 12px;
      margin-bottom: 5rem;
      align-items: center;
    }

    .swatch {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .palette-label {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--m-muted);
      margin-left: 4px;
    }

    /* ── SECTION LABEL ── */
    .section-label {
      font-family: var(--font-body);
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--m-muted);
      opacity: 0.7;
      margin-bottom: 1.5rem;
      padding-top: 4rem;
      border-top: 1px solid var(--m-border);
      display: block;
    }

    /* ── PROCESS GRID — 3 col, smaller ── */
    .process-grid {
      columns: 3;
      column-gap: 4px;
      margin-bottom: 0;
    }

    /* ── IMAGE GRID — masonry, 2 col finals ── */
    .image-grid {
      columns: 2;
      column-gap: 4px;
    }

    .image-item {
      break-inside: avoid;
      margin-bottom: 4px;
      position: relative;
      cursor: zoom-in;
      overflow: hidden;
    }

    .image-item img {
      width: 100%;
      display: block;
      transition: opacity 0.3s ease, transform 0.7s cubic-bezier(0.16,1,0.3,1);
    }
    .image-item:hover img { opacity: 0.9; transform: scale(1.01); }

    .image-caption {
      font-family: var(--font-body);
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      color: var(--m-muted);
      text-transform: uppercase;
      padding: 8px 0 0;
    }

    /* ── LIGHTBOX (dark with purple tint) ── */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(18,12,32,0.97);
      z-index: 500;
      align-items: center;
      justify-content: center;
      padding: 32px;
      cursor: zoom-out;
    }
    .lightbox.open { display: flex; }
    .lightbox img {
      max-width: 100%;
      max-height: 92vh;
      object-fit: contain;
      display: block;
      cursor: default;
    }
    .lightbox-close {
      position: absolute;
      top: 24px; right: 32px;
      background: none; border: none;
      color: rgba(180,160,220,0.5);
      font-size: 11px; letter-spacing: 0.16em;
      text-transform: uppercase;
      cursor: pointer;
      font-family: var(--font-body);
      transition: color 0.2s;
    }
    .lightbox-close:hover { color: rgba(180,160,220,1); }

    /* ── FOOTER NAV ── */
    .next-project {
      margin-top: 8rem;
      padding-top: 3rem;
      border-top: 1px solid var(--m-border);
      display: flex;
      gap: 3rem;
    }
    .next-all {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--m-muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .next-all:hover { color: var(--m-purple); }

    @media (max-width: 768px) {
      .image-grid { columns: 1; }
      .meta-row { gap: 2rem; }
    }
  </style>

  <div class="marbling-page">

    <nav class="back-nav">
      <a href="/projects/textiles">← Textile Practice</a>
    </nav>

    <header class="page-header">
      <span class="page-label">Textile Practice · Dyeing · Surface</span>
      <h1 class="page-title">Mar<span>bling</span></h1>
      <p class="page-desc">
        Marbling exploring color, fluid pattern, and surface tension. Violet, golden yellow, and burnt orange dyes were floated on a carrageenan size, swirled and combed into motion, then lifted onto cloth in a single press.
      </p>
    </header>

    <div class="meta-row">
      <div class="meta-item">
        <span class="meta-label">Practice</span>
        <span class="meta-value">Textile Practice · Parsons, 2025</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Medium</span>
        <span class="meta-value">Carrageenan size · Fabric dye</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Colors</span>
        <span class="meta-value">Violet · Golden yellow · Burnt orange · Sage</span>
      </div>
    </div>

    <div class="palette-row">
      <div class="swatch" style="background:#6B55A2;"></div>
      <div class="swatch" style="background:#C8961C;"></div>
      <div class="swatch" style="background:#C4773E;"></div>
      <div class="swatch" style="background:#7AAEB4;"></div>
      <span class="palette-label">Dye palette</span>
    </div>

    <span class="section-label">Process</span>
    <div class="process-grid">
      {process.map((img: { src: string; alt: string; caption?: string }) => (
        <div class="image-item lightbox-trigger" data-src={img.src} data-alt={img.alt}>
          <img src={img.src} alt={img.alt} loading="lazy" />
          {img.caption && <p class="image-caption">{img.caption}</p>}
        </div>
      ))}
    </div>

    <span class="section-label">Results</span>
    <div class="image-grid">
      {finals.map((img: { src: string; alt: string; caption?: string }) => (
        <div class="image-item lightbox-trigger" data-src={img.src} data-alt={img.alt}>
          <img src={img.src} alt={img.alt} loading="lazy" />
          {img.caption && <p class="image-caption">{img.caption}</p>}
        </div>
      ))}
    </div>

    <div class="next-project">
      <a href="/projects/textiles" class="next-all">← Textile Practice</a>
      <a href="/projects/fashion" class="next-all">All Fashion →</a>
    </div>

  </div>

  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightboxClose">Close ×</button>
    <img id="lightboxImg" src="" alt="" />
  </div>

  <script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement | null;

    document.querySelectorAll('.lightbox-trigger').forEach(el => {
      el.addEventListener('click', () => {
        if (!lightbox || !lightboxImg) return;
        lightboxImg.src = (el as HTMLElement).dataset.src || '';
        lightboxImg.alt = (el as HTMLElement).dataset.alt || '';
        lightbox.classList.add('open');
      });
    });

    function closeLightbox() { lightbox?.classList.remove('open'); }
    document.getElementById('lightboxClose')?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
  </script>

</MainLayout>
