---
// src/pages/projects/traveller.astro
// Drop this file into your src/pages/projects/ directory
// Update image paths to match your actual uploaded image filenames

import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Traveller — Karen Dettmar">

  <style>
    /* ─── Reset & Base ─── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .project-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 120px 2rem 8rem;
      font-family: 'Georgia', 'Times New Roman', serif;
      color: #1a1a1a;
    }

    /* ─── Back Nav ─── */
    .back-nav {
      padding: 2.5rem 0 4rem;
      font-family: 'Arial', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .back-nav a {
      color: #888;
      text-decoration: none;
      transition: color 0.2s;
    }
    .back-nav a:hover { color: #1a1a1a; }

    /* ─── Hero ─── */
    .hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: end;
      margin-bottom: 7rem;
    }

    .hero-image {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
      display: block;
    }

    .hero-image-placeholder {
      width: 100%;
      aspect-ratio: 3/4;
      background: #f0ede8;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Arial', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #aaa;
    }

    .hero-text {
      padding-bottom: 1rem;
    }

    .hero-label {
      font-family: 'Arial', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #999;
      margin-bottom: 1.5rem;
    }

    .hero-title {
      font-size: clamp(3.5rem, 8vw, 6.5rem);
      font-weight: 400;
      line-height: 0.95;
      letter-spacing: -0.02em;
      margin-bottom: 2.5rem;
      font-style: italic;
    }

    .hero-subtitle {
      font-family: 'Arial', sans-serif;
      font-size: 0.85rem;
      line-height: 1.7;
      color: #555;
      max-width: 32ch;
      margin-bottom: 3rem;
    }

    .hero-meta {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .hero-meta-item {
      display: flex;
      gap: 1.5rem;
      font-family: 'Arial', sans-serif;
      font-size: 0.72rem;
      letter-spacing: 0.08em;
    }

    .meta-label {
      text-transform: uppercase;
      color: #bbb;
      width: 6rem;
      flex-shrink: 0;
    }

    .meta-value { color: #444; }

    /* ─── Concept Section ─── */
    .section {
      margin-bottom: 7rem;
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: 2rem;
      margin-bottom: 3rem;
    }

    .section-number {
      font-family: 'Arial', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #ccc;
    }

    .section-title {
      font-family: 'Arial', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #1a1a1a;
    }

    .section-rule {
      flex: 1;
      height: 1px;
      background: #e0e0e0;
    }

    .concept-text {
      max-width: 65ch;
      font-size: 1.15rem;
      line-height: 1.85;
      color: #333;
    }

    .concept-text p + p { margin-top: 1.5rem; }

    /* ─── Principles ─── */
    .principles {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      margin-bottom: 7rem;
    }

    .principle {
      background: #f7f5f2;
      padding: 3rem 2rem;
    }

    .principle-number {
      font-family: 'Arial', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #bbb;
      margin-bottom: 1.5rem;
    }

    .principle-text {
      font-size: 1.4rem;
      font-style: italic;
      line-height: 1.3;
      color: #1a1a1a;
    }

    .principle-caption {
      font-family: 'Arial', sans-serif;
      font-size: 0.78rem;
      line-height: 1.6;
      color: #777;
      margin-top: 1rem;
    }

    /* ─── Mood Board ─── */
    .moodboard-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      grid-template-rows: auto auto;
      gap: 2px;
    }

    .moodboard-grid .img-main {
      grid-row: 1 / 3;
    }

    .moodboard-grid img,
    .moodboard-grid .img-placeholder {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .img-placeholder {
      background: #ece9e4;
      aspect-ratio: 4/3;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Arial', sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #bbb;
    }

    .img-placeholder.tall { aspect-ratio: 2/3; }
    .img-placeholder.square { aspect-ratio: 1/1; }

    /* ─── Sketches ─── */
    .sketches-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }

    .sketch-item img,
    .sketch-item .img-placeholder {
      width: 100%;
      aspect-ratio: 2/3;
      object-fit: cover;
      display: block;
    }

    .sketch-caption {
      font-family: 'Arial', sans-serif;
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      color: #999;
      margin-top: 0.75rem;
      text-transform: uppercase;
    }

    /* ─── Flats + Swatches ─── */
    .technical-grid {
      display: grid;
      grid-template-columns: 3fr 2fr;
      gap: 4rem;
      align-items: start;
    }

    .flats-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
    }

    .flat-item img,
    .flat-item .img-placeholder {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: contain;
      background: #f7f5f2;
      display: block;
    }

    .swatches-title {
      font-family: 'Arial', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #999;
      margin-bottom: 2rem;
    }

    .swatch-list {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .swatch-item {
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }

    .swatch-color {
      width: 3rem;
      height: 3rem;
      flex-shrink: 0;
      border: 1px solid rgba(0,0,0,0.06);
    }

    .swatch-info {
      font-family: 'Arial', sans-serif;
    }

    .swatch-name {
      font-size: 0.8rem;
      color: #222;
      margin-bottom: 0.2rem;
    }

    .swatch-note {
      font-size: 0.68rem;
      color: #999;
      letter-spacing: 0.04em;
    }

    /* ─── Process Note ─── */
    .process-note {
      border-left: 1px solid #ddd;
      padding-left: 2rem;
      max-width: 55ch;
    }

    .process-note p {
      font-size: 1rem;
      line-height: 1.8;
      color: #555;
    }

    /* ─── Next Project Nav ─── */
    .next-project {
      margin-top: 8rem;
      padding-top: 3rem;
      border-top: 1px solid #e8e8e8;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .next-all {
      font-family: 'Arial', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #888;
      text-decoration: none;
      transition: color 0.2s;
    }
    .next-all:hover { color: #1a1a1a; }

    .next-link {
      text-decoration: none;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.4rem;
      transition: opacity 0.2s;
    }
    .next-link:hover { opacity: 0.6; }

    .next-label {
      font-family: 'Arial', sans-serif;
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #bbb;
    }

    .next-title {
      font-size: 1.4rem;
      font-style: italic;
      color: #1a1a1a;
    }

    /* ─── Responsive ─── */
    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr; gap: 2rem; }
      .principles { grid-template-columns: 1fr; }
      .moodboard-grid { grid-template-columns: 1fr; }
      .moodboard-grid .img-main { grid-row: auto; }
      .technical-grid { grid-template-columns: 1fr; gap: 3rem; }
      .sketches-grid { grid-template-columns: 1fr 1fr; }
      .flats-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>

  <div class="project-page">

    <!-- Back Nav -->
    <nav class="back-nav">
      <a href="/projects">← All Projects</a>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <!-- Replace src with your actual mood board hero image -->
      <div class="hero-image-placeholder tall">Mood Board Hero Image</div>

      <div class="hero-text">
        <p class="hero-label">Parsons School of Design · 2024</p>
        <h1 class="hero-title">Traveller</h1>
        <p class="hero-subtitle">
          A modular collection for living in motion. Designed for packing light, wearing twice, and arriving ready.
        </p>
        <div class="hero-meta">
          <div class="hero-meta-item">
            <span class="meta-label">Category</span>
            <span class="meta-value">Full Collection Concept</span>
          </div>
          <div class="hero-meta-item">
            <span class="meta-label">School</span>
            <span class="meta-value">Parsons School of Design</span>
          </div>
          <div class="hero-meta-item">
            <span class="meta-label">Deliverables</span>
            <span class="meta-value">Mood Board, Sketches, Technical Flats, Swatches</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Concept -->
    <section class="section">
      <div class="section-header">
        <span class="section-number">01</span>
        <span class="section-title">Concept</span>
        <div class="section-rule"></div>
      </div>
      <div class="concept-text">
        <p>
          Traveller began with a suitcase and a question: what do you keep when you have to leave everything behind?
        </p>
        <p>
          Designed during a period of personal transition — moving cities, living without a fixed address, existing between places — this collection explores modular dressing as a philosophy rather than a gimmick. Each piece is designed to pack flat, layer intuitively, and shift between contexts: a dinner, a flight, a meeting, a morning walk in an unfamiliar city.
        </p>
        <p>
          The woman this collection is for knows how to travel light without looking like it. She moves through the world with intention. Her wardrobe doesn't announce itself.
        </p>
      </div>
    </section>

    <!-- Principles -->
    <div class="principles">
      <div class="principle">
        <div class="principle-number">Principle 01</div>
        <div class="principle-text">Pack flat.</div>
        <p class="principle-caption">Every silhouette considered for the suitcase first.</p>
      </div>
      <div class="principle">
        <div class="principle-number">Principle 02</div>
        <div class="principle-text">Wear twice.</div>
        <p class="principle-caption">Each piece designed to function across at least two distinct contexts.</p>
      </div>
      <div class="principle">
        <div class="principle-number">Principle 03</div>
        <div class="principle-text">Arrive ready.</div>
        <p class="principle-caption">No piece that requires ironing, steaming, or special care on the road.</p>
      </div>
    </div>

    <!-- Mood Board -->
    <section class="section">
      <div class="section-header">
        <span class="section-number">02</span>
        <span class="section-title">Mood Board</span>
        <div class="section-rule"></div>
      </div>
      <div class="moodboard-grid">
        <!-- Replace these placeholders with your actual mood board images -->
        <!-- <img class="img-main" src="/images/traveller/moodboard-main.jpg" alt="Traveller mood board" /> -->
        <div class="img-placeholder tall img-main">Mood Board — Main Image</div>
        <div class="img-placeholder square">Reference 01</div>
        <div class="img-placeholder square">Reference 02</div>
      </div>
    </section>

    <!-- Sketches -->
    <section class="section">
      <div class="section-header">
        <span class="section-number">03</span>
        <span class="section-title">Sketches & Ideation</span>
        <div class="section-rule"></div>
      </div>
      <div class="sketches-grid">
        <!-- Replace placeholders with your actual sketch images -->
        <div class="sketch-item">
          <div class="img-placeholder">Sketch 01</div>
          <p class="sketch-caption">Look 01 — Departure</p>
        </div>
        <div class="sketch-item">
          <div class="img-placeholder">Sketch 02</div>
          <p class="sketch-caption">Look 02 — In Transit</p>
        </div>
        <div class="sketch-item">
          <div class="img-placeholder">Sketch 03</div>
          <p class="sketch-caption">Look 03 — Arrival</p>
        </div>
      </div>
    </section>

    <!-- Technical Flats + Swatches -->
    <section class="section">
      <div class="section-header">
        <span class="section-number">04</span>
        <span class="section-title">Technical Development</span>
        <div class="section-rule"></div>
      </div>
      <div class="technical-grid">
        <div>
          <div class="flats-grid">
            <!-- Replace placeholders with your actual flat images -->
            <div class="flat-item"><div class="img-placeholder">Flat 01 — Front</div></div>
            <div class="flat-item"><div class="img-placeholder">Flat 01 — Back</div></div>
            <div class="flat-item"><div class="img-placeholder">Flat 02 — Front</div></div>
            <div class="flat-item"><div class="img-placeholder">Flat 02 — Back</div></div>
          </div>
        </div>
        <div>
          <p class="swatches-title">Material Palette</p>
          <div class="swatch-list">
            <!-- Update colors and names to match your actual swatches -->
            <div class="swatch-item">
              <div class="swatch-color" style="background: #d4cfc8;"></div>
              <div class="swatch-info">
                <div class="swatch-name">Stone</div>
                <div class="swatch-note">Wrinkle-resistant, packs flat</div>
              </div>
            </div>
            <div class="swatch-item">
              <div class="swatch-color" style="background: #2c2c2a;"></div>
              <div class="swatch-info">
                <div class="swatch-name">Noir</div>
                <div class="swatch-note">Versatile base, day to evening</div>
              </div>
            </div>
            <div class="swatch-item">
              <div class="swatch-color" style="background: #8c8070;"></div>
              <div class="swatch-info">
                <div class="swatch-name">Warm Taupe</div>
                <div class="swatch-note">Accent, works across climates</div>
              </div>
            </div>
            <div class="swatch-item">
              <div class="swatch-color" style="background: #e8e4de;"></div>
              <div class="swatch-info">
                <div class="swatch-name">Chalk</div>
                <div class="swatch-note">Lightweight layer</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Process Note -->
    <section class="section">
      <div class="section-header">
        <span class="section-number">05</span>
        <span class="section-title">Process</span>
        <div class="section-rule"></div>
      </div>
      <div class="process-note">
        <p>
          Developed through mood research, hand sketching, and CAD technical flat work. Fabric selection prioritized wrinkle resistance, packability, and a restrained palette that travels well across climates and occasions. The collection was designed to be finished in construction — the next phase would be full pattern development and sample making.
        </p>
      </div>
    </section>

    <!-- Project Navigation -->
    <div class="next-project">
      <a href="/projects" class="next-all">← All Projects</a>
      <a href="/projects/project-1" class="next-link">
        <span class="next-label">Next Project</span>
        <span class="next-title">Sustainable Evening Gown →</span>
      </a>
    </div>

  </div>

</MainLayout>