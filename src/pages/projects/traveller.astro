---
// src/pages/projects/traveller.astro
// Drop this file into your src/pages/projects/ directory
// Update image paths to match your actual uploaded image filenames

import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Traveler — Karen Dettmar">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .project-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 120px 2rem 8rem;
      font-family: var(--font-display);
      color: var(--black);
    }

    .back-nav {
      padding: 2.5rem 0 4rem;
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .back-nav a {
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .back-nav a:hover { color: var(--black); }

    .hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: end;
      margin-bottom: 7rem;
    }

    .hero-image {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
      display: block;
    }

    .hero-image-placeholder {
      width: 100%;
      aspect-ratio: 3/4;
      background: var(--placeholder-bg);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .hero-text { padding-bottom: 1rem; }

    .hero-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
    }

    .hero-title {
      font-size: clamp(3.5rem, 8vw, 6.5rem);
      font-weight: 300;
      line-height: 0.95;
      letter-spacing: -0.02em;
      margin-bottom: 2.5rem;
      font-style: italic;
    }

    .hero-subtitle {
      font-family: var(--font-body);
      font-size: 0.85rem;
      line-height: 1.75;
      color: var(--text-body);
      max-width: 32ch;
      margin-bottom: 3rem;
      font-weight: 300;
    }

    .hero-meta { display: flex; flex-direction: column; gap: 0; }

    .hero-meta-item {
      display: flex;
      gap: 1.5rem;
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
    }

    .meta-label {
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.65rem;
      color: var(--muted);
      width: 6rem;
      flex-shrink: 0;
    }

    .meta-value { color: var(--text-body); }

    .section { margin-bottom: 7rem; }

    .section-header {
      display: flex;
      align-items: center;
      gap: 2rem;
      margin-bottom: 3rem;
    }

    .section-number {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .section-title {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--black);
    }

    .section-rule {
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .concept-text {
      max-width: 65ch;
      font-size: 1.12rem;
      line-height: 1.88;
      color: var(--text-body);
      font-weight: 300;
    }

    .concept-text p + p { margin-top: 1.5rem; }

    .principles {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      margin-bottom: 7rem;
    }

    .principle {
      background: var(--placeholder-bg);
      padding: 3rem 2rem;
    }

    .principle-number {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
    }

    .principle-text {
      font-size: 1.4rem;
      font-style: italic;
      font-weight: 300;
      line-height: 1.3;
      color: var(--black);
    }

    .principle-caption {
      font-family: var(--font-body);
      font-size: 0.78rem;
      line-height: 1.6;
      color: var(--text-body);
      margin-top: 1rem;
      font-weight: 300;
    }

    .moodboard-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      grid-template-rows: auto auto;
      gap: 2px;
    }

    .reference-stack {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .reference-stack img {
      width: 100%;
      height: auto;
      display: block;
    }

    .img-placeholder {
      background: var(--placeholder-bg);
      aspect-ratio: 4/3;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .img-placeholder.tall { aspect-ratio: 2/3; }
    .img-placeholder.square { aspect-ratio: 1/1; }

    .sketches-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 2px;
    }

    .sketch-item {
      display: flex;
      flex-direction: column;
    }

    .sketch-item .sketch-img-wrap {
      aspect-ratio: 2/3;
      overflow: hidden;
      background: transparent;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .sketch-item img,
    .sketch-item .img-placeholder {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }

    .sketch-caption {
      font-family: var(--font-body);
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      color: var(--muted);
      margin-top: 0.75rem;
      text-transform: uppercase;
    }

    .technical-grid {
      display: grid;
      grid-template-columns: 3fr 2fr;
      gap: 4rem;
      align-items: start;
    }

    .flats-grid {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .flat-item img {
      width: 100%;
      display: block;
      object-fit: contain;
      background: var(--placeholder-bg);
      cursor: zoom-in;
      transition: opacity 0.2s ease;
    }
    .flat-item img:hover { opacity: 0.88; }

    /* ── LIGHTBOX ── */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(24,16,10,0.96);
      z-index: 500;
      align-items: center;
      justify-content: center;
      padding: 32px;
      cursor: zoom-out;
    }
    .lightbox.open { display: flex; }
    .lightbox img {
      max-width: 100%;
      max-height: 92vh;
      object-fit: contain;
      display: block;
      cursor: default;
    }
    .lightbox-close {
      position: absolute;
      top: 24px; right: 32px;
      background: none; border: none;
      color: rgba(237,229,208,0.5);
      font-size: 11px; letter-spacing: 0.16em;
      text-transform: uppercase;
      cursor: pointer;
      font-family: var(--font-body);
      transition: color 0.2s;
    }
    .lightbox-close:hover { color: rgba(237,229,208,1); }

    .swatches-title {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 2rem;
    }

    .swatch-list { display: flex; flex-direction: column; gap: 1.5rem; }

    .swatch-item { display: flex; align-items: center; gap: 1.25rem; }

    .swatch-color {
      width: 3rem;
      height: 3rem;
      flex-shrink: 0;
      border: 1px solid var(--border);
    }

    .swatch-info { font-family: var(--font-body); }

    .swatch-name {
      font-size: 0.8rem;
      color: var(--black);
      margin-bottom: 0.2rem;
    }

    .swatch-note {
      font-size: 0.68rem;
      color: var(--muted);
      letter-spacing: 0.04em;
    }

    .process-note {
      border-left: 1px solid var(--border);
      padding-left: 2rem;
      max-width: 55ch;
    }

    .process-note p {
      font-size: 1rem;
      line-height: 1.85;
      color: var(--text-body);
      font-weight: 300;
    }

    .next-project {
      margin-top: 8rem;
      padding-top: 3rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .next-all {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .next-all:hover { color: var(--black); }

    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr; gap: 2rem; }
      .principles { grid-template-columns: 1fr; }
      .moodboard-grid { grid-template-columns: 1fr; }
      .moodboard-grid .img-main { grid-row: auto; }
      .technical-grid { grid-template-columns: 1fr; gap: 3rem; }
      .sketches-grid { grid-template-columns: repeat(3, 1fr); }
      .flats-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>

  <div class="project-page">

    <!-- Back Nav -->
    <nav class="back-nav">
      <a href="/projects/fashion">← Fashion</a>
    </nav>

    <!-- Hero -->
    <section class="hero">
  
      <img class="hero-image" src="/images/traveller/Traveller-moodboard.png" alt="Traveler mood board" />

      <div class="hero-text">
        <p class="hero-label">Parsons School of Design · 2024</p>
        <h1 class="hero-title">Traveler</h1>
        <p class="hero-subtitle">
          A modular collection for living in motion. Designed for packing light, wearing twice, and arriving ready.
        </p>
        <div class="hero-meta">
          <div class="hero-meta-item">
            <span class="meta-label">Category</span>
            <span class="meta-value">Full Collection Concept</span>
          </div>
          <div class="hero-meta-item">
            <span class="meta-label">School</span>
            <span class="meta-value">Parsons School of Design</span>
          </div>
          <div class="hero-meta-item">
            <span class="meta-label">Deliverables</span>
            <span class="meta-value">Mood Board, Sketches, Technical Flats, Swatches</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Concept -->
    <section class="section">
      <div class="section-header">
        <span class="section-number">01</span>
        <span class="section-title">Concept</span>
        <div class="section-rule"></div>
      </div>
      <div class="concept-text">
        <p>
          Traveler began with a suitcase and a question: what do you keep when you have to leave everything behind?
        </p>
        <p>
          Designed during a period of personal transition. Moving cities, living without a fixed address, existing between places. This collection explores modular dressing as a philosophy rather than a gimmick. Each piece is designed to pack flat, layer intuitively, and shift between contexts: a dinner, a flight, a meeting, a morning walk in an unfamiliar city.
        </p>
        <p>
          The woman this collection is for knows how to travel light without looking like it. She moves through the world with intention. Her wardrobe doesn't announce itself.
        </p>
      </div>
    </section>

    <!-- Principles -->
    <div class="principles">
      <div class="principle">
        <div class="principle-number">Principle 01</div>
        <div class="principle-text">Pack flat.</div>
        <p class="principle-caption">Every silhouette considered for the suitcase first.</p>
      </div>
      <div class="principle">
        <div class="principle-number">Principle 02</div>
        <div class="principle-text">Wear twice.</div>
        <p class="principle-caption">Each piece designed to function across at least two distinct contexts.</p>
      </div>
      <div class="principle">
        <div class="principle-number">Principle 03</div>
        <div class="principle-text">Arrive ready.</div>
        <p class="principle-caption">No piece that requires ironing, steaming, or special care on the road.</p>
      </div>
    </div>

    <!-- Fabrics -->
    <section class="section">
      <div class="section-header">
        <span class="section-number">02</span>
        <span class="section-title">Fabrics</span>
        <div class="section-rule"></div>
      </div>
      <div class="reference-stack">
        <img src="/images/traveller/fabrics.png" alt="fabric swatches" />
      </div>
    </section>

    <!-- Sketches -->
    <section class="section">
      <div class="section-header">
        <span class="section-number">03</span>
        <span class="section-title">Sketches & Ideation</span>
        <div class="section-rule"></div>
      </div>
      <div class="sketches-grid">
        <div class="sketch-item">
          <div class="sketch-img-wrap">
            <img src="/images/traveller/Look1.png" alt="Look 1" />
          </div>
          <p class="sketch-caption">Look 01 — Departure</p>
        </div>
        <div class="sketch-item">
          <div class="sketch-img-wrap">
            <img src="/images/traveller/Look2.png" alt="Look 2" />
          </div>
          <p class="sketch-caption">Look 02 — In Transit</p>
        </div>
        <div class="sketch-item">
          <div class="sketch-img-wrap">
            <img src="/images/traveller/Look3.png" alt="Look 3" />
          </div>
          <p class="sketch-caption">Look 03 — Arrival</p>
        </div>
        <div class="sketch-item">
          <div class="sketch-img-wrap">
            <img src="/images/traveller/Look4.png" alt="Look 4" />
          </div>
          <p class="sketch-caption">Look 04</p>
        </div>
        <div class="sketch-item">
          <div class="sketch-img-wrap">
            <img src="/images/traveller/Look5.png" alt="Look 5" />
          </div>
          <p class="sketch-caption">Look 05</p>
        </div>
      </div>
    </section>

    <!-- Technical Flats + Swatches -->
    <section class="section">
      <div class="section-header">
        <span class="section-number">04</span>
        <span class="section-title">Technical Development</span>
        <div class="section-rule"></div>
      </div>
      <div class="technical-grid">
        <div>
          <div class="flats-grid">
            <div class="flat-item">
              <img src="/images/traveller/Dettmar_Final_FW.png" alt="Technical Flats AW" class="lightbox-trigger" />
            </div>
            <div class="flat-item">
              <img src="/images/traveller/Dettmar_Final_SS.png" alt="Technical Flats SS" class="lightbox-trigger" />
            </div>
          </div>
        </div>
        <div>
          <p class="swatches-title">Material Palette</p>
          <div class="swatch-list">
    
            <div class="swatch-item">
              <div class="swatch-color" style="background: #e5e1dd;"></div>
              <div class="swatch-info">
                <div class="swatch-name">Warm Stone</div>
                <div class="swatch-note">Wrinkle-resistant, packs flat</div>
              </div>
            </div>
            <div class="swatch-item">
              <div class="swatch-color" style="background: #9db19e;"></div>
              <div class="swatch-info">
                <div class="swatch-name">Light Green</div>
                <div class="swatch-note">Works across climates</div>
              </div>
            </div>
            <div class="swatch-item">
              <div class="swatch-color" style="background: #657352;"></div>
              <div class="swatch-info">
                <div class="swatch-name">Olive</div>
                <div class="swatch-note"> Basic Neutral</div>
              </div>
            </div>
              <div class="swatch-item">
              <div class="swatch-color" style="background: #483e1f;"></div>
              <div class="swatch-info">
                <div class="swatch-name">Marsh Green</div>
                <div class="swatch-note">Earthy and grounding when you are always on the go </div>
              </div>
            </div>
              <div class="swatch-item">
              <div class="swatch-color" style="background: #771114;"></div>
              <div class="swatch-info">
                <div class="swatch-name">Red</div>
                <div class="swatch-note">Accent - Lightweight layer</div>
              </div>
            </div>
              <div class="swatch-item">
              <div class="swatch-color" style="background: #6cb7cf;"></div>
              <div class="swatch-info">
                <div class="swatch-name">Blue</div>
                <div class="swatch-note">Accent - Lightweight layer</div>
              </div>
            </div>
              <div class="swatch-item">
              <div class="swatch-color" style="background: #f49f1d;"></div>
              <div class="swatch-info">
                <div class="swatch-name">Yellow</div>
                <div class="swatch-note">Accent - Lightweight layer</div>
              </div>
            </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Process Note -->
    <section class="section">
      <div class="section-header">
        <span class="section-number">05</span>
        <span class="section-title">Process</span>
        <div class="section-rule"></div>
      </div>
      <div class="process-note">
        <p>
          Developed through mood research, hand sketching, and CAD technical flat work. Fabric selection prioritized wrinkle resistance, packability, and a restrained palette that travels well across climates and occasions. The collection was designed to be finished in construction. The next phase would be full pattern development and sample making.
        </p>
      </div>
    </section>

    <!-- Project Navigation -->
    <div class="next-project">
      <a href="/projects" class="next-all">← All Projects</a>
    </div>

  </div>

  <!-- LIGHTBOX -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightboxClose">Close ×</button>
    <img id="lightboxImg" src="" alt="" />
  </div>

  <script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement | null;

    document.querySelectorAll('.lightbox-trigger').forEach(img => {
      img.addEventListener('click', () => {
        if (!lightbox || !lightboxImg) return;
        lightboxImg.src = (img as HTMLImageElement).src;
        lightboxImg.alt = (img as HTMLImageElement).alt;
        lightbox.classList.add('open');
      });
    });

    function closeLightbox() { lightbox?.classList.remove('open'); }

    document.getElementById('lightboxClose')?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
  </script>

</MainLayout>