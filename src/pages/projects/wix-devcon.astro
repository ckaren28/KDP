---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Wix DevCon 2022 — Karen Dettmar">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .project-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 120px 2rem 8rem;
      color: var(--black);
    }

    .back-nav {
      padding: 2.5rem 0 4rem;
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .back-nav a {
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .back-nav a:hover { color: var(--black); }

    /* ── SLIDER ── */
    .slider {
      position: relative;
      width: 100%;
      background: var(--warm-white);
      border: 1px solid var(--border);
      margin-bottom: 4rem;
      overflow: hidden;
    }

    .slider-track {
      display: grid;
      grid-template-areas: "stack";
      min-height: 480px;
      max-height: 76vh;
    }

    .slide {
      grid-area: stack;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px;
      opacity: 0;
      transition: opacity 0.8s ease;
      pointer-events: none;
    }

    .slide.active {
      opacity: 1;
      pointer-events: auto;
    }

    .slide img {
      max-width: 100%;
      max-height: 72vh;
      width: auto;
      height: auto;
      object-fit: contain;
      display: block;
    }

    .slider-dots {
      position: absolute;
      bottom: 16px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--border);
      border: 1px solid var(--muted);
      cursor: pointer;
      transition: background 0.2s, transform 0.2s;
      padding: 0;
      outline: none;
    }

    .dot.active {
      background: var(--sienna);
      border-color: var(--sienna);
      transform: scale(1.3);
    }

    /* ── HERO ── */
    .hero {
      display: flex;
      gap: 2rem;
      align-items: center;
      justify-content: center;
      min-height: calc(100vh - 280px);
      margin-bottom: 4rem;
    }

    .hero-image {
      width: 150px;
      height: 150px;
      border-radius: 50%;
      object-fit: cover;
      display: block;
      flex-shrink: 0;
      margin-top: 0.25rem;
    }

    .hero-text { padding-bottom: 1rem; }

    .hero-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
    }

    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(3rem, 7vw, 5.5rem);
      font-weight: 300;
      line-height: 0.95;
      letter-spacing: -0.02em;
      margin-bottom: 0.4rem;
      font-style: italic;
    }

    .hero-year {
      font-family: var(--font-display);
      font-size: clamp(1.2rem, 2vw, 1.6rem);
      font-weight: 300;
      color: var(--sienna);
      margin-bottom: 2.5rem;
    }

    .hero-subtitle {
      font-family: var(--font-body);
      font-size: 0.85rem;
      line-height: 1.75;
      color: var(--text-body);
      max-width: 34ch;
      margin-bottom: 3rem;
      font-weight: 300;
    }

    .hero-meta { display: flex; flex-direction: column; gap: 0; }

    .hero-meta-item {
      display: flex;
      gap: 1.5rem;
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
    }

    .meta-label {
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.65rem;
      color: var(--muted);
      width: 6rem;
      flex-shrink: 0;
    }

    .meta-value { color: var(--text-body); }

    .meta-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .meta-tag {
      font-size: 9px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      border: 1px solid var(--border);
      padding: 3px 8px;
    }

    /* ── SECTIONS ── */
    .section { margin-bottom: 7rem; }

    .section-header {
      display: flex;
      align-items: center;
      gap: 2rem;
      margin-bottom: 3rem;
    }

    .section-number {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .section-title {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--black);
    }

    .section-rule {
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .body-text {
      max-width: 65ch;
      font-family: var(--font-body);
      font-size: 0.95rem;
      line-height: 1.88;
      color: var(--text-body);
      font-weight: 300;
    }

    .body-text p + p { margin-top: 1.5rem; }

    /* ── IMAGE LAYOUTS ── */
    .img-full {
      width: 100%;
      display: block;
      object-fit: cover;
    }

    .img-full.wide { aspect-ratio: 16/9; }
    .img-full.landing { aspect-ratio: 4/3; min-height: 600px; }
    .img-full.landscape { aspect-ratio: 3/2; }

    .img-caption {
      font-family: var(--font-body);
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      color: var(--muted);
      margin-top: 1rem;
      text-transform: uppercase;
    }

    /* ── ROLE CALLOUT ── */
    .role-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      margin-bottom: 5rem;
    }

    .role-card {
      background: var(--warm-white);
      padding: 2.5rem 2rem;
      border: 1px solid var(--border);
    }

    .role-card-label {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--sienna);
      margin-bottom: 1rem;
    }

    .role-card-title {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-style: italic;
      font-weight: 300;
      line-height: 1.2;
      color: var(--black);
      margin-bottom: 0.75rem;
    }

    .role-card-desc {
      font-family: var(--font-body);
      font-size: 0.78rem;
      line-height: 1.65;
      color: var(--text-body);
      font-weight: 300;
    }

    /* ── FOOTER NAV ── */
    .next-project {
      margin-top: 8rem;
      padding-top: 3rem;
      border-top: 1px solid var(--border);
    }

    .next-all {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .next-all:hover { color: var(--black); }

    @media (max-width: 768px) {
      .role-grid { grid-template-columns: 1fr; }
      .img-full.landing { min-height: 320px; }
    }
  </style>

  <div class="project-page">

    <nav class="back-nav">
      <a href="/projects/tech">← Technology</a>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <img
        class="hero-image"
        src="/images/wix-devcon/wix-coverimage.png"
        alt="Wix DevCon 2022 — Cover"
      />
      <div class="hero-text">
        <p class="hero-label">Wix · Developer Relations</p>
        <h1 class="hero-title">Wix DevCon</h1>
        <p class="hero-year">2022</p>
        <p class="hero-subtitle">
          The first developer conference at Wix. Planned, built, and delivered from the ground up. Keynote speaker and demo architect for the launch of new platform coding capabilities.
        </p>
        <div class="hero-meta">
          <div class="hero-meta-item">
            <span class="meta-label">Company</span>
            <span class="meta-value">Wix</span>
          </div>
          <div class="hero-meta-item">
            <span class="meta-label">Year</span>
            <span class="meta-value">2022</span>
          </div>
          <div class="hero-meta-item">
            <span class="meta-label">Role</span>
            <span class="meta-value">Event Organizer · Keynote Speaker · Demo Engineer</span>
          </div>
          <div class="hero-meta-item">
            <span class="meta-label">Stack</span>
            <div class="meta-tags">
              <span class="meta-tag">TypeScript</span>
              <span class="meta-tag">JavaScript</span>
              <span class="meta-tag">Web Design</span>
              <span class="meta-tag">Speaking</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    

    <!-- Role callouts -->
    <div class="role-grid">
      <div class="role-card">
        <p class="role-card-label">01 — Organizer</p>
        <h2 class="role-card-title">First & only Wix dev conference.</h2>
        <p class="role-card-desc">Planned and produced the inaugural Wix developer conference end-to-end. Ideation of format, venue, content, speakers, and execution.</p>
      </div>
      <div class="role-card">
        <p class="role-card-label">02 — Keynote</p>
        <h2 class="role-card-title">On stage, live demo.</h2>
        <p class="role-card-desc">Delivered the keynote and built the live coding demo that launched Wix's new integrated code editor capabilities to the developer community.</p>
      </div>
      <div class="role-card">
        <p class="role-card-label">03 — Web Design</p>
        <h2 class="role-card-title">Community landing page.</h2>
        <p class="role-card-desc">Designed and built the DevCon announcement landing page for the Wix Discord developer community.</p>
      </div>
    </div>
    

    <!-- Overview -->
    <section class="section">
      <div class="section-header">
        <span class="section-number">01</span>
        <span class="section-title">Overview</span>
        <div class="section-rule"></div>
      </div>
      <div class="body-text">
        <p>
          Created the Mother of all demos to showcase the platform's new capabilities including intergration to GitHub and the ability to connect the code console to your local IDE. Inspired by the NFT craze of the time, the user could randomize their avatar and had to complete a series of tasks to enter a raffle for a free dinner with the CEO.
        </p>
      </div>
    </section>
    <!-- On Stage -->
    <section class="section">
      <div class="section-header">
        <span class="section-number">02</span>
        <span class="section-title">On Stage</span>
        <div class="section-rule"></div>
      </div>
      <div class="slider" id="slider">
        <div class="slider-track">
          <div class="slide active">
            <img src="/images/wix-devcon/keynote-ad.png" alt="Wix DevCon 2022 — Keynote Speaker Ad" />
          </div>
          <div class="slide">
            <img src="/images/wix-devcon/speaking-1.png" alt="On stage — DevCon 2022" />
          </div>
          <div class="slide">
            <img src="/images/wix-devcon/speaking-2.jpg" alt="Keynote presentation — DevCon 2022" />
          </div>
        </div>
        <div class="slider-dots">
          <button class="dot active" data-index="0" aria-label="Slide 1"></button>
          <button class="dot" data-index="1" aria-label="Slide 2"></button>
          <button class="dot" data-index="2" aria-label="Slide 3"></button>
        </div>
      </div>
    </section>

    <!-- Landing Page -->
    <section class="section">
      <div class="section-header">
        <span class="section-number">03</span>
        <span class="section-title">Community Landing Page</span>
        <div class="section-rule"></div>
      </div>
      <img
        class="img-full landing"
        src="/images/wix-devcon/DevCon.gif"
        alt="DevCon announcement landing page for the Wix Discord community"
      />
      <p class="img-caption">DevCon announcement page. Built for the Wix Discord developer community</p>
       <div class="body-text">
        <p>
          Created the prelaunch landing page filled with easter eggs and scavenger hunt in the browser console to win a prize.
        </p>
      </div>
    </section>

    <div class="next-project">
      <a href="/projects/tech" class="next-all">← All Technology Projects</a>
    </div>

  </div>

  <script>
    const slider  = document.getElementById('slider')!;
    const slides  = slider.querySelectorAll<HTMLElement>('.slide');
    const dots    = slider.querySelectorAll<HTMLButtonElement>('.dot');
    let current   = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(n: number) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = (n + slides.length) % slides.length;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
    }

    function start() {
      timer = setInterval(() => goTo(current + 1), 2000);
    }

    function stop() {
      clearInterval(timer);
    }

    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        stop();
        goTo(Number(dot.dataset.index));
        start();
      });
    });

    slider.addEventListener('mouseenter', stop);
    slider.addEventListener('mouseleave', start);

    start();
  </script>

</MainLayout>
