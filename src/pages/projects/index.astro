---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Projects — Karen Dettmar">
  <div class="page-container">

    <span class="page-eyebrow">Portfolio</span>
    <h1 class="page-title">Selected <em>Projects</em></h1>

    <div class="work-grid">


      <!-- Traveler — standalone project page -->
      <a href="/projects/traveller" class="work-item reveal">
        <div class="work-item-inner">
          <div class="work-placeholder">
            <img src="/images/traveller/Traveller-moodboard.png" alt="Traveler" />
          </div>
          <div class="work-overlay">
            <div class="work-tag">Fashion Design · Parsons</div>
            <div class="work-name">Traveler</div>
          </div>
        </div>
        <div class="work-label">
          <span class="work-label-name">Traveler</span>
          <span class="work-label-cat">Collection Concept</span>
        </div>
      </a>

      <!-- Garment Construction -->
      <a href="/projects/construction" class="work-item reveal">
        <div class="work-item-inner">
          <div class="work-placeholder">
            <img src="/images/constructions-2/lucky-dress1.JPG" alt="Garment Construction" class="img-contain" />
          </div>
          <div class="work-overlay">
            <div class="work-tag">Fashion Design</div>
            <div class="work-name">Garment Construction</div>
          </div>
        </div>
        <div class="work-label">
          <span class="work-label-name">Garment Construction</span>
          <span class="work-label-cat">Pattern Work · Flats</span>
        </div>
      </a>

      <!-- Creative Technology -->
      <a href="/projects/tech" class="work-item reveal">
        <div class="work-item-inner">
          <div class="work-placeholder work-placeholder-tech">
            <img src="/images/tech/cover.jpg" alt="Creative Technology" class="tech-cover" />
          </div>
          <div class="work-overlay">
            <div class="work-tag">Creative Technology</div>
            <div class="work-name">Technical Projects</div>
          </div>
        </div>
        <div class="work-label">
          <span class="work-label-name">Technical Projects</span>
          <span class="work-label-cat">Tools · Prototypes</span>
        </div>
      </a>

    </div>
  </div>
</MainLayout>

<style>
  .work-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 16px;
  }

  .work-item:nth-child(odd)  { grid-column: span 7; }
  .work-item:nth-child(even) { grid-column: span 5; }

  .work-item {
    position: relative;
    overflow: hidden;
    background: var(--black);
    text-decoration: none;
    color: inherit;
    cursor: none;
  }

  .work-item-inner {
    aspect-ratio: 4/3;
    position: relative;
    overflow: hidden;
  }

  .work-placeholder {
    width: 100%;
    height: 100%;
    transition: transform 0.7s cubic-bezier(0.16,1,0.3,1);
  }

  .work-item:hover .work-placeholder { transform: scale(1.04); }

  .work-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
    transition: opacity 0.5s ease;
  }
  .work-item:hover .work-placeholder img { opacity: 1; }
  .work-placeholder img.img-contain { object-fit: contain; }

  .swatch { width: 100%; height: 100%; }
  .swatch-default      { background: #2A2420; }
  .swatch-traveler    { background: #1C1815; }
  .swatch-construction { background: #2E2318; }

  /* Tech card — image with CSS fallback */
  .work-placeholder-tech {
    background: #1A1E24;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .tech-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.75;
    transition: opacity 0.5s ease;
    /* Hide broken image icon if file not yet added */
    color: transparent;
  }
  /* Hide alt text / broken icon when image fails to load */
  .tech-cover[src="/images/tech/cover.jpg"]:not([naturalWidth]) {
    display: none;
  }
  .work-item:hover .work-placeholder-tech .tech-cover { opacity: 1; }

  .work-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(14,13,11,0.88) 0%, transparent 55%);
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .work-item:hover .work-overlay { opacity: 1; }

  .work-tag {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sienna-light);
    margin-bottom: 6px;
  }

  .work-name {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 400;
    color: var(--off-white);
    line-height: 1.1;
  }

  .work-label {
    padding: 14px 0 0;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .work-label-name {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 400;
    font-style: italic;
    color: var(--black);
  }

  .work-label-cat {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .work-grid { grid-template-columns: 1fr; gap: 12px; }
    .work-item:nth-child(n) { grid-column: span 1; }
  }
</style>
