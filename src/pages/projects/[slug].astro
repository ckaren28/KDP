---
import { getCollection } from "astro:content";
import TabbedCaseStudyLayout from "../../layouts/TabbedCaseStudyLayout.astro";
import FashionCollectionLayout from "../../layouts/FashionCollectionLayout.astro";
import TextilesLayout from "../../layouts/TextilesLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Fashion collection: has structured look/palette/icon data
const isFashionCollection =
  entry.data.track === "fashion" &&
  (entry.data.looks || entry.data.color_palette || entry.data.collection_icon);

// Textiles projects + the textiles hub page (track:fashion, slug:textiles)
const isTextileLayout =
  entry.data.track === "textiles" || entry.slug === "textiles";

// Everything else: tech projects + fashion garment/case-study pages
// (isFashionCollection and isTextileLayout are already excluded above)
---

{
  isFashionCollection ? (
    <FashionCollectionLayout
      title={entry.data.title}
      description={entry.data.description}
      season={entry.data.season}
      year={entry.data.year}
      logo={entry.data.logo}
      collection_icon={entry.data.collection_icon}
      background_color={entry.data.background_color}
      color_palette={entry.data.color_palette}
      looks={entry.data.looks}
      technical_flats={entry.data.technical_flats}
      fabric_notes={entry.data.fabric_notes}
      material_palette={entry.data.material_palette}
      tags={entry.data.tags}
    >
      <Content />
    </FashionCollectionLayout>
  ) : isTextileLayout ? (
    <TextilesLayout
      title={entry.data.title}
      description={entry.data.description}
      track={entry.data.track as "fashion" | "textiles"}
      tags={entry.data.tags}
      filterable={entry.slug === "textiles"}
    >
      <Content />
    </TextilesLayout>
  ) : (
    <TabbedCaseStudyLayout
      title={entry.data.title}
      description={entry.data.description}
      track={entry.data.track}
      tags={entry.data.tags}
      github_url={entry.data.github_url}
      coverImage={entry.data.coverImage}
      password_protected={entry.data.password_protected}
      slug={entry.slug}
      hero_image={entry.data.hero_image}
      problem_statement={entry.data.problem_statement}
      who_its_for={entry.data.who_its_for}
      why_i_built_it={entry.data.why_i_built_it}
      scope_constraints={entry.data.scope_constraints}
      architecture_diagram={entry.data.architecture_diagram}
      output_structure={entry.data.output_structure}
      sample_output={entry.data.sample_output}
      design_decisions={entry.data.design_decisions}
      live_url={entry.data.live_url}
      live_embed_url={entry.data.live_embed_url}
      live_embed_note={entry.data.live_embed_note}
      process_images={entry.data.process_images}
      results_images={entry.data.results_images}
    >
      <Content />
    </TabbedCaseStudyLayout>
  )
}
