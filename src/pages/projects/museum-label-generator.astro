    <!-- ── YOUR ARTWORK ── -->
    <section class="your-artwork-section">
      <span class="section-label">Your artwork</span>
      <div class="your-artwork-inner">

        <!-- Image upload -->
        <div class="upload-area" id="uploadArea">
          <input type="file" id="artworkUpload" accept="image/jpeg,image/png,image/gif,image/webp" />
          <div class="upload-placeholder" id="uploadPlaceholder">
