        <!-- User's generated wall label -->
        <div class="wall-label-card">
          <span class="wlc-eyebrow">Wall Label</span>
          <div class="wlc-title" id="user-wlc-title">Untitled</div>
          <div class="wlc-meta" id="user-wlc-meta">Artist unknown · Date unknown</div>
          <p class="wlc-body placeholder" id="user-wlc-body">Generate a label above to see your draft here.</p>
        </div>

