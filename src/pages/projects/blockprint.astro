---
import MainLayout from '../../layouts/MainLayout.astro';

const inspo = [
  { src: '/images/blockprint/portugal1.jpg', alt: 'Portugal — tile detail 1' },
  { src: '/images/blockprint/portugal2.jpg', alt: 'Portugal — tile detail 2' },
  { src: '/images/blockprint/portugal3.jpg', alt: 'Portugal — tile detail 3' },
  { src: '/images/blockprint/portugal4.jpg', alt: 'Portugal — tile detail 4' },
  { src: '/images/blockprint/portugal5.jpg', alt: 'Portugal — tile detail 5' },
  { src: '/images/blockprint/portugal6.jpg', alt: 'Portugal — tile detail 6' },
  { src: '/images/blockprint/blockprint-inspo.jpg', alt: 'Block print reference sketch' },
];
---

<MainLayout title="Block Printing — Karen Dettmar">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .project-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 120px 2rem 8rem;
      font-family: var(--font-display);
      color: var(--black);
    }

    .back-nav {
      padding: 2.5rem 0 4rem;
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .back-nav a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .back-nav a:hover { color: var(--black); }

    .page-header {
      margin-bottom: 5rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--border);
    }

    .page-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
      display: block;
    }

    .page-title {
      font-size: clamp(3rem, 7vw, 5.5rem);
      font-weight: 300;
      line-height: 0.95;
      letter-spacing: -0.02em;
      font-style: italic;
      margin-bottom: 2rem;
    }

    .page-desc {
      font-family: var(--font-body);
      font-size: 0.9rem;
      line-height: 1.75;
      color: var(--text-body);
      max-width: 52ch;
      font-weight: 300;
    }

    .meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 3rem;
      margin-bottom: 5rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--border);
    }

    .meta-label {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.5rem;
      display: block;
    }

    .meta-value {
      font-family: var(--font-body);
      font-size: 0.85rem;
      color: var(--text-body);
      font-weight: 300;
    }

    /* ── SECTION LABEL ── */
    .section-label {
      font-family: var(--font-body);
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--muted);
      opacity: 0.6;
      margin-bottom: 1.5rem;
      display: block;
    }

    /* ── INSPO SECTION ── */
    .inspo-section {
      margin-bottom: 5rem;
    }

    /* 4-col × 3-row explicit grid — fills exactly 12 cells, perfect rectangle */
    .inspo-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(3, 180px);
      gap: 3px;
    }

    /* item 1: large anchor — cols 1-2, rows 1-2 */
    .inspo-grid .inspo-item:nth-child(1) { grid-column: 1 / 3; grid-row: 1 / 3; }
    /* items 2-3: right side, row 1 */
    .inspo-grid .inspo-item:nth-child(2) { grid-column: 3; grid-row: 1; }
    .inspo-grid .inspo-item:nth-child(3) { grid-column: 4; grid-row: 1; }
    /* items 4-5: right side, row 2 */
    .inspo-grid .inspo-item:nth-child(4) { grid-column: 3; grid-row: 2; }
    .inspo-grid .inspo-item:nth-child(5) { grid-column: 4; grid-row: 2; }
    /* items 6-7: bottom row, each spans 2 cols */
    .inspo-grid .inspo-item:nth-child(6) { grid-column: 1 / 3; grid-row: 3; }
    .inspo-grid .inspo-item:nth-child(7) { grid-column: 3 / 5; grid-row: 3; }

    .inspo-item {
      overflow: hidden;
      cursor: zoom-in;
    }

    .inspo-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.72;
      filter: saturate(0.85);
      transition: opacity 0.4s ease, filter 0.4s ease;
      display: block;
    }
    .inspo-item:hover img {
      opacity: 0.92;
      filter: saturate(1);
    }

    /* ── PROCESS ── */
    .process-section {
      margin-bottom: 5rem;
    }

    .process-single {
      cursor: zoom-in;
      overflow: hidden;
    }

    .process-single img {
      width: 100%;
      display: block;
      transition: opacity 0.3s ease, transform 0.7s cubic-bezier(0.16,1,0.3,1);
    }
    .process-single:hover img { opacity: 0.9; transform: scale(1.01); }

    .image-caption {
      font-family: var(--font-body);
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      color: var(--muted);
      text-transform: uppercase;
      padding: 8px 0 0;
    }

    /* ── FINAL ── */
    .final-section {}

    .final-image {
      cursor: zoom-in;
      overflow: hidden;
    }

    .final-image img {
      width: 100%;
      display: block;
      transition: opacity 0.3s ease, transform 0.7s cubic-bezier(0.16,1,0.3,1);
    }
    .final-image:hover img { opacity: 0.9; transform: scale(1.01); }

    /* ── LIGHTBOX ── */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(24,16,10,0.96);
      z-index: 500;
      align-items: center;
      justify-content: center;
      padding: 32px;
      cursor: zoom-out;
    }
    .lightbox.open { display: flex; }
    .lightbox img {
      max-width: 100%;
      max-height: 92vh;
      object-fit: contain;
      display: block;
      cursor: default;
    }
    .lightbox-close {
      position: absolute;
      top: 24px; right: 32px;
      background: none; border: none;
      color: rgba(237,229,208,0.5);
      font-size: 11px; letter-spacing: 0.16em;
      text-transform: uppercase;
      cursor: pointer;
      font-family: var(--font-body);
      transition: color 0.2s;
    }
    .lightbox-close:hover { color: rgba(237,229,208,1); }

    /* ── PROJECT NAV ── */
    .project-nav {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-top: 6rem;
      margin-bottom: 2rem;
    }
    .project-nav-link {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .project-nav-link:hover { color: var(--black); }

    /* ── FOOTER NAV ── */
    .next-project {
      margin-top: 0;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }
    .next-all {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .next-all:hover { color: var(--black); }

    @media (max-width: 768px) {
      .inspo-grid {
        grid-template-columns: repeat(2, 1fr);
        grid-template-rows: repeat(4, 140px);
      }
      .inspo-grid .inspo-item:nth-child(1) { grid-column: 1 / 3; grid-row: 1 / 3; }
      .inspo-grid .inspo-item:nth-child(2) { grid-column: 1; grid-row: 3; }
      .inspo-grid .inspo-item:nth-child(3) { grid-column: 2; grid-row: 3; }
      .inspo-grid .inspo-item:nth-child(4) { grid-column: 1; grid-row: 4; }
      .inspo-grid .inspo-item:nth-child(5) { grid-column: 2; grid-row: 4; }
      .inspo-grid .inspo-item:nth-child(6) { grid-column: 1; grid-row: 5; }
      .inspo-grid .inspo-item:nth-child(7) { grid-column: 2; grid-row: 5; }
      .meta-row { gap: 2rem; }
    }
  </style>

  <div class="project-page">

    <nav class="back-nav">
      <a href="/projects/textiles">← Textile Practice</a>
    </nav>

    <header class="page-header">
      <span class="page-label">Textile Practice · Printing · Relief</span>
      <h1 class="page-title">Block Printing</h1>
      <p class="page-desc">
        Hand-carved relief blocks and repeat pattern development on muslin. The design was inspired by a trip to Portugal with the geometric logic of azulejo tilework seen throughout Lisbon and Porto. The linoleum was carved by hand, inked, and pressed in sequence to build a repeating motif referencing the symmetry and interlocking forms of Portuguese tile.
      </p>
    </header>

    <div class="meta-row">
      <div class="meta-item">
        <span class="meta-label">Fiber</span>
        <span class="meta-value">Muslin</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Block medium</span>
        <span class="meta-value">Linoleum</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Inspiration</span>
        <span class="meta-value">Azulejo tile, Portugal</span>
      </div>
    </div>

    <!-- ── INSPIRATION ── -->
    <div class="inspo-section">
      <span class="section-label">Reference — Portugal</span>
      <div class="inspo-grid">
        {inspo.map((img) => (
          <div class="inspo-item lightbox-trigger" data-src={img.src} data-alt={img.alt}>
            <img src={img.src} alt={img.alt} loading="lazy" />
          </div>
        ))}
      </div>
    </div>

    <!-- ── PROCESS ── -->
    <div class="process-section">
      <span class="section-label">Process</span>
      <div class="process-single lightbox-trigger" data-src="/images/blockprint/Printmaking-process.JPG" data-alt="Carving the linoleum block">
        <img src="/images/blockprint/Printmaking-process.JPG" alt="Carving the linoleum block" />
        <p class="image-caption">Carving the linoleum block</p>
      </div>
    </div>

    <!-- ── FINAL ── -->
    <div class="final-section">
      <span class="section-label">Result</span>
      <div class="final-image lightbox-trigger" data-src="/images/blockprint/blockprint.jpg" data-alt="Block print — finished fabric">
        <img src="/images/blockprint/blockprint.jpg" alt="Block print — finished fabric" />
      </div>
    </div>

    <div class="project-nav">
      <a href="/projects/batik" class="project-nav-link">← Batik</a>
      <a href="/projects/felting" class="project-nav-link">Felting →</a>
    </div>
    <div class="next-project">
      <a href="/projects/textiles" class="next-all">← Textile Practice</a>
    </div>

  </div>

  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightboxClose">Close ×</button>
    <img id="lightboxImg" src="" alt="" />
  </div>

  <script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement | null;

    document.querySelectorAll('.lightbox-trigger').forEach(el => {
      el.addEventListener('click', () => {
        if (!lightbox || !lightboxImg) return;
        lightboxImg.src = (el as HTMLElement).dataset.src || '';
        lightboxImg.alt = (el as HTMLElement).dataset.alt || '';
        lightbox.classList.add('open');
      });
    });

    function closeLightbox() { lightbox?.classList.remove('open'); }
    document.getElementById('lightboxClose')?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
  </script>

</MainLayout>
