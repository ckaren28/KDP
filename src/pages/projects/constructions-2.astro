---
import MainLayout from '../../layouts/MainLayout.astro';


const images: { src: string; alt: string; caption?: string }[] = [
  { src: '/images/constructions-2/lucky-dress1.JPG', alt: 'Green organza dress — 3/4 view', caption: '3/4 view' },
  { src: '/images/constructions-2/lucky-dress2.JPG', alt: 'Green organza dress — front', caption: 'Front' },

  // { src: '/images/constructions-2/cloverpocket.png', alt: 'Four-leaf clover — pocket inspiration', caption: 'Pocket inspiration' },
];
---

<MainLayout title="Lucky Dress">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .project-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 120px 2rem 8rem;
      font-family: var(--font-display);
      color: var(--black);
    }

    .back-nav {
      padding: 2.5rem 0 4rem;
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .back-nav a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .back-nav a:hover { color: var(--black); }

    .page-header {
      margin-bottom: 5rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--border);
    }

    .page-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
      display: block;
    }

    .page-title {
      font-size: clamp(3rem, 7vw, 5.5rem);
      font-weight: 300;
      line-height: 0.95;
      letter-spacing: -0.02em;
      font-style: italic;
      margin-bottom: 2rem;
    }

    .page-desc {
      font-family: var(--font-body);
      font-size: 0.9rem;
      line-height: 1.75;
      color: var(--text-body);
      max-width: 52ch;
      font-weight: 300;
    }

    /* ── PROJECT META ROW ── */
    .meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 3rem;
      margin-bottom: 5rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--border);
    }

    .meta-item {}

    .meta-label {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.5rem;
      display: block;
    }

    .meta-value {
      font-family: var(--font-body);
      font-size: 0.85rem;
      color: var(--text-body);
      font-weight: 300;
    }

    /* ── IMAGES — two full-width stacked ── */
    .image-stack {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .image-item {
      position: relative;
      cursor: zoom-in;
      overflow: hidden;
    }

    .image-item img {
      width: 100%;
      display: block;
      object-fit: cover;
      transition: opacity 0.3s ease, transform 0.7s cubic-bezier(0.16,1,0.3,1);
    }

    .image-item:hover img {
      opacity: 0.9;
      transform: scale(1.01);
    }

    .image-caption {
      font-family: var(--font-body);
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      color: var(--muted);
      text-transform: uppercase;
      padding: 10px 0 0;
    }

    /* ── LIGHTBOX ── */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(24,16,10,0.96);
      z-index: 500;
      align-items: center;
      justify-content: center;
      padding: 32px;
      cursor: zoom-out;
    }
    .lightbox.open { display: flex; }
    .lightbox img {
      max-width: 100%;
      max-height: 92vh;
      object-fit: contain;
      display: block;
      cursor: default;
    }
    .lightbox-close {
      position: absolute;
      top: 24px; right: 32px;
      background: none; border: none;
      color: rgba(237,229,208,0.5);
      font-size: 11px; letter-spacing: 0.16em;
      text-transform: uppercase;
      cursor: pointer;
      font-family: var(--font-body);
      transition: color 0.2s;
    }
    .lightbox-close:hover { color: rgba(237,229,208,1); }

    /* ── FOOTER NAV ── */
    .next-project {
      margin-top: 8rem;
      padding-top: 3rem;
      border-top: 1px solid var(--border);
      display: flex;
      gap: 3rem;
    }
    .next-all {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .next-all:hover { color: var(--black); }

    @media (max-width: 768px) {
      .meta-row { gap: 2rem; }
    }
  </style>

  <div class="project-page">

    <nav class="back-nav">
      <a href="/projects/construction">← Garment Construction</a>
    </nav>

    <header class="page-header">
      <span class="page-label">Parsons School of Design · Constructions 2</span>
      <h1 class="page-title">Clover<em>Dress</em></h1>
      <p class="page-desc">
        A draped and constructed tea-length dress in organza, developed as a final project for Constructions 2 at Parsons. The silhouette is shaped through princess seams. French seam finished throughout on an industrial machine. Zipper on the back seam and features four oversized side pockets inspired by the four-leaf clover. Light and epherial. 
      </p>
    </header>

    <div class="meta-row">
      <div class="meta-item">
        <span class="meta-label">Course</span>
        <span class="meta-value">Constructions 2</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Institution</span>
        <span class="meta-value">Parsons School of Design</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Material</span>
        <span class="meta-value">Green organza</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Technique</span>
        <span class="meta-value">Draping · Construction</span>
      </div>
    </div>

    <div class="image-stack">
      {images.map((img) => (
        <div class="image-item lightbox-trigger" data-src={img.src} data-alt={img.alt}>
          <img src={img.src} alt={img.alt} />
          {img.caption && <p class="image-caption">{img.caption}</p>}
        </div>
      ))}
    </div>

    <div class="next-project">
      <a href="/projects/construction" class="next-all">← Garment Construction</a>
      <a href="/projects" class="next-all">All Projects →</a>
    </div>

  </div>

  <!-- LIGHTBOX -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightboxClose">Close ×</button>
    <img id="lightboxImg" src="" alt="" />
  </div>

  <script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement | null;

    document.querySelectorAll('.lightbox-trigger').forEach(el => {
      el.addEventListener('click', () => {
        if (!lightbox || !lightboxImg) return;
        lightboxImg.src = (el as HTMLElement).dataset.src || '';
        lightboxImg.alt = (el as HTMLElement).dataset.alt || '';
        lightbox.classList.add('open');
      });
    });

    function closeLightbox() { lightbox?.classList.remove('open'); }
    document.getElementById('lightboxClose')?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
  </script>

</MainLayout>
