---
import MainLayout from '../../layouts/MainLayout.astro';

const projects = [
  {
    title: 'Generative Textile Pattern Tool',
    subtitle: 'Living patterns generated from collection concepts',
    desc: 'Enter a collection concept and generate a living textile pattern. Palette and structure are AI-suggested, then fully adjustable. Export as SVG.',
    tags: ['Claude API', 'Canvas', 'Generative Art', 'Textile Design'],
    status: 'Live',
    link: '/projects/textile-pattern-generator',
    featured: true,
  },
  {
    title: 'Garment Construction Decoder',
    subtitle: 'Structured technical breakdown for garment construction',
    desc: 'Describe a garment and get a technical breakdown — seam types, fabric behavior, lining, interfacing, closure options, and construction order. Includes Traveler Mode for packability constraints.',
    tags: ['Claude API', 'Netlify Functions', 'Construction'],
    status: 'Live',
    link: '/projects/garment-construction-decoder',
  },
  {
    title: 'Museum Label Generator',
    subtitle: 'AI-powered interpretive text for cultural institutions',
    desc: 'Generates accessible, engaging museum label copy from structured object data — built for fashion archives, textile collections, and cultural institutions.',
    tags: ['Claude API', 'TypeScript', 'Prompt Engineering'],
    status: 'Live',
    link: '/projects/museum-label-generator',
  },
  {
    title: 'DevCon',
    subtitle: 'First developer conference at Wix — organized, built, and delivered',
    desc: 'Planned and produced the inaugural Wix developer conference. Delivered the keynote and live-coded the demo launching new platform coding capabilities. Also designed the DevCon announcement landing page for the Wix Discord developer community.',
    tags: ['TypeScript', 'JavaScript', 'Speaking', 'Web Design'],
    status: '2022',
    link: '/projects/wix-devcon',
  },
];
---

<MainLayout title="Creative Technology — Karen Dettmar">

  <style>
    .tech-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 120px 48px 100px;
    }

    .page-header {
      margin-bottom: 48px;
      padding-bottom: 32px;
      border-bottom: 1px solid var(--border);
    }
    .page-header-top {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .page-eyebrow {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .github-link {
      font-size: 10px;
      letter-spacing: 0.14em;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.25s;
    }
    .github-link:hover { color: var(--black); }
    .page-title {
      font-family: var(--font-display);
      font-size: clamp(44px, 6vw, 80px);
      font-weight: 300;
      line-height: 0.95;
      letter-spacing: -0.02em;
    }
    .page-title em { font-style: italic; color: var(--sienna); }

    /* grid */
    .project-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .project-card {
      display: flex;
      flex-direction: column;
      padding: 36px;
      border: 1px solid var(--border);
      text-decoration: none;
      color: inherit;
      cursor: none;
      transition: border-color 0.3s ease, background 0.3s ease;
    }
    .project-card:hover {
      border-color: var(--black);
      background: var(--warm-white);
    }

    .card-title {
      font-family: var(--font-display);
      font-size: clamp(24px, 2.4vw, 34px);
      font-weight: 300;
      font-style: italic;
      line-height: 1.05;
      letter-spacing: -0.01em;
      color: var(--black);
      margin-bottom: 8px;
      transition: color 0.3s;
    }
    .project-card:hover .card-title { color: var(--sienna); }

    .card-subtitle {
      font-size: 12px;
      color: var(--muted);
      letter-spacing: 0.02em;
      font-weight: 300;
      margin-bottom: 20px;
    }

    .card-desc {
      font-size: 13px;
      line-height: 1.75;
      color: var(--text-body);
      font-weight: 300;
      flex: 1;
      margin-bottom: 28px;
    }

    .card-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 24px;
    }
    .card-tag {
      font-size: 9px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      border: 1px solid var(--border);
      padding: 4px 10px;
    }

    .card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .card-status {
      font-size: 9px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--sienna);
    }
    .card-link {
      font-family: var(--font-display);
      font-size: 15px;
      font-style: italic;
      font-weight: 300;
      color: var(--muted);
      transition: color 0.3s;
    }
    .project-card:hover .card-link { color: var(--black); }

    /* ── CANVAS SECTION ── */
    .canvas-section {
      position: relative;
      width: 100%;
      height: 65vh;
      min-height: 400px;
      margin-bottom: 64px;
      border: 1px solid var(--border);
      overflow: hidden;
    }

    #heroCanvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
    }

    @media (max-width: 900px) {
      .tech-page { padding: 100px 24px 72px; }
      .project-grid { grid-template-columns: 1fr; }
      .project-card { padding: 28px 24px; }
      .canvas-section { height: 50vh; min-height: 320px; margin-bottom: 40px; }
    }
  </style>

  <div class="tech-page">

    <header class="page-header reveal">
      <div class="page-header-top">
        <span class="page-eyebrow">Creative Technology</span>
        <a href="https://github.com/ckaren28" target="_blank" rel="noopener" class="github-link">github.com/ckaren28</a>
      </div>
      <h1 class="page-title"><em>Technology</em></h1>
    </header>

    <section class="canvas-section">
      <canvas id="heroCanvas"></canvas>
    </section>

    <div class="project-grid">
      {projects.map((p) => (
        <a href={p.link} class="project-card reveal">
          <h2 class="card-title">{p.title}</h2>
          <p class="card-subtitle">{p.subtitle}</p>
          <p class="card-desc">{p.desc}</p>
          <div class="card-tags">
            {p.tags.map(t => <span class="card-tag">{t}</span>)}
          </div>
          <div class="card-footer">
            <span class="card-status">{p.status}</span>
            <span class="card-link">View project →</span>
          </div>
        </a>
      ))}
    </div>

  </div>

  <script>
    // T-SHIRT THREAD DRAWING
    (function() {
      const canvas = document.getElementById('heroCanvas') as HTMLCanvasElement | null;
      if (!canvas) return;
      const ctx = canvas.getContext('2d')!;

      const SHIRT_COLORS = ['#faf8f5','#e8dcc8','#c4a882','#8b6f5e','#2C1A0E','#7d8c7c','#B85C38','#5a5550'];
      const THREAD_COLORS = ['#8b6f5e','#5a5550','#c4a882','#7d8c7c','#b8846a','#9b8fa0','#D4845C'];

      // SVG path data extracted from Basic T Shirt.svg (viewBox 0 0 595.28 841.89)
      const SVG_SHIRT        = 'M176.24,594.87l247.9,.32c-1.03,-65.35,-2.07,-130.7,-3.1,-196.05l35.61,15.42,48.03,-62.22,-93.95,-75.82,-80.52,-29.08s-3.95,43.87,-31.85,45.38c-27.9,1.51,-34.43,-43.97,-34.43,-43.97l-70.76,23.49,-102.59,79.4,49.45,62.81,36.02,-17.37c.06,65.89,.12,131.78,.18,197.67Z';
      const SVG_COLLAR_FILL  = 'M265.35,247.58s31.65,10.12,63.76,-.88c.6,3.91,3.03,22.39,-9.15,36.76c-2.92,3.45,-10.21,12.04,-21.59,12.47c-11.08,.42,-18.84,-7.18,-21.61,-9.89c-14.39,-14.08,-11.85,-35.22,-11.42,-38.46Z';

      let shirtColor = SHIRT_COLORS[0];
      let threadColorIdx = 0;

      interface Pt { x: number; y: number; }
      interface Trail { pts: Pt[]; color: string; }

      let trails: Trail[] = [];
      let currentTrail: Trail | null = null;
      let isDrawing = false;
      let W = 0, H = 0;
      let shirtPath: Path2D | null = null;
      let shirtMx: DOMMatrix | null = null;
      let shirtMidY = 0;
      let shirtBottomY = 0;
      let hintOpacity = 1;
      let hasDrawn = false;
      let swatchHits: { x: number; y: number; r: number; color: string }[] = [];

      function isDark() {
        return document.documentElement.getAttribute('data-theme') === 'dark';
      }

      const SVG_SHIRT_LEFT = 91, SVG_SHIRT_TOP = 247, SVG_SHIRT_W = 414, SVG_SHIRT_H = 348;

      function buildShirtPath() {
        const targetW = Math.min(W * 0.58, H * 0.68);
        const scale   = targetW / SVG_SHIRT_W;
        const offsetX = W / 2 - (SVG_SHIRT_LEFT + SVG_SHIRT_W / 2) * scale;
        const offsetY = H * 0.05 + 50 - SVG_SHIRT_TOP * scale;
        shirtMx = new DOMMatrix([scale, 0, 0, scale, offsetX, offsetY]);
        const raw = new Path2D(SVG_SHIRT);
        shirtPath = new Path2D();
        shirtPath.addPath(raw, shirtMx);
        shirtBottomY = offsetY + 595  * scale;
        shirtMidY    = offsetY + (SVG_SHIRT_TOP + SVG_SHIRT_H / 2) * scale;
      }

      function buildSwatchHits() {
        const n = SHIRT_COLORS.length;
        const r = Math.min(12, (W * 0.75) / (n * 3.2));
        const spacing = r * 3.2;
        const startX  = W / 2 - ((n - 1) * spacing) / 2;
        const swY = shirtBottomY + (H * 0.90 - shirtBottomY) * 0.42;
        swatchHits = SHIRT_COLORS.map((color, i) => ({
          x: startX + i * spacing, y: swY, r, color,
        }));
      }

      function resize() {
        W = canvas!.width  = canvas!.offsetWidth;
        H = canvas!.height = canvas!.offsetHeight;
        buildShirtPath();
        buildSwatchHits();
      }

      function hexToRgb(hex: string) {
        return { r: parseInt(hex.slice(1,3),16), g: parseInt(hex.slice(3,5),16), b: parseInt(hex.slice(5,7),16) };
      }

      function txPath(d: string) {
        const p = new Path2D(); p.addPath(new Path2D(d), shirtMx!); return p;
      }

      function drawGrid() {
        const dark = isDark();
        ctx.strokeStyle = dark ? 'rgba(200,190,170,0.04)' : 'rgba(160,150,135,0.09)';
        ctx.lineWidth = 0.5;
        const sp = 22;
        for (let x = 0; x < W; x += sp) { ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,H); ctx.stroke(); }
        for (let y = 0; y < H; y += sp) { ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); }
      }

      function drawShirtFill() {
        if (!shirtPath || !shirtMx) return;
        const dark = isDark();
        ctx.save();
        ctx.shadowColor  = dark ? 'rgba(0,0,0,0.70)' : 'rgba(44,26,14,0.28)';
        ctx.shadowBlur   = 38;
        ctx.shadowOffsetX = 6;
        ctx.shadowOffsetY = 16;
        ctx.fillStyle = shirtColor;
        ctx.fill(shirtPath);
        ctx.shadowColor = 'transparent';
        ctx.shadowBlur  = 0;
        ctx.shadowOffsetX = 0;
        ctx.shadowOffsetY = 0;
        ctx.fillStyle = dark ? 'rgba(0,0,0,0.20)' : 'rgba(0,0,0,0.11)';
        ctx.fill(txPath(SVG_COLLAR_FILL));
        ctx.restore();
      }

      function drawThreads() {
        if (!shirtPath || trails.length === 0) return;
        ctx.save();
        ctx.clip(shirtPath);
        trails.forEach(trail => {
          if (trail.pts.length < 2) return;
          const { r, g, b } = hexToRgb(trail.color);
          ctx.lineCap = 'round'; ctx.lineJoin = 'round'; ctx.lineWidth = 1.6;
          for (let i = 1; i < trail.pts.length; i++) {
            const a = trail.pts[i-1], bp = trail.pts[i];
            ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(bp.x,bp.y);
            ctx.strokeStyle = `rgba(${r},${g},${b},0.80)`;
            ctx.stroke();
          }
        });
        ctx.restore();
      }

      function drawShirtOverlay() {
        if (!shirtPath || !shirtMx) return;
        const dark = isDark();
        ctx.save();
        ctx.strokeStyle = dark ? 'rgba(200,190,170,0.38)' : 'rgba(44,26,14,0.30)';
        ctx.lineWidth = 1.5;
        ctx.stroke(shirtPath);
        ctx.restore();
      }

      function drawSwatches() {
        const dark = isDark();
        swatchHits.forEach(sw => {
          ctx.save();
          ctx.beginPath();
          ctx.arc(sw.x, sw.y, sw.r, 0, Math.PI * 2);
          ctx.fillStyle = sw.color;
          ctx.fill();
          ctx.strokeStyle = sw.color === shirtColor
            ? (dark ? 'rgba(250,248,245,0.9)' : 'rgba(44,26,14,0.75)')
            : (dark ? 'rgba(200,190,170,0.18)' : 'rgba(44,26,14,0.12)');
          ctx.lineWidth = sw.color === shirtColor ? 2 : 0.5;
          ctx.stroke();
          ctx.restore();
        });
        const first = swatchHits[0];
        if (!first) return;
        ctx.save();
        ctx.font = '500 8px "Archivo", sans-serif';
        ctx.letterSpacing = '0.16em';
        ctx.fillStyle = isDark() ? 'rgba(220,210,190,0.60)' : 'rgba(44,26,14,0.35)';
        ctx.textAlign = 'center';
        ctx.fillText('SHIRT COLOR', W / 2, first.y - first.r - 8);
        ctx.textAlign = 'left'; ctx.letterSpacing = '0';
        ctx.restore();
      }

      const isTouch = window.matchMedia('(pointer: coarse)').matches;

      function shirtTextColor() {
        const hex = shirtColor.replace('#', '');
        const r = parseInt(hex.slice(0,2),16), g = parseInt(hex.slice(2,4),16), b = parseInt(hex.slice(4,6),16);
        const lum = (r * 299 + g * 587 + b * 114) / 1000;
        return lum > 128 ? '44,26,14' : '240,232,220';
      }

      function drawHint() {
        if (hintOpacity <= 0 || !shirtPath) return;
        const base = shirtTextColor();
        const lines = isTouch
          ? ['DRAG INSIDE THE SHIRT TO DRAW', 'DOUBLE-TAP TO ERASE']
          : ['CLICK & DRAG INSIDE THE SHIRT TO DRAW', 'DOUBLE-CLICK TO ERASE'];
        ctx.save();
        ctx.clip(shirtPath);
        ctx.font = '500 9px "Archivo", sans-serif';
        ctx.letterSpacing = '0.14em';
        ctx.fillStyle = `rgba(${base},${hintOpacity * 0.52})`;
        ctx.textAlign = 'center';
        lines.forEach((line, i) => ctx.fillText(line, W / 2, shirtMidY - 8 + i * 17));
        ctx.textAlign = 'left'; ctx.letterSpacing = '0';
        ctx.restore();
      }

      function drawFrame() {
        requestAnimationFrame(drawFrame);
        ctx.clearRect(0, 0, W, H);
        drawGrid();
        drawShirtFill();
        drawThreads();
        drawShirtOverlay();
        if (hasDrawn) hintOpacity = Math.max(0, hintOpacity - 0.012);
        drawHint();
        drawSwatches();
      }

      function getXY(e: MouseEvent | Touch) {
        const rect = canvas!.getBoundingClientRect();
        return { x: e.clientX - rect.left, y: e.clientY - rect.top };
      }
      function inShirt(x: number, y: number) {
        return shirtPath ? ctx.isPointInPath(shirtPath, x, y) : false;
      }
      function hitSwatch(x: number, y: number) {
        return swatchHits.find(s => Math.hypot(x - s.x, y - s.y) <= s.r * 1.5);
      }
      function addPoint(x: number, y: number) {
        if (!currentTrail) {
          currentTrail = { pts: [], color: THREAD_COLORS[threadColorIdx % THREAD_COLORS.length] };
          threadColorIdx++;
          trails.push(currentTrail);
        }
        const last = currentTrail.pts[currentTrail.pts.length - 1];
        if (!last || Math.hypot(x - last.x, y - last.y) > 4) {
          currentTrail.pts.push({ x, y });
          hasDrawn = true;
        }
      }

      const section = canvas!.parentElement!;

      section.addEventListener('mousedown', (e: MouseEvent) => {
        const { x, y } = getXY(e);
        const sw = hitSwatch(x, y);
        if (sw) { shirtColor = sw.color; return; }
        if (inShirt(x, y)) { isDrawing = true; currentTrail = null; addPoint(x, y); }
      });
      section.addEventListener('mousemove', (e: MouseEvent) => {
        if (!isDrawing) return;
        const { x, y } = getXY(e);
        if (inShirt(x, y)) addPoint(x, y);
      });
      section.addEventListener('mouseup',    () => { isDrawing = false; currentTrail = null; });
      section.addEventListener('mouseleave', () => { isDrawing = false; currentTrail = null; });
      section.addEventListener('dblclick', (e: MouseEvent) => {
        const { x, y } = getXY(e);
        if (inShirt(x, y)) { trails = []; currentTrail = null; }
      });

      let lastTap = 0;
      section.addEventListener('touchstart', (e: TouchEvent) => {
        const { x, y } = getXY(e.touches[0]);
        const sw = hitSwatch(x, y);
        if (sw) { shirtColor = sw.color; return; }
        if (inShirt(x, y)) { isDrawing = true; currentTrail = null; addPoint(x, y); }
        const now = Date.now();
        if (now - lastTap < 300 && inShirt(x, y)) { trails = []; currentTrail = null; }
        lastTap = now;
      }, { passive: true });
      section.addEventListener('touchmove', (e: TouchEvent) => {
        e.preventDefault();
        if (!isDrawing) return;
        const { x, y } = getXY(e.touches[0]);
        if (inShirt(x, y)) addPoint(x, y);
      }, { passive: false });
      section.addEventListener('touchend', () => { isDrawing = false; currentTrail = null; });

      window.addEventListener('resize', resize);
      resize();
      drawFrame();
    })();
  </script>

</MainLayout>
