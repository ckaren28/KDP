---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Generative Textile Pattern Tool — Karen Dettmar">

  <style>
    /* ── PAGE SHELL ── */
    .tool-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 120px 48px 100px;
    }

    .back-nav {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      margin-bottom: 48px;
      transition: color 0.3s;
    }
    .back-nav:hover { color: var(--black); }

    /* ── PROJECT NAV ── */
    .project-nav {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-top: 6rem;
      margin-bottom: 2rem;
    }
    .project-nav-link {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .project-nav-link:hover { color: var(--black); }

    .next-project {
      margin-top: 0;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }
    .next-all {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .next-all:hover { color: var(--black); }

    .page-header {
      margin-bottom: 48px;
      padding-bottom: 32px;
      border-bottom: 1px solid var(--border);
    }
    .page-eyebrow {
      display: block;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 12px;
    }
    .page-title {
      font-family: var(--font-display);
      font-size: clamp(36px, 5vw, 72px);
      font-weight: 300;
      line-height: 0.95;
      letter-spacing: -0.01em;
      margin-bottom: 20px;
    }
    .page-title em { font-style: italic; color: var(--sienna); }

    .page-desc {
      font-size: 14px;
      line-height: 1.75;
      color: var(--text-body);
      font-weight: 300;
      max-width: 560px;
    }

    /* ── TWO-COLUMN TOOL LAYOUT ── */
    .tool-layout {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 0;
      align-items: start;
      min-height: calc(100vh - 300px);
    }

    /* ── CONTROLS PANEL ── */
    .controls-panel {
      border-right: 1px solid var(--border);
      padding-right: 36px;
      padding-bottom: 60px;
    }

    .ctrl-section {
      border-top: 1px solid var(--border);
      padding-top: 24px;
      margin-top: 24px;
    }
    .ctrl-section:first-child {
      border-top: none;
      padding-top: 0;
      margin-top: 0;
    }

    .ctrl-label {
      display: block;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-variant: small-caps;
      color: var(--muted);
      margin-bottom: 12px;
    }

    /* Concept textarea */
    .concept-textarea {
      width: 100%;
      resize: none;
      border: 1px solid var(--border);
      background: var(--off-white);
      color: var(--black);
      font-family: var(--font-body);
      font-size: 13px;
      font-weight: 300;
      line-height: 1.6;
      padding: 10px 12px;
      margin-bottom: 12px;
      outline: none;
      transition: border-color 0.3s;
      box-sizing: border-box;
    }
    .concept-textarea:focus { border-color: var(--black); }
    .concept-textarea::placeholder { color: var(--muted); }

    /* Generate button */
    .btn-generate {
      width: 100%;
      background: var(--black);
      color: var(--off-white);
      border: none;
      font-family: var(--font-body);
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 13px 20px;
      cursor: none;
      transition: background 0.3s, opacity 0.3s;
    }
    .btn-generate:hover:not(:disabled) { background: var(--hover-sweep, #3D2B1A); }
    .btn-generate:disabled { opacity: 0.5; cursor: not-allowed; }

    /* Swatches — scoped to parent only; children are JS-created so use :global */
    .swatch-row {
      margin-bottom: 12px;
    }
    :global(.swatch-item) {
      display: flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
      padding: 4px 0;
    }
    :global(.swatch-block) {
      position: relative;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      flex-shrink: 0;
      overflow: hidden;
      transition: box-shadow 0.2s;
    }
    :global(.swatch-item:hover .swatch-block) {
      box-shadow: 0 0 0 2px var(--black);
    }
    :global(.swatch-input) {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      cursor: pointer;
      border: none;
      padding: 0;
    }
    :global(.swatch-hex) {
      font-family: 'Courier New', monospace;
      font-size: 10.5px;
      color: var(--muted);
      flex: 1;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    :global(.swatch-edit) {
      font-size: 9px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      opacity: 0;
      transition: opacity 0.15s;
    }
    :global(.swatch-item:hover .swatch-edit) { opacity: 1; }

    .mood-text {
      font-size: 12px;
      font-style: italic;
      color: var(--muted);
      line-height: 1.6;
      min-height: 20px;
    }

    .error-msg {
      font-size: 11px;
      color: var(--sienna);
      margin-top: 8px;
      min-height: 16px;
    }

    /* Pattern type buttons */
    .pattern-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px;
    }
    .btn-pattern {
      border: 1px solid var(--border);
      background: transparent;
      color: var(--black);
      font-family: var(--font-body);
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 9px 12px;
      cursor: none;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
    }
    .btn-pattern:hover:not(.active) {
      border-color: var(--black);
    }
    .btn-pattern.active {
      background: var(--black);
      color: var(--off-white);
      border-color: var(--black);
    }

    /* Density slider */
    .density-slider {
      width: 100%;
      -webkit-appearance: none;
      appearance: none;
      height: 1px;
      background: var(--border);
      outline: none;
      margin-bottom: 8px;
      cursor: none;
    }
    .density-slider::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 14px;
      height: 14px;
      background: var(--black);
      border-radius: 50%;
      cursor: none;
    }
    .density-slider::-moz-range-thumb {
      width: 14px;
      height: 14px;
      background: var(--black);
      border-radius: 50%;
      border: none;
      cursor: none;
    }
    .density-labels {
      display: flex;
      justify-content: space-between;
    }
    .density-label {
      font-size: 9px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* Download button */
    .btn-download {
      width: 100%;
      background: transparent;
      color: var(--black);
      border: 1px solid var(--border);
      font-family: var(--font-body);
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 13px 20px;
      cursor: none;
      transition: border-color 0.3s, color 0.3s;
    }
    .btn-download:hover {
      border-color: var(--sienna);
      color: var(--sienna);
    }

    /* ── CANVAS PANEL ── */
    .canvas-panel {
      position: sticky;
      top: 100px;
      padding-left: 36px;
      display: flex;
      flex-direction: column;
      height: calc(100vh - 200px);
    }

    #patternCanvas {
      flex: 1;
      width: 100%;
      background: var(--warm-white);
      display: block;
    }

    .canvas-hint {
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      margin-top: 10px;
      text-align: center;
    }

    /* ── MOCKUP SECTION ── */
    .mockup-section {
      margin-top: 80px;
      padding-top: 48px;
      border-top: 1px solid var(--border);
    }
    .mockup-label {
      display: block;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 32px;
    }
    .mockup-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }
    .mockup-frame {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      background: var(--warm-white, #F5F1E8);
      padding: 28px 20px 20px;
    }
    .mockup-svg-container {
      width: 100%;
      height: 220px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .mockup-svg-container svg {
      max-width: 100%;
      max-height: 100%;
      display: block;
    }
    .mockup-name {
      font-family: var(--font-body);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* ── MOBILE ── */
    @media (max-width: 900px) {
      .tool-page { padding: 100px 24px 72px; }

      .tool-layout {
        grid-template-columns: 1fr;
        gap: 0;
      }

      .canvas-panel {
        position: static;
        height: max(60vw, 320px);
        padding-left: 0;
        margin-bottom: 40px;
        order: -1;
      }

      .controls-panel {
        border-right: none;
        padding-right: 0;
      }
    }
  </style>

  <div class="tool-page">

    <a href="/projects/tech" class="back-nav">← Creative Technology</a>

    <header class="page-header">
      <span class="page-eyebrow">Creative Technology</span>
      <h1 class="page-title">Generative Textile <em>Pattern Tool</em></h1>
      <p class="page-desc">Enter a collection concept and generate a living textile pattern. Palette and structure are AI-suggested, then fully adjustable.</p>

      <div class="mockup-section">
      <span class="mockup-label">Pattern in Context</span>
      <div class="mockup-row">
        <div class="mockup-frame">
          <div class="mockup-svg-container" id="mockupChair"></div>
          <span class="mockup-name">Chair</span>
        </div>
        <div class="mockup-frame">
          <div class="mockup-svg-container" id="mockupCoat"></div>
          <span class="mockup-name">Coat</span>
        </div>
        <div class="mockup-frame">
          <div class="mockup-svg-container" id="mockupTote"></div>
          <span class="mockup-name">Tote Bag</span>
        </div>
      </div>
    </div>
    </header>
    

    <div class="tool-layout">

      <!-- CONTROLS -->
      <aside class="controls-panel">

        <!-- Collection Concept -->
        <div class="ctrl-section">
          <label class="ctrl-label" for="conceptInput">Collection Concept</label>
          <textarea
            id="conceptInput"
            class="concept-textarea"
            rows="2"
            placeholder="e.g. Traveler, neutral tones, geometric"
          ></textarea>
          <button id="generateBtn" class="btn-generate">Generate Palette</button>
          <div class="error-msg" id="errorMsg"></div>
        </div>

        <!-- Color Palette -->
        <div class="ctrl-section">
          <span class="ctrl-label">Color Palette</span>
          <div class="swatch-row" id="swatches"></div>
          <p class="mood-text" id="moodText"></p>
        </div>

        <!-- Pattern Type -->
        <div class="ctrl-section">
          <span class="ctrl-label">Pattern Type</span>
          <div class="pattern-grid">
            <button class="btn-pattern" data-pattern="geometric">Geometric</button>
            <button class="btn-pattern" data-pattern="organic">Floral</button>
            <button class="btn-pattern" data-pattern="organic2">Organic</button>
            <button class="btn-pattern" data-pattern="stripe">Stripe</button>
            <button class="btn-pattern" data-pattern="grid">Grid</button>
          </div>
        </div>

        <!-- Density -->
        <div class="ctrl-section">
          <span class="ctrl-label">Density</span>
          <input type="range" id="densitySlider" class="density-slider" min="1" max="10" value="5" />
          <div class="density-labels">
            <span class="density-label">Coarse</span>
            <span class="density-label">Fine</span>
          </div>
        </div>

        <!-- Export -->
        <div class="ctrl-section">
          <button id="downloadBtn" class="btn-download">Download SVG</button>
        </div>

      </aside>

      <!-- CANVAS -->
      <div class="canvas-panel">
        <canvas id="patternCanvas"></canvas>
        <p class="canvas-hint">Click to pause · Click again to resume</p>
      </div>

    </div>

    

    <div class="project-nav">
      <span></span>
      <a href="/projects/garment-construction-decoder" class="project-nav-link">Garment Construction Decoder →</a>
    </div>
    <div class="next-project">
      <a href="/projects/tech" class="next-all">← Creative Technology</a>
    </div>

  </div>

  <script>
    // ── STATE ──
    let colors = ['#C4A882', '#8B6F5E', '#DED5BE', '#7D8C7C', '#5A5550'];
    let patternType = 'geometric';
    let density = 5;
    let frame = 0;
    let paused = false;
    let organicT  = 0;   // floral animation offset, incremented per frame
    let organic2T = 0;   // organic2 flow field offset
    let organicRafId:  number | null = null;
    let organic2RafId: number | null = null;

    // ── ELEMENTS ──
    const canvas = document.getElementById('patternCanvas');
    const ctx = canvas.getContext('2d');
    const generateBtn = document.getElementById('generateBtn');
    const conceptInput = document.getElementById('conceptInput');
    const errorMsg = document.getElementById('errorMsg');
    const moodText = document.getElementById('moodText');
    const densitySlider = document.getElementById('densitySlider');
    const downloadBtn = document.getElementById('downloadBtn');

    // ── CANVAS RESIZE ──
    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }

    // ── TILE SIZE ──
    function getTileSize() {
      return Math.round(100 - (density - 1) * 80 / 9);
    }

    // ── PATTERN DRAWING ──

    function drawGeometric(ctx, W, H, colors, tileSize, frame) {
      const t = tileSize;
      const drift  = (frame * 0.10) % t;
      const slowRot = frame * 0.004; // gentle continuous rotation

      ctx.fillStyle = colors[0];
      ctx.fillRect(0, 0, W, H);

      const cols = Math.ceil(W / t) + 3;
      const rows = Math.ceil(H / t) + 3;

      for (let row = -1; row < rows; row++) {
        for (let col = -1; col < cols; col++) {
          const cx = col * t + t / 2 - drift;
          const cy = row * t + t / 2 - drift;
          const isAlt = (row + col) % 2 !== 0;
          const r = t * 0.46;
          const innerR = r * 0.42;

          // Alternating tile background
          ctx.fillStyle = isAlt ? colors[1] : colors[0];
          ctx.fillRect(cx - t / 2, cy - t / 2, t, t);

          ctx.save();
          ctx.translate(cx, cy);
          ctx.rotate(slowRot);

          // 8-pointed star (classic Islamic khatam motif)
          ctx.beginPath();
          for (let i = 0; i < 16; i++) {
            const angle = (i * Math.PI / 8) - Math.PI / 2;
            const rad = i % 2 === 0 ? r : innerR;
            const px = Math.cos(angle) * rad;
            const py = Math.sin(angle) * rad;
            if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
          }
          ctx.closePath();
          ctx.fillStyle = isAlt ? colors[2] : colors[3];
          ctx.fill();

          // Inner square rotated 45° (counter-rotates slightly for depth)
          const sq = innerR * 0.64;
          ctx.rotate(Math.PI / 4 - slowRot * 0.5);
          ctx.fillStyle = isAlt ? colors[3] : colors[2];
          ctx.fillRect(-sq, -sq, sq * 2, sq * 2);

          // Centre jewel
          ctx.rotate(-Math.PI / 4 + slowRot * 0.5);
          ctx.beginPath();
          ctx.arc(0, 0, r * 0.14, 0, Math.PI * 2);
          ctx.fillStyle = colors[4];
          ctx.fill();

          ctx.restore();

          // Small rotated diamond accent at each tile corner midpoint
          if (!isAlt) {
            [[t / 2, 0], [0, t / 2], [-t / 2, 0], [0, -t / 2]].forEach(([dx, dy]) => {
              ctx.save();
              ctx.translate(cx + dx, cy + dy);
              ctx.rotate(Math.PI / 4);
              const ds = t * 0.09;
              ctx.fillStyle = colors[4];
              ctx.fillRect(-ds, -ds, ds * 2, ds * 2);
              ctx.restore();
            });
          }
        }
      }
    }

    // ── FLORAL — Marimekko bold botanical tile grid ──

    // Irregular blob: 8 bezier points with ±40% radius variation
    function drawFloralBlob(c: CanvasRenderingContext2D, cx: number, cy: number,
                             r: number, seed: number) {
      const N = 8;
      // Compute all radii first so we can close the shape cleanly
      const radii: number[] = [];
      for (let i = 0; i < N; i++) radii.push(r * (0.6 + 0.4 * Math.abs(Math.sin(seed + i * 1.9))));
      c.beginPath();
      for (let i = 0; i < N; i++) {
        const a0 = (i / N) * Math.PI * 2 - Math.PI / 2;
        const a1 = ((i + 1) / N) * Math.PI * 2 - Math.PI / 2;
        const aMid = (a0 + a1) / 2;
        // current point
        const px = cx + Math.cos(a0) * radii[i];
        const py = cy + Math.sin(a0) * radii[i];
        // next point
        const nx = cx + Math.cos(a1) * radii[(i + 1) % N];
        const ny = cy + Math.sin(a1) * radii[(i + 1) % N];
        // control point bulges outward at midpoint
        const cpR = (radii[i] + radii[(i + 1) % N]) / 2 * 1.15;
        const cpx = cx + Math.cos(aMid) * cpR;
        const cpy = cy + Math.sin(aMid) * cpR;
        if (i === 0) c.moveTo(px, py);
        c.quadraticCurveTo(cpx, cpy, nx, ny);
      }
      c.closePath();
      c.fill();
    }

    // Leaf: pointed oval from (x0,y0) to (x1,y1) with bulge controlled by bulge param
    function drawLeaf(c: CanvasRenderingContext2D, x0: number, y0: number,
                       x1: number, y1: number, bulge: number) {
      const mx = (x0 + x1) / 2, my = (y0 + y1) / 2;
      const dx = x1 - x0, dy = y1 - y0;
      const px = -dy * bulge, py = dx * bulge; // perpendicular offset
      c.beginPath();
      c.moveTo(x0, y0);
      c.quadraticCurveTo(mx + px, my + py, x1, y1);
      c.quadraticCurveTo(mx - px, my - py, x0, y0);
      c.closePath();
      c.fill();
    }

    // Draw one complete floral tile centered at (cx, cy) with given tile size
    function drawFloralTile(c: CanvasRenderingContext2D, cx: number, cy: number,
                             tileSize: number, tileAngle: number, seed: number) {
      c.save();
      c.translate(cx, cy);
      c.rotate(tileAngle);

      const blobR   = tileSize * 0.35;
      const pLen    = tileSize * 0.38; // petal length
      const pHalf   = tileSize * 0.09; // petal half-width at widest
      const stemLen = tileSize * 0.3;
      const leafLen = tileSize * 0.2;

      // 1. Background blob in colors[1]
      c.fillStyle = colors[1];
      drawFloralBlob(c, 0, 0, blobR, seed);

      // 2. Five teardrop petals radiating from center, alternating colors[2] / colors[3]
      for (let p = 0; p < 5; p++) {
        const angle = (p / 5) * Math.PI * 2 - Math.PI / 2;
        c.save();
        c.rotate(angle);
        c.fillStyle = (p % 2 === 0) ? colors[2] : colors[3];
        c.beginPath();
        // Teardrop: base at origin, tip at (0, -pLen)
        c.moveTo(0, 0);
        c.bezierCurveTo(-pHalf * 1.2, -pLen * 0.25, -pHalf, -pLen * 0.75, 0, -pLen);
        c.bezierCurveTo( pHalf,       -pLen * 0.75,  pHalf * 1.2, -pLen * 0.25, 0, 0);
        c.closePath();
        c.fill();
        c.restore();
      }

      // 3. Curved stem downward from blob edge
      const stemStartY = blobR;
      const stemEndY   = stemStartY + stemLen;
      const stemCPx    = tileSize * 0.1 * Math.sin(seed);
      c.strokeStyle = colors[4];
      c.lineWidth   = Math.max(2, tileSize * 0.03);
      c.lineCap     = 'round';
      c.beginPath();
      c.moveTo(0, stemStartY);
      c.quadraticCurveTo(stemCPx, stemStartY + stemLen * 0.5, 0, stemEndY);
      c.stroke();

      // 4. Two pointed leaves branching from stem at 1/3 down
      const leafY      = stemStartY + stemLen * 0.33;
      const leafColors = [colors[2], colors[3]];
      for (let l = 0; l < 2; l++) {
        const side = l === 0 ? 1 : -1;
        c.fillStyle = leafColors[l];
        drawLeaf(c,
          side * tileSize * 0.04, leafY,
          side * leafLen, leafY - leafLen * 0.6,
          0.45
        );
      }

      // 5. Center dot in colors[4] — drawn LAST so it sits on top
      c.fillStyle = colors[4];
      c.beginPath();
      c.arc(0, 0, tileSize * 0.06, 0, Math.PI * 2);
      c.fill();

      c.restore();
    }

    function drawOrganicFrame() {
      if (paused) return;
      const W  = (canvas as HTMLCanvasElement).width;
      const H  = (canvas as HTMLCanvasElement).height;
      // density 1=coarse (large tiles ~300px), 10=fine (small tiles ~120px)
      const tileSize = Math.round(300 - (density - 1) * 20); // 300 → 120
      const drift    = Math.sin(organicT) * 4; // gentle breathing offset

      ctx.globalAlpha = 1.0;
      ctx.fillStyle   = colors[0];
      ctx.fillRect(0, 0, W, H);

      const cols = Math.ceil(W / tileSize) + 2;
      const rows = Math.ceil(H / tileSize) + 2;

      for (let row = -1; row < rows; row++) {
        for (let col = -1; col < cols; col++) {
          // Brick-layout stagger: every other column shifts down half a tile
          const stagger = (col % 2 === 0) ? 0 : tileSize * 0.5;
          const cx = col * tileSize + tileSize * 0.5 + drift;
          const cy = row * tileSize + tileSize * 0.5 + stagger + drift * 0.7;

          // Small deterministic rotation per tile, capped at ±15°
          const rawAngle = ((col * 17 + row * 31) % 360) * (Math.PI / 180);
          const tileAngle = ((rawAngle + Math.PI) % (Math.PI * 2) - Math.PI) * (8 / 180);

          const seed = col * 7.3 + row * 13.1;
          drawFloralTile(ctx, cx, cy, tileSize, tileAngle, seed);
        }
      }

      mockupTick++;
      if (mockupTick % MOCKUP_EVERY === 0) updateMockupPatterns();

      organicT += 0.008;
      organicRafId = requestAnimationFrame(drawOrganicFrame);
    }

    function startOrganicLoop() {
      if (organicRafId !== null) return;
      organicRafId = requestAnimationFrame(drawOrganicFrame);
    }
    function stopOrganicLoop() {
      if (organicRafId !== null) { cancelAnimationFrame(organicRafId); organicRafId = null; }
    }

    // ── ORGANIC2 — Truchet tile system ──

    function drawOrganic2Frame() {
      if (paused) return;
      const W        = (canvas as HTMLCanvasElement).width;
      const H        = (canvas as HTMLCanvasElement).height;
      const tileSize = getTileSize();
      const phase    = Math.floor(organic2T / 60); // morphs every 60 frames

      ctx.fillStyle   = colors[0];
      ctx.fillRect(0, 0, W, H);
      ctx.lineCap     = 'butt';
      ctx.lineJoin    = 'round';
      ctx.globalAlpha = 1.0;

      const cols = Math.ceil(W / tileSize) + 1;
      const rows = Math.ceil(H / tileSize) + 1;

      for (let row = 0; row < rows; row++) {
        for (let col = 0; col < cols; col++) {
          const x         = col * tileSize;
          const y         = row * tileSize;
          const isTypeA   = Math.sin(col * 1.7 + row * 2.3 + phase) > 0;
          const cellColor = colors[1 + ((col * 2 + row * 3) % 4)];

          // Draw thick colored arc
          ctx.lineWidth   = tileSize * 0.6;
          ctx.strokeStyle = cellColor;
          ctx.beginPath();
          if (isTypeA) {
            // Type A: arc at top-left corner, connects top-mid to left-mid
            ctx.arc(x, y, tileSize / 2, 0, Math.PI / 2);
          } else {
            // Type B: arc at bottom-right corner, connects bottom-mid to right-mid
            ctx.arc(x + tileSize, y + tileSize, tileSize / 2, Math.PI, Math.PI * 3 / 2);
          }
          ctx.stroke();

          // Draw narrow gap arc in background color on top
          ctx.lineWidth   = tileSize * 0.18;
          ctx.strokeStyle = colors[0];
          ctx.beginPath();
          if (isTypeA) {
            ctx.arc(x, y, tileSize / 2, 0, Math.PI / 2);
          } else {
            ctx.arc(x + tileSize, y + tileSize, tileSize / 2, Math.PI, Math.PI * 3 / 2);
          }
          ctx.stroke();
        }
      }

      mockupTick++;
      if (mockupTick % MOCKUP_EVERY === 0) updateMockupPatterns();

      organic2T += 1;
      organic2RafId = requestAnimationFrame(drawOrganic2Frame);
    }

    function startOrganic2Loop() {
      if (organic2RafId !== null) return;
      organic2RafId = requestAnimationFrame(drawOrganic2Frame);
    }
    function stopOrganic2Loop() {
      if (organic2RafId !== null) { cancelAnimationFrame(organic2RafId); organic2RafId = null; }
    }
    function stopAllLoops() {
      stopOrganicLoop();
      stopOrganic2Loop();
      // main draw() self-terminates when paused === true
    }

    function drawStripe(ctx, W, H, colors, tileSize, frame) {
      ctx.fillStyle = colors[0];
      ctx.fillRect(0, 0, W, H);

      const stripeWidth = tileSize;
      const diagonalLen = Math.sqrt(W * W + H * H);
      const slideOffset = (frame * 0.4) % (stripeWidth * colors.length);

      ctx.save();
      ctx.translate(W / 2, H / 2);
      ctx.rotate(Math.PI / 4);

      const count = Math.ceil(diagonalLen * 2 / stripeWidth) + colors.length;
      const startX = -diagonalLen - slideOffset;

      for (let i = 0; i < count; i++) {
        const x = startX + i * stripeWidth;
        ctx.fillStyle = colors[i % colors.length];
        ctx.fillRect(x, -diagonalLen, stripeWidth, diagonalLen * 2);
      }

      ctx.restore();
    }

    function drawGrid(ctx, W, H, colors, tileSize, frame) {
      ctx.fillStyle = colors[0];
      ctx.fillRect(0, 0, W, H);

      const t = tileSize;
      const offsetX = (frame * 0.12) % t;
      const offsetY = (frame * 0.12) % t;

      const cols = Math.ceil(W / t) + 2;
      const rows = Math.ceil(H / t) + 2;

      // Weft bands (horizontal)
      for (let row = -1; row < rows; row++) {
        const y = row * t + offsetY;
        ctx.globalAlpha = 0.75;
        ctx.fillStyle = colors[1];
        ctx.fillRect(0, y, W, t * 0.55);
      }

      // Warp bands (vertical)
      for (let col = -1; col < cols; col++) {
        const x = col * t + offsetX;
        ctx.globalAlpha = 0.7;
        ctx.fillStyle = colors[2];
        ctx.fillRect(x, 0, t * 0.55, H);
      }

      // Intersection squares
      for (let row = -1; row < rows; row++) {
        for (let col = -1; col < cols; col++) {
          const x = col * t + offsetX;
          const y = row * t + offsetY;
          ctx.globalAlpha = 0.85;
          ctx.fillStyle = colors[3];
          ctx.fillRect(x, y, t * 0.55, t * 0.55);
        }
      }

      ctx.globalAlpha = 1;
    }

    // ── SVG MOCKUPS ──
    const STROKE = '#3d2b1f';
    const SVG_NS = 'http://www.w3.org/2000/svg';

    // Small offscreen canvas for pattern sampling (avoids toDataURL on the huge main canvas)
    const offCanvas = document.createElement('canvas');
    offCanvas.width = 512;
    offCanvas.height = 512;
    const offCtx = offCanvas.getContext('2d');

    let mockupTick = 0;
    const MOCKUP_EVERY = 4; // update pattern image every N frames

    async function loadMockupSVG(
      svgPath: string,
      containerId: string,
      patternId: string
    ) {
      try {
        const res = await fetch(svgPath);
        const text = await res.text();
        const parser = new DOMParser();
        const svgDoc = parser.parseFromString(text, 'image/svg+xml');
        const svgEl = svgDoc.querySelector('svg');
        if (!svgEl) return;

        const vb = (svgEl.getAttribute('viewBox') || '0 0 100 100').split(/[\s,]+/);
        const vw = parseFloat(vb[2]);
        const vh = parseFloat(vb[3]);

        // Ensure defs element
        let defs = svgEl.querySelector('defs');
        if (!defs) {
          defs = svgDoc.createElementNS(SVG_NS, 'defs');
          svgEl.insertBefore(defs, svgEl.firstChild);
        }

        // Inject pattern + image placeholder
        const pat = svgDoc.createElementNS(SVG_NS, 'pattern');
        pat.setAttribute('id', patternId);
        pat.setAttribute('patternUnits', 'userSpaceOnUse');
        pat.setAttribute('x', '0'); pat.setAttribute('y', '0');
        pat.setAttribute('width', String(vw)); pat.setAttribute('height', String(vh));

        const imgNode = svgDoc.createElementNS(SVG_NS, 'image');
        imgNode.setAttribute('id', `${patternId}-img`);
        imgNode.setAttribute('x', '0'); imgNode.setAttribute('y', '0');
        imgNode.setAttribute('width', String(vw)); imgNode.setAttribute('height', String(vh));
        imgNode.setAttribute('preserveAspectRatio', 'xMidYMid slice');
        imgNode.setAttribute('href', '');

        pat.appendChild(imgNode);
        defs.appendChild(pat);

        // Apply pattern fill only to paths whose id contains "fabric" (case-insensitive).
        // Structural paths (no fabric id) keep their original styles unchanged.
        svgEl.querySelectorAll('[style]').forEach(el => {
          const id = (el.getAttribute('id') || '').toLowerCase();
          const isFabric = id.includes('fabric');
          let s = el.getAttribute('style') || '';

          if (isFabric) {
            if (/fill:\s*[^;]+/.test(s)) {
              s = s.replace(/fill:\s*[^;]+/, `fill: url(#${patternId})`);
            } else {
              s = `fill: url(#${patternId}); ${s}`;
            }
          }

          // Apply warm stroke color to any path that already has a stroke defined
          if (s.includes('stroke:')) {
            s = s.replace(/stroke:\s*#[0-9a-fA-F]+/, `stroke: ${STROKE}`);
          }

          el.setAttribute('style', s);
        });

        // Make SVG fluid
        svgEl.setAttribute('width', '100%');
        svgEl.setAttribute('height', '100%');
        svgEl.style.cssText = 'display:block;width:100%;height:100%;';

        // Import into live document
        const container = document.getElementById(containerId);
        if (!container) return;
        container.innerHTML = '';
        container.appendChild(document.importNode(svgEl, true));

      } catch (e) {
        // silently skip failed loads
      }
    }

    function updateMockupPatterns() {
      const mainCanvas = canvas as HTMLCanvasElement;
      if (!mainCanvas || !mainCanvas.width || !offCtx) return;
      offCtx.drawImage(mainCanvas, 0, 0, offCanvas.width, offCanvas.height);
      const dataUrl = offCanvas.toDataURL('image/jpeg', 0.72);
      for (const pid of ['mp-chair', 'mp-coat', 'mp-tote']) {
        const imgEl = document.getElementById(`${pid}-img`);
        if (imgEl) imgEl.setAttribute('href', dataUrl);
      }
    }

    // Load all three SVGs on page load
    Promise.all([
      loadMockupSVG('/images/chair-textilegen.svg',   'mockupChair', 'mp-chair'),
      loadMockupSVG('/images/coat-textilegen.svg',    'mockupCoat',  'mp-coat'),
      loadMockupSVG('/images/totebag-textilegen.svg', 'mockupTote',  'mp-tote'),
    ]);

    // ── DRAW LOOP ──
    function draw() {
      if (paused) return;

      const W = canvas.width;
      const H = canvas.height;
      const tileSize = getTileSize();

      if (patternType === 'geometric') drawGeometric(ctx, W, H, colors, tileSize, frame);
      else if (patternType === 'stripe') drawStripe(ctx, W, H, colors, tileSize, frame);
      else if (patternType === 'grid') drawGrid(ctx, W, H, colors, tileSize, frame);
      // organic + organic2 have their own RAF loops — skipped here

      if (patternType !== 'organic' && patternType !== 'organic2') {
        mockupTick++;
        if (mockupTick % MOCKUP_EVERY === 0) updateMockupPatterns();
      }

      frame++;
      requestAnimationFrame(draw);
    }

    // ── SVG EXPORT ──
    function generateSVG() {
      const t = getTileSize();
      const W = 800;
      const H = 600;

      if (patternType === 'geometric') {
        // 8-pointed star (khatam) tiled across canvas — static snapshot
        const r    = t * 0.46;
        const innR = r * 0.42;
        const sq   = innR * 0.64;
        let tiles  = '';
        const svgCols = Math.ceil(W / t) + 2;
        const svgRows = Math.ceil(H / t) + 2;
        for (let row = -1; row < svgRows; row++) {
          for (let col = -1; col < svgCols; col++) {
            const cx = col * t + t / 2;
            const cy = row * t + t / 2;
            const alt = (row + col) % 2 !== 0;
            tiles += `<rect x="${cx - t/2}" y="${cy - t/2}" width="${t}" height="${t}" fill="${alt ? colors[1] : colors[0]}"/>`;
            let pts = '';
            for (let i = 0; i < 16; i++) {
              const a = (i * Math.PI / 8) - Math.PI / 2;
              const rad = i % 2 === 0 ? r : innR;
              pts += `${(cx + Math.cos(a)*rad).toFixed(1)},${(cy + Math.sin(a)*rad).toFixed(1)} `;
            }
            tiles += `<polygon points="${pts}" fill="${alt ? colors[2] : colors[3]}"/>`;
            tiles += `<rect x="${(cx-sq).toFixed(1)}" y="${(cy-sq).toFixed(1)}" width="${(sq*2).toFixed(1)}" height="${(sq*2).toFixed(1)}" fill="${alt ? colors[3] : colors[2]}" transform="rotate(45,${cx.toFixed(1)},${cy.toFixed(1)})"/>`;
            tiles += `<circle cx="${cx}" cy="${cy}" r="${(r*0.14).toFixed(1)}" fill="${colors[4]}"/>`;
          }
        }
        return `<svg xmlns="http://www.w3.org/2000/svg" width="${W}" height="${H}">${tiles}</svg>`;

      } else if (patternType === 'organic') {
        // Floral — render to offscreen canvas using same drawFloralTile logic, embed as PNG in SVG
        const oc  = document.createElement('canvas');
        oc.width  = W; oc.height = H;
        const oc2 = oc.getContext('2d')!;
        const tileSize2 = Math.round(300 - (density - 1) * 20);
        const drift2    = Math.sin(organicT) * 4;
        oc2.fillStyle = colors[0]; oc2.fillRect(0, 0, W, H);
        const cols2 = Math.ceil(W / tileSize2) + 2;
        const rows2 = Math.ceil(H / tileSize2) + 2;
        for (let row = -1; row < rows2; row++) {
          for (let col = -1; col < cols2; col++) {
            const stagger   = (col % 2 === 0) ? 0 : tileSize2 * 0.5;
            const cx2       = col * tileSize2 + tileSize2 * 0.5 + drift2;
            const cy2       = row * tileSize2 + tileSize2 * 0.5 + stagger + drift2 * 0.7;
            const rawAngle2 = ((col * 17 + row * 31) % 360) * (Math.PI / 180);
            const tileAngle2 = ((rawAngle2 + Math.PI) % (Math.PI * 2) - Math.PI) * (8 / 180);
            drawFloralTile(oc2, cx2, cy2, tileSize2, tileAngle2, col * 7.3 + row * 13.1);
          }
        }
        const dataUrl = oc.toDataURL('image/png');
        return `<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="${W}" height="${H}"><image width="${W}" height="${H}" xlink:href="${dataUrl}"/></svg>`;

      } else if (patternType === 'organic2') {
        // Truchet tiles — render to offscreen canvas using same drawOrganic2Frame logic, embed as PNG in SVG
        const oc  = document.createElement('canvas');
        oc.width  = W; oc.height = H;
        const oc2 = oc.getContext('2d')!;
        const ts2   = getTileSize();
        const phase2 = Math.floor(organic2T / 60);
        oc2.fillStyle = colors[0]; oc2.fillRect(0, 0, W, H);
        oc2.lineCap = 'butt'; oc2.lineJoin = 'round'; oc2.globalAlpha = 1.0;
        const cols3 = Math.ceil(W / ts2) + 1;
        const rows3 = Math.ceil(H / ts2) + 1;
        for (let row = 0; row < rows3; row++) {
          for (let col = 0; col < cols3; col++) {
            const x3 = col * ts2, y3 = row * ts2;
            const isA3   = Math.sin(col * 1.7 + row * 2.3 + phase2) > 0;
            const cc  = colors[1 + ((col * 2 + row * 3) % 4)];
            function drawTruchetArc(c: CanvasRenderingContext2D) {
              c.beginPath();
              if (isA3) { c.arc(x3, y3, ts2 / 2, 0, Math.PI / 2); }
              else      { c.arc(x3 + ts2, y3 + ts2, ts2 / 2, Math.PI, Math.PI * 3 / 2); }
              c.stroke();
            }
            oc2.lineWidth = ts2 * 0.6;  oc2.strokeStyle = cc;         drawTruchetArc(oc2);
            oc2.lineWidth = ts2 * 0.18; oc2.strokeStyle = colors[0];  drawTruchetArc(oc2);
          }
        }
        const dataUrl2 = oc.toDataURL('image/png');
        return `<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="${W}" height="${H}"><image width="${W}" height="${H}" xlink:href="${dataUrl2}"/></svg>`;

      } else if (patternType === 'stripe') {
        const sw = t;
        const diag = Math.sqrt(W * W + H * H);
        const count = Math.ceil(diag * 2 / sw) + colors.length;
        const cx = W / 2;
        const cy = H / 2;
        let rects = '';
        for (let i = 0; i < count; i++) {
          const x = cx - diag + i * sw;
          rects += `  <rect x="${x.toFixed(1)}" y="${(cy - diag).toFixed(1)}" width="${sw}" height="${(diag * 2).toFixed(1)}" fill="${colors[i % colors.length]}"/>\n`;
        }
        return `<svg xmlns="http://www.w3.org/2000/svg" width="${W}" height="${H}">
  <rect width="${W}" height="${H}" fill="${colors[0]}"/>
  <g transform="rotate(45, ${cx}, ${cy})">
${rects}  </g>
</svg>`;

      } else {
        // grid
        const cols = Math.ceil(W / t) + 1;
        const rows = Math.ceil(H / t) + 1;
        let weft = '';
        let warp = '';
        let intersections = '';
        for (let row = 0; row < rows; row++) {
          weft += `  <rect x="0" y="${row * t}" width="${W}" height="${(t * 0.55).toFixed(1)}" fill="${colors[1]}" fill-opacity="0.75"/>\n`;
        }
        for (let col = 0; col < cols; col++) {
          warp += `  <rect x="${col * t}" y="0" width="${(t * 0.55).toFixed(1)}" height="${H}" fill="${colors[2]}" fill-opacity="0.7"/>\n`;
        }
        for (let row = 0; row < rows; row++) {
          for (let col = 0; col < cols; col++) {
            intersections += `  <rect x="${col * t}" y="${row * t}" width="${(t * 0.55).toFixed(1)}" height="${(t * 0.55).toFixed(1)}" fill="${colors[3]}" fill-opacity="0.85"/>\n`;
          }
        }
        return `<svg xmlns="http://www.w3.org/2000/svg" width="${W}" height="${H}">
  <rect width="${W}" height="${H}" fill="${colors[0]}"/>
${weft}${warp}${intersections}</svg>`;
      }
    }

    // ── UI HELPERS ──

    function updateSwatches() {
      const container = document.getElementById('swatches');
      if (!container) return;
      container.innerHTML = colors.map((hex, i) => `
        <div class="swatch-item" data-index="${i}">
          <div class="swatch-block" style="background:${hex}">
            <input type="color" class="swatch-input" value="${hex}" data-index="${i}" />
          </div>
          <span class="swatch-hex">${hex}</span>
          <span class="swatch-edit">Edit</span>
        </div>
      `).join('');

      container.querySelectorAll('.swatch-input').forEach(input => {
        input.addEventListener('input', () => {
          const el = input as HTMLInputElement;
          const idx = Number(el.dataset.index);
          const hex = el.value;
          colors[idx] = hex;
          const block = el.closest('.swatch-item')!.querySelector('.swatch-block') as HTMLElement;
          block.style.background = hex;
          el.closest('.swatch-item')!.querySelector('.swatch-hex')!.textContent = hex;
        });
      });
    }

    function updatePatternBtns() {
      document.querySelectorAll('.btn-pattern').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.pattern === patternType);
      });
    }

    // ── EVENT HANDLERS ──

    generateBtn.addEventListener('click', async () => {
      const concept = conceptInput.value.trim();
      if (concept.length < 3) {
        errorMsg.textContent = 'Please enter a concept (3+ characters).';
        return;
      }
      errorMsg.textContent = '';
      generateBtn.textContent = 'Generating\u2026';
      generateBtn.disabled = true;

      try {
        const res = await fetch('/.netlify/functions/textile-palette', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ concept }),
        });
        const data = await res.json();
        if (!res.ok) {
          errorMsg.textContent = data.error || 'Something went wrong. Try again.';
        } else {
          colors = data.colors;
          patternType = data.patternStyle || patternType;
          moodText.textContent = data.mood || '';
          updateSwatches();
          updatePatternBtns();
        }
      } catch {
        errorMsg.textContent = 'Network error. Please try again.';
      } finally {
        generateBtn.textContent = 'Generate Palette';
        generateBtn.disabled = false;
      }
    });

    document.querySelectorAll('.btn-pattern').forEach(btn => {
      btn.addEventListener('click', () => {
        const next = (btn as HTMLElement).dataset.pattern as string;
        // Stop any running organic loops before switching
        stopOrganicLoop();
        stopOrganic2Loop();
        patternType = next;
        if (next === 'organic')  startOrganicLoop();
        if (next === 'organic2') startOrganic2Loop();
        updatePatternBtns();
      });
    });

    densitySlider.addEventListener('input', () => {
      density = Number(densitySlider.value);
    });

    canvas.addEventListener('click', () => {
      paused = !paused;
      if (paused) {
        stopAllLoops();
      } else {
        if (patternType === 'organic')       startOrganicLoop();
        else if (patternType === 'organic2') startOrganic2Loop();
        else requestAnimationFrame(draw);
      }
    });

    window.addEventListener('resize', resize);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        paused = true;
        stopAllLoops();
      } else {
        paused = false;
        if (patternType === 'organic')       startOrganicLoop();
        else if (patternType === 'organic2') startOrganic2Loop();
        else requestAnimationFrame(draw);
      }
    });

    downloadBtn.addEventListener('click', () => {
      const svg = generateSVG();
      const blob = new Blob([svg], { type: 'image/svg+xml' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'textile-pattern.svg';
      a.click();
      URL.revokeObjectURL(url);
    });

    // ── INIT ──
    updateSwatches();
    updatePatternBtns();
    resize();
    draw();
  </script>

</MainLayout>
