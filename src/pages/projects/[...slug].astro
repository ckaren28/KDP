---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project, allProjects: projects },
  }));
}

const { project, allProjects } = Astro.props;
const { Content } = await project.render();

const sorted = allProjects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const currentIndex = sorted.findIndex(p => p.slug === project.slug);
const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

// Traveller is a standalone page — use it as the adjacent project when at the boundary
const prevLink = prev ? { href: `/projects/${prev.slug}`, title: prev.data.title } : { href: '/projects/traveller', title: 'Traveller' };
const nextLink = next ? { href: `/projects/${next.slug}`, title: next.data.title } : { href: '/projects/traveller', title: 'Traveller' };
---

<MainLayout title={`${project.data.title} — Karen Dettmar`}>
  <div class="project-wrapper">

    <!-- Page header -->
    <div class="project-header">
      <span class="page-eyebrow">{project.data.tags[0]}</span>
      <h1 class="project-title">{project.data.title}</h1>
      <p class="project-description">{project.data.description}</p>
    </div>

    <!-- Cover image -->
    {project.data.coverImage && (
      <div class="project-cover">
        <img src={project.data.coverImage} alt={project.data.title} />
      </div>
    )}

    <!-- Tags -->
    <div class="project-tags">
      {project.data.tags.map((tag: string) => (
        <a href={`/tags/${tag}`} class="tag">{tag}</a>
      ))}
    </div>

    <!-- Content -->
    <div class="project-content">
      <Content />
    </div>

    <!-- Project navigation -->
    <nav class="project-nav">
      <a href="/projects" class="nav-all">← All Projects</a>
      <div class="nav-adjacent">
        <a href={prevLink.href} class="nav-prev">
          <span class="nav-dir">← Previous</span>
          <span class="nav-project-title">{prevLink.title}</span>
        </a>
        <a href={nextLink.href} class="nav-next">
          <span class="nav-dir">Next →</span>
          <span class="nav-project-title">{nextLink.title}</span>
        </a>
      </div>
    </nav>

  </div>
</MainLayout>

<style>
  .project-wrapper {
    max-width: 860px;
    margin: 0 auto;
    padding: 120px 48px 100px;
  }

  /* ── HEADER ── */
  .project-header {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .project-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .project-description {
    font-family: var(--font-display);
    font-size: clamp(16px, 2vw, 20px);
    font-style: italic;
    font-weight: 400;
    color: var(--muted);
    line-height: 1.5;
    max-width: 60ch;
  }

  /* ── COVER ── */
  .project-cover {
    margin-bottom: 40px;
  }

  .project-cover img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
  }

  /* ── TAGS ── */
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 48px;
  }

  .tag {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 6px 14px;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .tag:hover {
    background: var(--black);
    color: var(--off-white);
  }

  /* ── CONTENT (MDX prose) ── */
  .project-content {
    font-size: 16px;
    line-height: 1.85;
    color: #3a3a38;
    margin-bottom: 80px;
  }

  .project-content :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 400;
    letter-spacing: -0.01em;
    margin: 56px 0 20px;
    color: var(--black);
  }

  .project-content :global(h3) {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 400;
    font-style: italic;
    margin: 40px 0 16px;
    color: var(--black);
  }

  .project-content :global(p) {
    margin-bottom: 20px;
  }

  .project-content :global(ul),
  .project-content :global(ol) {
    padding-left: 1.5em;
    margin-bottom: 20px;
  }

  .project-content :global(li) {
    margin-bottom: 8px;
  }

  .project-content :global(strong) {
    font-weight: 500;
    color: var(--black);
  }

  /* ── PROJECT NAVIGATION ── */
  .project-nav {
    border-top: 1px solid var(--border);
    padding-top: 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-all {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-all:hover { color: var(--black); }

  .nav-adjacent {
    display: flex;
    gap: 48px;
  }

  .nav-prev,
  .nav-next {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-prev { align-items: flex-start; }
  .nav-next { align-items: flex-end; }

  .nav-dir {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.2s;
  }

  .nav-project-title {
    font-family: var(--font-display);
    font-size: clamp(16px, 2vw, 22px);
    font-weight: 400;
    font-style: italic;
    color: var(--black);
    transition: color 0.2s;
  }

  .nav-prev:hover .nav-dir,
  .nav-next:hover .nav-dir { color: var(--black); }

  .nav-prev:hover .nav-project-title,
  .nav-next:hover .nav-project-title { color: var(--sienna); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .project-wrapper { padding: 100px 28px 72px; }
    .nav-adjacent { gap: 24px; }
    .nav-project-title { font-size: 16px; }
  }

  @media (max-width: 600px) {
    .project-nav { flex-direction: column; align-items: flex-start; gap: 24px; }
    .nav-adjacent { flex-direction: column; gap: 20px; }
    .nav-next { align-items: flex-start; }
  }
</style>
