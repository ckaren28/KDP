---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Garment Construction Decoder — Karen Dettmar">

  <style>
    *, *::before, *::after { box-sizing: border-box; }

    .tool-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 120px 2rem 8rem;
      font-family: var(--font-display);
      color: var(--black);
    }

    .back-nav {
      padding: 2.5rem 0 4rem;
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .back-nav a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .back-nav a:hover { color: var(--black); }

    .page-header {
      margin-bottom: 4rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--border);
    }

    .page-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
      display: block;
    }

    .page-title {
      font-size: clamp(3rem, 7vw, 5.5rem);
      font-weight: 300;
      line-height: 0.95;
      letter-spacing: -0.02em;
      font-style: italic;
      margin-bottom: 2rem;
    }

    .page-desc {
      font-family: var(--font-body);
      font-size: 0.9rem;
      line-height: 1.75;
      color: var(--text-body);
      max-width: 52ch;
      font-weight: 300;
    }

    /* ── TOOL GRID ── */
    .tool-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    @media (max-width: 900px) {
      .tool-grid { grid-template-columns: 1fr; }
    }

    /* ── PANELS ── */
    .panel {
      border: 1px solid var(--border);
      padding: 2rem;
    }

    .panel-title {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 300;
      font-style: italic;
      margin-bottom: 0.4rem;
      color: var(--black);
    }

    .panel-subtitle {
      font-family: var(--font-body);
      font-size: 0.75rem;
      color: var(--muted);
      margin-bottom: 2rem;
      font-weight: 300;
    }

    /* ── FORM ── */
    .form-field {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      margin-bottom: 1rem;
    }

    .form-field label {
      font-family: var(--font-body);
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .form-field input,
    .form-field textarea,
    .form-field select {
      font-family: var(--font-body);
      font-size: 0.82rem;
      color: var(--black);
      background: transparent;
      border: 1px solid var(--border);
      padding: 8px 12px;
      outline: none;
      transition: border-color 0.2s;
      width: 100%;
    }

    .form-field input:focus,
    .form-field textarea:focus,
    .form-field select:focus {
      border-color: var(--sienna);
    }

    .form-field textarea { min-height: 150px; resize: vertical; }
    .form-hint {
      font-family: var(--font-body);
      font-size: 0.65rem;
      color: var(--muted);
    }

    /* ── TRAVELLER TOGGLE ── */
    .traveller-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1rem;
      border: 1px solid var(--border);
      margin-bottom: 1.25rem;
      cursor: pointer;
      transition: border-color 0.2s;
    }
    .traveller-row:has(input:checked) { border-color: var(--sienna); }

    .traveller-row label {
      font-family: var(--font-body);
      font-size: 0.78rem;
      color: var(--text-body);
      cursor: pointer;
      flex: 1;
    }

    .traveller-row .traveller-badge {
      font-family: var(--font-body);
      font-size: 0.6rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--sienna);
      border: 1px solid var(--sienna);
      padding: 2px 8px;
    }

    /* ── BUTTONS ── */
    .btn-generate {
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--off-white);
      background: var(--black);
      border: 1px solid var(--black);
      padding: 12px 24px;
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
      width: 100%;
      margin-top: 0.5rem;
    }
    .btn-generate:hover:not(:disabled) { background: var(--sienna); border-color: var(--sienna); }
    .btn-generate:disabled { opacity: 0.35; cursor: not-allowed; }

    /* ── PRESETS ── */
    .presets-label {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.6rem;
    }
    .presets-list { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 1.5rem; }
    .preset-btn {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.08em;
      color: var(--muted);
      border: 1px solid var(--border);
      background: transparent;
      padding: 4px 10px;
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s;
    }
    .preset-btn:hover { color: var(--black); border-color: var(--black); }

    /* ── ERROR ── */
    .error-box {
      font-family: var(--font-body);
      font-size: 0.78rem;
      color: #a0291a;
      border: 1px solid #e8c4be;
      background: #fdf5f4;
      padding: 10px 14px;
      margin-top: 0.75rem;
    }

    /* ── OUTPUT STATES ── */
    .output-empty,
    .output-loading {
      font-family: var(--font-body);
      font-size: 0.8rem;
      color: var(--muted);
      padding: 3rem 0;
      text-align: center;
      border: 1px dashed var(--border);
    }

    /* ── OUTPUT SECTIONS ── */
    .output-section {
      padding: 1.25rem 0;
      border-bottom: 1px solid var(--border);
    }
    .output-section:first-child { border-top: 1px solid var(--border); }

    .output-section-title {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.75rem;
      display: block;
    }

    .output-text {
      font-family: var(--font-body);
      font-size: 0.82rem;
      line-height: 1.75;
      color: var(--text-body);
    }

    /* seam / interfacing / closure cards */
    .card-list { display: flex; flex-direction: column; gap: 8px; }
    .card {
      border: 1px solid var(--border);
      padding: 0.875rem 1rem;
    }
    .card-name {
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--black);
      margin-bottom: 0.3rem;
    }
    .card-detail {
      font-family: var(--font-body);
      font-size: 0.78rem;
      line-height: 1.65;
      color: var(--text-body);
    }
    .card-meta {
      font-family: var(--font-body);
      font-size: 0.68rem;
      color: var(--muted);
      margin-top: 0.25rem;
    }

    /* numbered steps */
    .steps-list {
      font-family: var(--font-body);
      font-size: 0.82rem;
      line-height: 1.75;
      color: var(--text-body);
      padding-left: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    /* bullet notes */
    .notes-list {
      font-family: var(--font-body);
      font-size: 0.82rem;
      line-height: 1.75;
      color: var(--text-body);
      padding-left: 1.25rem;
    }

    /* traveller highlight */
    .traveller-output {
      border-left: 2px solid var(--sienna);
      padding-left: 1rem;
    }
    .traveller-output .output-section-title { color: var(--sienna); }

    /* lining badge */
    .lining-row {
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
      margin-bottom: 0.4rem;
    }
    .badge {
      font-family: var(--font-body);
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 2px 8px;
      border: 1px solid;
    }
    .badge-yes { color: #2d6a3f; border-color: #2d6a3f; }
    .badge-no  { color: var(--muted); border-color: var(--border); }

    .next-project {
      margin-top: 8rem;
      padding-top: 3rem;
      border-top: 1px solid var(--border);
    }
    .next-all {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .next-all:hover { color: var(--black); }
  </style>

  <div class="tool-page">

    <nav class="back-nav">
      <a href="/projects/tech">← Creative Technology</a>
    </nav>

    <header class="page-header">
      <span class="page-label">Creative Technology · Tool</span>
      <h1 class="page-title">Garment Construction <em>Decoder</em></h1>
      <p class="page-desc">
        Describe a garment and get a structured technical breakdown, seam types, fabric behavior, lining, interfacing, closure options, and a step-by-step construction order. Built at the intersection of pattern-making knowledge and language models.
      </p>
    </header>

    <div class="tool-grid">

      <!-- INPUT PANEL -->
      <div class="panel">
        <div class="panel-title">Garment details</div>
        <div class="panel-subtitle">Describe what you're making — the more specific, the better.</div>

        <div class="presets-label">Quick examples</div>
        <div class="presets-list">
          <button data-preset="shirtdress" type="button" class="preset-btn">Shirt dress</button>
          <button data-preset="blazer" type="button" class="preset-btn">Structured blazer</button>
          <button data-preset="bias-skirt" type="button" class="preset-btn">Bias-cut skirt</button>
          <button data-preset="trousers" type="button" class="preset-btn">Tailored trousers</button>
        </div>

        <div class="form-field">
          <label for="gd-garment-type">Garment type (optional)</label>
          <input id="gd-garment-type" type="text" placeholder="e.g. dress, jacket, trousers" />
        </div>

        <div class="form-field">
          <label for="gd-fabric">Fabric (optional)</label>
          <input id="gd-fabric" type="text" placeholder="e.g. silk charmeuse, medium-weight wool, linen" />
        </div>

        <div class="form-field">
          <label for="gd-description">Description (required)</label>
          <textarea id="gd-description" placeholder="Describe the garment — silhouette, details, construction complexity, any specific techniques you want to use..."></textarea>
          <span class="form-hint">Minimum: ~20 characters</span>
        </div>

        <div class="traveller-row">
          <input id="gd-traveller" type="checkbox" />
          <label for="gd-traveller">Traveller Mode — optimize for packability &amp; travel</label>
          <span class="traveller-badge">Traveller</span>
        </div>

        <button id="gd-generate" class="btn-generate" disabled type="button">Decode construction</button>

        <div id="gd-error" class="error-box" style="display:none"></div>
      </div>

      <!-- OUTPUT PANEL -->
      <div class="panel">
        <div class="panel-title">Breakdown</div>
        <div class="panel-subtitle">Technical construction analysis.</div>

        <div id="gd-empty" class="output-empty">Describe your garment to see the full technical breakdown here.</div>
        <div id="gd-loading" class="output-loading" style="display:none">Analysing construction…</div>

        <div id="gd-output" style="display:none">

          <!-- Fabric behavior -->
          <div class="output-section">
            <span class="output-section-title">Fabric behavior</span>
            <p id="gd-fabric-behavior" class="output-text"></p>
          </div>

          <!-- Lining -->
          <div class="output-section">
            <span class="output-section-title">Lining</span>
            <div class="lining-row">
              <span id="gd-lining-badge" class="badge"></span>
              <span id="gd-lining-type" class="output-text"></span>
            </div>
            <p id="gd-lining-reason" class="card-meta"></p>
          </div>

          <!-- Seam types -->
          <div class="output-section">
            <span class="output-section-title">Seam types</span>
            <div id="gd-seams" class="card-list"></div>
          </div>

          <!-- Interfacing -->
          <div class="output-section">
            <span class="output-section-title">Interfacing</span>
            <div id="gd-interfacing" class="card-list"></div>
          </div>

          <!-- Closure options -->
          <div class="output-section">
            <span class="output-section-title">Closure options</span>
            <div id="gd-closures" class="card-list"></div>
          </div>

          <!-- Construction order -->
          <div class="output-section">
            <span class="output-section-title">Construction order</span>
            <ol id="gd-order" class="steps-list"></ol>
          </div>

          <!-- Construction notes -->
          <div class="output-section">
            <span class="output-section-title">Construction notes</span>
            <ul id="gd-notes" class="notes-list"></ul>
          </div>

          <!-- Traveller notes -->
          <div id="gd-traveller-section" class="output-section traveller-output" style="display:none;border-bottom:none">
            <span class="output-section-title">Traveller notes</span>
            <ul id="gd-traveller-notes" class="notes-list"></ul>
          </div>

        </div>
      </div>

    </div>

    <div class="next-project">
      <a href="/projects/tech" class="next-all">← Creative Technology</a>
    </div>

  </div>

  <script>
  (() => {
    const $ = (id: string) => document.getElementById(id);

    const descEl      = $("gd-description")   as HTMLTextAreaElement | null;
    const garmentEl   = $("gd-garment-type")  as HTMLInputElement    | null;
    const fabricEl    = $("gd-fabric")        as HTMLInputElement    | null;
    const travellerEl = $("gd-traveller")     as HTMLInputElement    | null;
    const btn         = $("gd-generate")      as HTMLButtonElement   | null;
    const errEl       = $("gd-error");
    const emptyEl     = $("gd-empty");
    const loadingEl   = $("gd-loading");
    const outputEl    = $("gd-output");

    const presets: Record<string, { garmentType: string; fabric: string; description: string }> = {
      shirtdress: {
        garmentType: "Shirt dress",
        fabric: "Cotton poplin",
        description: "A relaxed shirt dress with a collar, button-front placket, patch pockets, and a self-tie belt. Knee length with a slightly oversized fit through the body.",
      },
      blazer: {
        garmentType: "Blazer",
        fabric: "Medium-weight wool suiting",
        description: "A structured single-breasted blazer with notch lapels, two welt pockets, a chest pocket, and a two-button front. Fully lined with a back vent.",
      },
      "bias-skirt": {
        garmentType: "Skirt",
        fabric: "Silk charmeuse",
        description: "A floor-length bias-cut skirt with a side seam invisible zipper and minimal ease. The bias cut allows the fabric to drape and cling to the body.",
      },
      trousers: {
        garmentType: "Trousers",
        fabric: "Lightweight wool crepe",
        description: "Tailored wide-leg trousers with a flat front, side pockets, and a concealed zip fly with a hook-and-bar closure. Mid-rise with a clean, pressed centre crease.",
      },
    };

    document.querySelector(".presets-list")?.addEventListener("click", (e) => {
      const b = (e.target as Element).closest("button[data-preset]");
      if (!b) return;
      const p = presets[b.getAttribute("data-preset") || ""];
      if (!p) return;
      if (garmentEl) garmentEl.value = p.garmentType;
      if (fabricEl)  fabricEl.value  = p.fabric;
      if (descEl)    descEl.value    = p.description;
      validate();
    });

    function validate() {
      if (btn) btn.disabled = (descEl?.value || "").trim().length < 20;
    }
    descEl?.addEventListener("input", validate);
    validate();

    btn?.addEventListener("click", async () => {
      if (errEl)    { errEl.style.display    = "none"; errEl.textContent = ""; }
      if (emptyEl)   emptyEl.style.display   = "none";
      if (outputEl)  outputEl.style.display  = "none";
      if (loadingEl) loadingEl.style.display = "block";

      try {
        const resp = await fetch("/.netlify/functions/garment-decoder", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            description:   descEl?.value,
            garmentType:   garmentEl?.value,
            fabricType:    fabricEl?.value,
            travellerMode: travellerEl?.checked,
          }),
        });

        // eslint-disable-next-line @typescript-eslint/no-explicit-any
        let data: any;
        const rawText = await resp.text();
        try {
          data = JSON.parse(rawText);
        } catch {
          if (resp.status === 404) throw new Error("Function not found (404). Make sure you're running `netlify dev` not `astro dev`.");
          if (resp.status === 502 || resp.status === 504) throw new Error("Request timed out — try a shorter description.");
          throw new Error(`Server error ${resp.status}: ${rawText.slice(0, 120)}`);
        }
        if (!resp.ok) throw new Error(data?.error || "Request failed.");

        // Fabric behavior
        const fbEl = $("gd-fabric-behavior");
        if (fbEl) fbEl.textContent = data.fabric_behavior || "";

        // Lining
        const lining = data.lining || {};
        const badgeEl = $("gd-lining-badge");
        const typeEl  = $("gd-lining-type");
        const reasonEl = $("gd-lining-reason");
        if (badgeEl) {
          badgeEl.textContent = lining.recommended ? "Recommended" : "Not required";
          badgeEl.className = "badge " + (lining.recommended ? "badge-yes" : "badge-no");
        }
        if (typeEl)   typeEl.textContent   = lining.type   || "";
        if (reasonEl) reasonEl.textContent = lining.reason || "";

        // Seams
        const seamsEl = $("gd-seams");
        if (seamsEl) {
          seamsEl.innerHTML = "";
          (data.seam_types || []).forEach((s: { name: string; description: string; where_used: string }) => {
            const div = document.createElement("div");
            div.className = "card";
            div.innerHTML = `<div class="card-name">${s.name}</div>
              <div class="card-detail">${s.description}</div>
              <div class="card-meta">${s.where_used}</div>`;
            seamsEl.appendChild(div);
          });
        }

        // Interfacing
        const interfEl = $("gd-interfacing");
        if (interfEl) {
          interfEl.innerHTML = "";
          (data.interfacing || []).forEach((i: { location: string; weight: string; type: string; reason: string }) => {
            const div = document.createElement("div");
            div.className = "card";
            div.innerHTML = `<div class="card-name">${i.location}</div>
              <div class="card-detail">${i.weight} — ${i.type}</div>
              <div class="card-meta">${i.reason}</div>`;
            interfEl.appendChild(div);
          });
        }

        // Closures
        const closuresEl = $("gd-closures");
        if (closuresEl) {
          closuresEl.innerHTML = "";
          (data.closure_options || []).forEach((c: { type: string; pros: string; cons: string; best_for: string }) => {
            const div = document.createElement("div");
            div.className = "card";
            div.innerHTML = `<div class="card-name">${c.type}</div>
              <div class="card-detail">↑ ${c.pros}</div>
              <div class="card-detail">↓ ${c.cons}</div>
              <div class="card-meta">Best for: ${c.best_for}</div>`;
            closuresEl.appendChild(div);
          });
        }

        // Construction order
        const orderEl = $("gd-order");
        if (orderEl) {
          orderEl.innerHTML = "";
          (data.construction_order || []).forEach((step: string) => {
            const li = document.createElement("li");
            li.textContent = step;
            orderEl.appendChild(li);
          });
        }

        // Construction notes
        const notesEl = $("gd-notes");
        if (notesEl) {
          notesEl.innerHTML = "";
          (data.construction_notes || []).forEach((n: string) => {
            const li = document.createElement("li");
            li.textContent = n;
            notesEl.appendChild(li);
          });
        }

        // Traveller notes
        const travellerSection = $("gd-traveller-section");
        const travellerNotesEl = $("gd-traveller-notes");
        const tNotes = data.traveller_notes || [];
        if (travellerSection) {
          travellerSection.style.display = tNotes.length > 0 ? "block" : "none";
        }
        if (travellerNotesEl) {
          travellerNotesEl.innerHTML = "";
          tNotes.forEach((n: string) => {
            const li = document.createElement("li");
            li.textContent = n;
            travellerNotesEl.appendChild(li);
          });
        }

        if (loadingEl) loadingEl.style.display = "none";
        if (outputEl)  outputEl.style.display  = "block";

      } catch (e) {
        if (loadingEl) loadingEl.style.display = "none";
        if (emptyEl)   emptyEl.style.display   = "block";
        if (errEl) {
          errEl.textContent = (e as Error)?.message || "Something went wrong.";
          errEl.style.display = "block";
        }
      }
    });
  })();
  </script>

</MainLayout>
