---
import MainLayout from '../../layouts/MainLayout.astro';

const textile = [
  {
    href: '/projects/shibori',
    image: '/images/shibori/Shibori1.jpg',
    alt: 'Shibori indigo resist-dyed fabric',
    label: 'Dyeing · Resist',
    title: 'Shibori',
    desc: 'Indigo shibori resist dyeing on cotton. Itajime, arashi, and kumo techniques explored across a series of scarves.',
  },
  {
    href: '/projects/marbling',
    image: '/images/marbling/marblingfinal1.png',
    alt: 'Marbled fabric with violet, gold, and orange swirls',
    label: 'Dyeing · Surface',
    title: 'Marbling',
    desc: 'Marbling exploring color, fluid pattern, and surface tension.',
  },
  {
    href: '/projects/batik',
    image: '/images/batik/Batik-final1.jpg',
    alt: 'Batik wax-resist dyed fabric',
    label: 'Dyeing · Resist',
    title: 'Batik',
    desc: 'Wax resist batik on fabric, exploring color layering and pattern.',
  },
  {
    href: '/projects/blockprint',
    image: '/images/blockprint/blockprint.jpg',
    alt: 'Block printed fabric — linoleum carved pattern',
    label: 'Printing · Relief',
    title: 'Block Printing',
    desc: 'Hand-carved relief blocks and repeat pattern development on muslin.',
  },
  {
    href: '/projects/felting',
    image: '/images/felting/felted-art1.JPG',
    alt: 'Felted textile',
    label: 'Fiber · Construction',
    title: 'Felting',
    desc: 'Felting exploration in texture and form.',
  },
  {
    href: '/projects/weaving',
    image: '/images/weaving/weaving.JPG',
    alt: 'Woven sample with reclaimed yarn',
    label: 'Fiber · Structure',
    title: 'Weaving',
    desc: 'Hand-woven textile exploring warp and weft structure. Materials sourced from a local weaving studio in the Upper East Side.',
  },
];

const knitting = [
  {
    image: '/images/knitting/dress.jpg',
    alt: 'Hand-knitted silk maxi dress in dove blue',
    label: 'Hand Knitting · Self-taught',
    title: 'Knit Dress',
    desc: 'Hand-knitted button-front maxi dress in dove blue 100% silk yarn. Buttons are vintage French mother of pearl from the 1940s.',
    caption: 'Hand-knitted from purchased patterns. Yarn and hardware selection by me. Part of an ongoing personal making practice.',
  },
  {
    image: '/images/knitting/vest.jpg',
    alt: 'Hand-knitted cropped cashmere vest',
    label: 'Hand Knitting · Self-taught',
    title: 'Knit Vest',
    desc: 'Hand-knitted cropped vest with button closure. Cashmere wool blend yarn. Buttons are vintage Italian navy mother of pearl from the 1990s.',
    caption: 'Hand-knitted from purchased patterns. Yarn and hardware selection by me. Part of an ongoing personal making practice.',
  },
];
---

<MainLayout title="Textile Practice — Karen Dettmar">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .project-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 120px 2rem 8rem;
      font-family: var(--font-display);
      color: var(--black);
    }

    .back-nav {
      padding: 2.5rem 0 4rem;
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .back-nav a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .back-nav a:hover { color: var(--black); }

    .page-header {
      margin-bottom: 5rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--border);
    }

    .page-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
      display: block;
    }

    .page-title {
      font-size: clamp(3rem, 7vw, 5.5rem);
      font-weight: 300;
      line-height: 0.95;
      letter-spacing: -0.02em;
      font-style: italic;
      margin-bottom: 2rem;
    }

    .page-desc {
      font-family: var(--font-body);
      font-size: 0.9rem;
      line-height: 1.75;
      color: var(--text-body);
      max-width: 52ch;
      font-weight: 300;
    }

    /* ── SECTION DIVIDER ── */
    .section-heading {
      font-family: var(--font-body);
      font-size: 0.6rem;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--muted);
      opacity: 0.7;
      display: block;
      padding-top: 4rem;
      padding-bottom: 2.5rem;
    }

    /* ── 3-COLUMN GRID ── */
    .project-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem 1.5rem;
      margin-bottom: 6rem;
    }

    .project-item {
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
    }

    .item-hero {
      width: 100%;
      height: 260px;
      overflow: hidden;
      display: block;
      margin-bottom: 1rem;
    }

    .item-hero img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.3s ease;
    }
    .project-item:hover .item-hero img { transform: scale(1.03); }

    .item-tag {
      font-family: var(--font-body);
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--sienna);
      margin-bottom: 0.4rem;
      display: block;
    }

    .item-title {
      font-family: var(--font-display);
      font-size: clamp(1.4rem, 2vw, 1.9rem);
      font-weight: 300;
      font-style: italic;
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--black);
      margin-bottom: 0.5rem;
      transition: color 0.2s;
    }
    .project-item:hover .item-title { color: var(--sienna); }

    .item-desc {
      font-family: var(--font-body);
      font-size: 0.78rem;
      line-height: 1.65;
      color: var(--text-body);
      font-weight: 300;
      margin-bottom: 0.75rem;
      flex-grow: 1;
    }

    .item-link {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
      padding-bottom: 2px;
      display: inline-block;
      align-self: flex-start;
      transition: color 0.2s, border-color 0.2s;
    }
    .project-item:hover .item-link { color: var(--sienna); border-color: var(--sienna); }

    @media (max-width: 768px) {
      .project-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 480px) {
      .project-grid { grid-template-columns: 1fr; }
    }

    .section-divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 0 0 0;
    }

    /* ── KNIT SLIDER ── */
    .knit-slider {
      position: relative;
      max-width: 300px;
      margin: 0 auto 1.5rem;
    }

    .knit-track { overflow: hidden; }

    .knit-slides {
      display: flex;
      transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .knit-item {
      flex: 0 0 100%;
      display: flex;
      flex-direction: column;
    }

    .knit-hero {
      width: 100%;
      height: 380px;
      overflow: hidden;
      background: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      cursor: zoom-in;
    }

    .knit-hero img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
      transition: opacity 0.2s;
    }
    .knit-hero:hover img { opacity: 0.85; }

    .knit-tag {
      font-family: var(--font-body);
      font-size: 0.58rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--sienna);
      margin-bottom: 0.5rem;
      display: block;
    }

    .knit-title {
      font-family: var(--font-display);
      font-size: clamp(1.1rem, 2vw, 1.4rem);
      font-weight: 300;
      font-style: italic;
      line-height: 1;
      letter-spacing: -0.02em;
      color: var(--black);
      margin-bottom: 0.5rem;
    }

    .knit-desc {
      font-family: var(--font-body);
      font-size: 0.72rem;
      line-height: 1.7;
      color: var(--text-body);
      font-weight: 300;
      max-width: 56ch;
      margin-bottom: 0.5rem;
    }

    .knit-caption {
      font-family: var(--font-body);
      font-size: 0.68rem;
      line-height: 1.65;
      color: var(--muted);
      font-weight: 300;
      max-width: 56ch;
    }

    .knit-nav {
      display: flex;
      align-items: center;
      gap: 12px;
      padding-top: 12px;
    }

    .knit-btn {
      background: none;
      border: none;
      font-family: var(--font-body);
      font-size: 0.6rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      cursor: pointer;
      padding: 0;
      transition: color 0.2s;
    }
    .knit-btn:hover { color: var(--black); }
    .knit-btn:disabled { opacity: 0.25; cursor: default; }

    .knit-dots { display: flex; gap: 5px; }

    .knit-dot {
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: var(--border);
      border: none;
      padding: 0;
      cursor: pointer;
      transition: background 0.2s;
    }
    .knit-dot.active { background: var(--black); }

    /* ── KNIT LIGHTBOX ── */
    .knit-lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(24,16,10,0.96);
      z-index: 500;
      align-items: center;
      justify-content: center;
      padding: 32px;
      cursor: zoom-out;
    }
    .knit-lightbox.open { display: flex; }
    .knit-lightbox img {
      max-width: 100%;
      max-height: 92vh;
      object-fit: contain;
      display: block;
      cursor: default;
      background: #fff;
    }
    .knit-lightbox-close {
      position: absolute;
      top: 24px; right: 32px;
      background: none; border: none;
      color: rgba(237,229,208,0.5);
      font-size: 11px; letter-spacing: 0.16em;
      text-transform: uppercase;
      cursor: pointer;
      font-family: var(--font-body);
      transition: color 0.2s;
    }
    .knit-lightbox-close:hover { color: rgba(237,229,208,1); }

    /* ── HAND KNITTING SECTION WRAPPER ── */
    .knit-section {
      position: relative;
      overflow: visible;
    }
    .yarn-decor {
      position: absolute;
      pointer-events: none;
      user-select: none;
      z-index: 0;
    }
    .yarn-topright {
      top: 0;
      right: -50px;
      bottom: 0;
      width: 400px;
      height: 116%;
    }
    .yarn-bottomleft {
      bottom: -7em;
      left: 15%;
      width: 160px;
    }
    /* Ensure slider content sits above the yarn decorations */
    #knitSlider {
      position: relative;
      z-index: 1;
    }
    @media (max-width: 768px) {
      .yarn-decor { display: none; }
    }

    /* ── PROJECT NAV ── */
    .project-nav {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-top: 4rem;
      margin-bottom: 2rem;
    }
    .project-nav-link {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .project-nav-link:hover { color: var(--black); }

    /* ── FOOTER NAV ── */
    .next-project {
      margin-top: 0;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }
    .next-all {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .next-all:hover { color: var(--black); }

    @media (max-width: 768px) {
      .knit-hero { height: 360px; }
      .knit-slider { max-width: 100%; }
    }
  </style>

  <div class="project-page">

    <nav class="back-nav">
      <a href="/projects/fashion">← Fashion</a>
    </nav>

    <header class="page-header">
      <span class="page-label">Textile Practice</span>
      <h1 class="page-title">Textile Practice</h1>
      <p class="page-desc">
        A record of making. Across dyeing, printing, weaving, and resist techniques, these pieces explore what happens when process drives design. Where the technique itself determines the pattern, the color, and the form.
      </p>
    </header>

    <!-- ── TEXTILE TECHNIQUES ── -->
    <span class="section-heading">Dyeing, Printing &amp; Fiber</span>
    <div class="project-grid">
      {textile.map(e => (
        <a href={e.href} class="project-item reveal">
          <div class="item-hero">
            <img src={e.image} alt={e.alt} loading="lazy" />
          </div>
          <span class="item-tag">{e.label}</span>
          <h2 class="item-title">{e.title}</h2>
          <p class="item-desc">{e.desc}</p>
          <span class="item-link">View project →</span>
        </a>
      ))}
    </div>

    <hr class="section-divider" />

    <!-- ── HAND KNITTING ── -->
    <div class="knit-section">
      <img src="/images/knitting/yarn-top.png" alt="" class="yarn-decor yarn-topright" aria-hidden="true" />
      <img src="/images/knitting/yarn-bottom.png" alt="" class="yarn-decor yarn-bottomleft" aria-hidden="true" />
      <span class="section-heading">Hand Knitting</span>
      <div class="knit-slider" id="knitSlider">
      <div class="knit-track">
        <div class="knit-slides" id="knitSlides">
          {knitting.map(k => (
            <div class="knit-item">
              <div class="knit-hero knit-lightbox-trigger" data-src={k.image} data-alt={k.alt}>
                <img src={k.image} alt={k.alt} loading="lazy" />
              </div>
              <span class="knit-tag">{k.label}</span>
              <h2 class="knit-title">{k.title}</h2>
              <p class="knit-desc">{k.desc}</p>
              <p class="knit-caption">{k.caption}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="knit-nav">
        <button class="knit-btn" id="knitPrev">← Prev</button>
        <div class="knit-dots" id="knitDots"></div>
        <button class="knit-btn" id="knitNext">Next →</button>
      </div>
    </div>
    </div>{/* end .knit-section */}

    <div class="project-nav">
      <a href="/projects/technical-flats" class="project-nav-link">← Technical Flats</a>
      <span></span>
    </div>
    <div class="next-project">
      <a href="/projects/fashion" class="next-all">← All Fashion</a>
    </div>

  </div>

  <div class="knit-lightbox" id="knitLightbox">
    <button class="knit-lightbox-close" id="knitLightboxClose">Close ×</button>
    <img id="knitLightboxImg" src="" alt="" />
  </div>

  <script>
    const slides = document.getElementById('knitSlides');
    const prevBtn = document.getElementById('knitPrev') as HTMLButtonElement;
    const nextBtn = document.getElementById('knitNext') as HTMLButtonElement;
    const dotsContainer = document.getElementById('knitDots');
    const total = slides ? slides.children.length : 0;
    let current = 0;

    const dots: HTMLButtonElement[] = [];
    for (let i = 0; i < total; i++) {
      const d = document.createElement('button');
      d.className = 'knit-dot' + (i === 0 ? ' active' : '');
      d.addEventListener('click', () => goTo(i));
      dotsContainer?.appendChild(d);
      dots.push(d);
    }

    function goTo(index: number) {
      current = index;
      if (slides) slides.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
      if (prevBtn) prevBtn.disabled = current === 0;
      if (nextBtn) nextBtn.disabled = current === total - 1;
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    goTo(0);

    // Lightbox
    const knitLightbox = document.getElementById('knitLightbox');
    const knitLightboxImg = document.getElementById('knitLightboxImg') as HTMLImageElement | null;

    document.querySelectorAll('.knit-lightbox-trigger').forEach(el => {
      el.addEventListener('click', () => {
        if (!knitLightbox || !knitLightboxImg) return;
        knitLightboxImg.src = (el as HTMLElement).dataset.src || '';
        knitLightboxImg.alt = (el as HTMLElement).dataset.alt || '';
        knitLightbox.classList.add('open');
      });
    });

    function closeKnitLightbox() { knitLightbox?.classList.remove('open'); }
    document.getElementById('knitLightboxClose')?.addEventListener('click', closeKnitLightbox);
    knitLightbox?.addEventListener('click', (e) => { if (e.target === knitLightbox) closeKnitLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeKnitLightbox(); });
  </script>

</MainLayout>
