---
import MainLayout from '../../layouts/MainLayout.astro';

---

<MainLayout title="Garment Construction — Karen Dettmar">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .project-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 120px 2rem 8rem;
      font-family: var(--font-display);
      color: var(--black);
    }

    .back-nav {
      padding: 2.5rem 0 4rem;
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .back-nav a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .back-nav a:hover { color: var(--black); }

    .page-header {
      margin-bottom: 5rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--border);
    }

    .page-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
      display: block;
    }

    .page-title {
      font-size: clamp(3rem, 7vw, 5.5rem);
      font-weight: 300;
      line-height: 0.95;
      letter-spacing: -0.02em;
      font-style: italic;
      margin-bottom: 2rem;
    }

    .page-desc {
      font-family: var(--font-body);
      font-size: 0.9rem;
      line-height: 1.75;
      color: var(--text-body);
      max-width: 52ch;
      font-weight: 300;
    }

    /* ── IMAGE GRID ── */
    .image-grid {
      columns: 2;
      column-gap: 2px;
    }

    .image-item {
      break-inside: avoid;
      margin-bottom: 2px;
      position: relative;
      cursor: zoom-in;
    }

    .image-item img {
      width: 100%;
      display: block;
      object-fit: cover;
      transition: opacity 0.2s ease;
    }
    .image-item:hover img { opacity: 0.88; }

    .image-caption {
      font-family: var(--font-body);
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      color: var(--muted);
      text-transform: uppercase;
      padding: 10px 0 0;
    }

    /* ── EMPTY STATE ── */
    .empty-state {
      padding: 6rem 0;
      text-align: center;
      border: 1px dashed var(--border);
    }

    .empty-state p {
      font-family: var(--font-body);
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      line-height: 1.8;
    }

    /* ── LIGHTBOX ── */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(24,16,10,0.96);
      z-index: 500;
      align-items: center;
      justify-content: center;
      padding: 32px;
      cursor: zoom-out;
    }
    .lightbox.open { display: flex; }
    .lightbox img {
      max-width: 100%;
      max-height: 92vh;
      object-fit: contain;
      display: block;
      cursor: default;
    }
    .lightbox-close {
      position: absolute;
      top: 24px; right: 32px;
      background: none; border: none;
      color: rgba(237,229,208,0.5);
      font-size: 11px; letter-spacing: 0.16em;
      text-transform: uppercase;
      cursor: pointer;
      font-family: var(--font-body);
      transition: color 0.2s;
    }
    .lightbox-close:hover { color: rgba(237,229,208,1); }

    .next-project {
      margin-top: 8rem;
      padding-top: 3rem;
      border-top: 1px solid var(--border);
    }
    .next-all {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .next-all:hover { color: var(--black); }

    /* ── PROJECT ENTRIES ── */
    .project-entries {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .project-entry {
      display: grid;
      grid-template-columns: 1fr 1fr;
      text-decoration: none;
      color: inherit;
      border: 1px solid var(--border);
      overflow: hidden;
      transition: border-color 0.3s;
    }
    .project-entry:hover { border-color: var(--sienna-light); }

    .entry-image {
      aspect-ratio: 3/4;
      position: relative;
      overflow: hidden;
      background: #2E2318;
    }

    .entry-image img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      opacity: 0.9;
      transition: opacity 0.4s ease;
      display: block;
    }
    .project-entry:hover .entry-image img { opacity: 1; }

    /* hide broken image — fallback shows the dark swatch */
    .entry-image img[src=""][alt],
    .entry-image-fallback {
      position: absolute;
      inset: 0;
      display: none;
    }

    .entry-body {
      padding: 3rem 2.5rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .entry-label {
      font-family: var(--font-body);
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.25rem;
      display: block;
    }

    .entry-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 3.5vw, 3.2rem);
      font-weight: 300;
      font-style: italic;
      line-height: 1;
      letter-spacing: -0.02em;
      color: var(--black);
      margin-bottom: 1.25rem;
    }

    .entry-desc {
      font-family: var(--font-body);
      font-size: 0.82rem;
      line-height: 1.75;
      color: var(--text-body);
      font-weight: 300;
      max-width: 36ch;
      margin-bottom: 2rem;
    }

    .entry-link {
      font-family: var(--font-body);
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
      padding-bottom: 2px;
      align-self: flex-start;
      transition: color 0.2s, border-color 0.2s;
    }
    .project-entry:hover .entry-link { color: var(--sienna); border-color: var(--sienna); }

    @media (max-width: 768px) {
      .image-grid { columns: 1; }
      .project-entry { grid-template-columns: 1fr; }
      .entry-image { aspect-ratio: 4/3; }
      .entry-body { padding: 2rem 1.5rem; }
    }
  </style>

  <div class="project-page">

    <nav class="back-nav">
      <a href="/projects">← All Projects</a>
    </nav>

    <header class="page-header">
      <span class="page-label">Parsons School of Design · FIT</span>
      <h1 class="page-title">Garment Construction</h1>
      <p class="page-desc">
        Pattern drafting, draping, and construction process work alongside technical flats and CAD drawings. Documentation of the making. Rrom the first toile to finished spec.
      </p>
    </header>

    <!-- ── PROJECT ENTRIES ── -->
    <div class="project-entries">

      <a href="/projects/constructions-2" class="project-entry reveal">
        <div class="entry-image">
          <img src="/images/constructions-2/lucky-dress1.JPG" alt="Clover dress" />
          <div class="entry-image-fallback"></div>
        </div>
        <div class="entry-body">
          <span class="entry-label">Parsons · Constructions 2 · Final</span>
          <h2 class="entry-title">Clover Dress</h2>
          <p class="entry-desc">A draped and constructed tea-length dress in a green organza. Princess seams, French seam finished, with four oversized clover-inspired pockets.</p>
          <span class="entry-link">View project →</span>
        </div>
      </a>

      <a href="/projects/lined-blazer" class="project-entry reveal">
        <div class="entry-image">
          <img src="/images/lined-blazer/blazer-front.jpg" alt="Fully lined blazer" />
          <div class="entry-image-fallback"></div>
        </div>
        <div class="entry-body">
          <span class="entry-label">FIT · Sewing 3</span>
          <h2 class="entry-title">Fully Lined Blazer</h2>
          <p class="entry-desc">A fully lined blazer with welt pockets, darts, sleeve heads, and shoulder pads. Fabric sourced from Fabscrap. 3/4-length sleeves.</p>
          <span class="entry-link">View project →</span>
        </div>
      </a>

      <a href="/projects/canvas-jacket" class="project-entry reveal">
        <div class="entry-image">
          <img src="/images/canvas-jacket/jacket-front.jpg" alt="Canvas zip-up jacket" />
          <div class="entry-image-fallback"></div>
        </div>
        <div class="entry-body">
          <span class="entry-label">FIT · Sewing Construction</span>
          <h2 class="entry-title">Canvas Zip Jacket</h2>
          <p class="entry-desc">A zip-up jacket in lightweight natural cotton canvas. Off-white with two large circular patch pockets.</p>
          <span class="entry-link">View project →</span>
        </div>
      </a>

      <a href="/projects/technical-flats" class="project-entry reveal">
        <div class="entry-image">
          <img src="/images/technical-flats/flat-01.png" alt="Technical flats" />
          <div class="entry-image-fallback"></div>
        </div>
        <div class="entry-body">
          <span class="entry-label">Parsons · Flats CAD</span>
          <h2 class="entry-title">Technical Flats</h2>
          <p class="entry-desc">Garment technical flats from the Flats CAD course at Parsons. The language between designer and production.</p>
          <span class="entry-link">View project →</span>
        </div>
      </a>

    </div>

    <div class="next-project">
      <a href="/projects" class="next-all">← All Projects</a>
    </div>

  </div>

  <!-- LIGHTBOX -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightboxClose">Close ×</button>
    <img id="lightboxImg" src="" alt="" />
  </div>

  <script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement | null;

    document.querySelectorAll('.lightbox-trigger').forEach(el => {
      el.addEventListener('click', () => {
        if (!lightbox || !lightboxImg) return;
        lightboxImg.src = (el as HTMLElement).dataset.src || '';
        lightboxImg.alt = (el as HTMLElement).dataset.alt || '';
        lightbox.classList.add('open');
      });
    });

    function closeLightbox() { lightbox?.classList.remove('open'); }
    document.getElementById('lightboxClose')?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
  </script>

</MainLayout>
