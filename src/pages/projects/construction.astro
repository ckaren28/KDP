---
import MainLayout from '../../layouts/MainLayout.astro';

// Add your images here as you upload them
// Each entry: { src: '/images/construction/filename.jpg', alt: 'description', caption: 'optional caption' }
const images: { src: string; alt: string; caption?: string }[] = [
  // { src: '/images/construction/flat-01.jpg', alt: 'Technical flat — bodice', caption: 'Bodice — front & back' },
];
---

<MainLayout title="Garment Construction — Karen Dettmar">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .project-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 120px 2rem 8rem;
      font-family: var(--font-display);
      color: var(--black);
    }

    .back-nav {
      padding: 2.5rem 0 4rem;
      font-family: var(--font-body);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .back-nav a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .back-nav a:hover { color: var(--black); }

    .page-header {
      margin-bottom: 5rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--border);
    }

    .page-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
      display: block;
    }

    .page-title {
      font-size: clamp(3rem, 7vw, 5.5rem);
      font-weight: 300;
      line-height: 0.95;
      letter-spacing: -0.02em;
      font-style: italic;
      margin-bottom: 2rem;
    }

    .page-desc {
      font-family: var(--font-body);
      font-size: 0.9rem;
      line-height: 1.75;
      color: var(--text-body);
      max-width: 52ch;
      font-weight: 300;
    }

    /* ── IMAGE GRID ── */
    .image-grid {
      columns: 2;
      column-gap: 2px;
    }

    .image-item {
      break-inside: avoid;
      margin-bottom: 2px;
      position: relative;
      cursor: zoom-in;
    }

    .image-item img {
      width: 100%;
      display: block;
      object-fit: cover;
      transition: opacity 0.2s ease;
    }
    .image-item:hover img { opacity: 0.88; }

    .image-caption {
      font-family: var(--font-body);
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      color: var(--muted);
      text-transform: uppercase;
      padding: 10px 0 0;
    }

    /* ── EMPTY STATE ── */
    .empty-state {
      padding: 6rem 0;
      text-align: center;
      border: 1px dashed var(--border);
    }

    .empty-state p {
      font-family: var(--font-body);
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      line-height: 1.8;
    }

    /* ── LIGHTBOX ── */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(24,16,10,0.96);
      z-index: 500;
      align-items: center;
      justify-content: center;
      padding: 32px;
      cursor: zoom-out;
    }
    .lightbox.open { display: flex; }
    .lightbox img {
      max-width: 100%;
      max-height: 92vh;
      object-fit: contain;
      display: block;
      cursor: default;
    }
    .lightbox-close {
      position: absolute;
      top: 24px; right: 32px;
      background: none; border: none;
      color: rgba(237,229,208,0.5);
      font-size: 11px; letter-spacing: 0.16em;
      text-transform: uppercase;
      cursor: pointer;
      font-family: var(--font-body);
      transition: color 0.2s;
    }
    .lightbox-close:hover { color: rgba(237,229,208,1); }

    .next-project {
      margin-top: 8rem;
      padding-top: 3rem;
      border-top: 1px solid var(--border);
    }
    .next-all {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .next-all:hover { color: var(--black); }

    @media (max-width: 768px) {
      .image-grid { columns: 1; }
    }
  </style>

  <div class="project-page">

    <nav class="back-nav">
      <a href="/projects">← All Projects</a>
    </nav>

    <header class="page-header">
      <span class="page-label">Parsons School of Design · FIT</span>
      <h1 class="page-title">Garment Construction</h1>
      <p class="page-desc">
        Pattern drafting, draping, and construction process work alongside technical flats and CAD drawings. Documentation of the making — from first toile to finished spec.
      </p>
    </header>

    {images.length > 0 ? (
      <div class="image-grid">
        {images.map((img) => (
          <div class="image-item lightbox-trigger" data-src={img.src} data-alt={img.alt}>
            <img src={img.src} alt={img.alt} />
            {img.caption && <p class="image-caption">{img.caption}</p>}
          </div>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p>Images coming soon.<br />Add entries to the <code>images</code> array in this file.</p>
      </div>
    )}

    <div class="next-project">
      <a href="/projects" class="next-all">← All Projects</a>
    </div>

  </div>

  <!-- LIGHTBOX -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightboxClose">Close ×</button>
    <img id="lightboxImg" src="" alt="" />
  </div>

  <script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement | null;

    document.querySelectorAll('.lightbox-trigger').forEach(el => {
      el.addEventListener('click', () => {
        if (!lightbox || !lightboxImg) return;
        lightboxImg.src = (el as HTMLElement).dataset.src || '';
        lightboxImg.alt = (el as HTMLElement).dataset.alt || '';
        lightbox.classList.add('open');
      });
    });

    function closeLightbox() { lightbox?.classList.remove('open'); }
    document.getElementById('lightboxClose')?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
  </script>

</MainLayout>
