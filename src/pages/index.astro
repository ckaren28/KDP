---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Karen Dettmar — Creative Technologist</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Archivo:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    /* ── RESET & BASE ── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --black: #0E0D0B;
      --off-white: #F4F0E8;
      --warm-white: #FAF8F4;
      --sienna: #A0522D;
      --sienna-light: #C4734A;
      --muted: #8A8478;
      --border: rgba(14,13,11,0.12);
      --font-display: 'Playfair Display', serif;
      --font-body: 'Archivo', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--off-white);
      color: var(--black);
      font-family: var(--font-body);
      font-weight: 300;
      cursor: none;
      overflow-x: hidden;
    }

    /* ── CUSTOM CURSOR ── */
    .cursor {
      position: fixed;
      top: 0; left: 0;
      width: 10px; height: 10px;
      background: var(--black);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      transform: translate(-50%, -50%);
      transition: transform 0.1s ease, width 0.3s ease, height 0.3s ease, background 0.3s ease;
      mix-blend-mode: multiply;
    }

    .cursor-ring {
      position: fixed;
      top: 0; left: 0;
      width: 36px; height: 36px;
      border: 1px solid var(--black);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9998;
      transform: translate(-50%, -50%);
      transition: transform 0.18s ease, width 0.3s ease, height 0.3s ease, opacity 0.3s ease;
      opacity: 0.4;
    }

    body:has(a:hover) .cursor,
    body:has(button:hover) .cursor { width: 16px; height: 16px; background: var(--sienna); }
    body:has(a:hover) .cursor-ring,
    body:has(button:hover) .cursor-ring { width: 52px; height: 52px; opacity: 0.2; }

    /* ── GRAIN OVERLAY ── */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      opacity: 0.028;
      pointer-events: none;
      z-index: 9997;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 28px 48px;
      mix-blend-mode: multiply;
    }

    .nav-logo {
      font-family: var(--font-body);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: none;
      opacity: 0;
      animation: fadeIn 0.6s ease 1.8s forwards;
    }

    .nav-links {
      display: flex;
      gap: 36px;
      list-style: none;
      opacity: 0;
      animation: fadeIn 0.6s ease 1.8s forwards;
    }

    .nav-links a {
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: none;
      position: relative;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -2px; left: 0;
      width: 0; height: 1px;
      background: var(--sienna);
      transition: width 0.3s ease;
    }
    .nav-links a:hover::after { width: 100%; }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 48px 64px;
      position: relative;
      overflow: hidden;
    }

    /* Editorial metadata bar above the name */
    .hero-masthead {
      display: flex;
      align-items: center;
      gap: 0;
      padding: 14px 0;
      border-top: 1px solid var(--border);
      margin-bottom: 40px;
      opacity: 0;
      animation: fadeIn 0.6s ease 0.1s forwards;
    }

    .hero-masthead-item {
      font-family: var(--font-body);
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .hero-masthead-divider {
      width: 1px;
      height: 10px;
      background: var(--border);
      margin: 0 20px;
      flex-shrink: 0;
    }

    .hero-masthead-accent {
      color: var(--sienna);
    }

    .hero-masthead-spacer {
      flex: 1;
    }

    .hero-name {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(72px, 13vw, 182px);
      line-height: 0.9;
      letter-spacing: -0.02em;
      color: var(--black);
      overflow: hidden;
      margin-bottom: 0;
    }

    .hero-name .line {
      display: block;
      overflow: hidden;
    }

    .hero-name .word {
      display: inline-block;
      transform: translateY(110%);
      opacity: 0;
    }

    .hero-name .word.first { animation: slideUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.2s forwards; }
    .hero-name .word.second {
      animation: slideUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.45s forwards;
      color: var(--sienna);
    }

    .hero-tagline {
      margin-top: 36px;
      padding-top: 20px;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 32px;
    }

    .hero-tagline .tag-text {
      font-family: var(--font-display);
      font-size: clamp(15px, 1.8vw, 22px);
      font-style: italic;
      font-weight: 400;
      color: var(--muted);
      opacity: 0;
      animation: fadeIn 0.7s ease 0.9s forwards;
      white-space: nowrap;
    }

    .hero-tagline .tag-line {
      flex: 1;
      height: 1px;
      background: var(--border);
      transform: scaleX(0);
      transform-origin: left;
      animation: scaleIn 0.8s cubic-bezier(0.16,1,0.3,1) 1.2s forwards;
    }

    .hero-tagline .tag-cta {
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: none;
      opacity: 0;
      animation: fadeIn 0.6s ease 1.4s forwards;
      display: flex;
      align-items: center;
      gap: 8px;
      white-space: nowrap;
    }

    .tag-cta .arrow {
      display: inline-block;
      transition: transform 0.3s ease;
    }
    .tag-cta:hover .arrow { transform: translateX(4px); }

    /* ── MARQUEE ── */
    .marquee-wrapper {
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 14px 0;
      overflow: hidden;
      opacity: 0;
      animation: fadeIn 0.6s ease 1.6s forwards;
    }

    .marquee-track {
      display: flex;
      gap: 0;
      animation: marquee 26s linear infinite;
      width: max-content;
    }

    .marquee-item {
      display: flex;
      align-items: center;
      gap: 28px;
      padding-right: 28px;
      white-space: nowrap;
    }

    .marquee-text {
      font-family: var(--font-body);
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .marquee-dot {
      width: 3px; height: 3px;
      border-radius: 50%;
      background: var(--sienna);
      flex-shrink: 0;
    }

    /* ── SECTION STRUCTURE ── */
    section { padding: 100px 48px; }

    .section-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 56px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border);
    }

    .section-eyebrow {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--muted);
      display: block;
      margin-bottom: 10px;
    }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(32px, 4.5vw, 58px);
      font-weight: 400;
      line-height: 1;
      letter-spacing: -0.01em;
    }

    .section-title em {
      font-style: italic;
      color: var(--sienna);
    }

    .section-link {
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
      align-self: flex-end;
      padding-bottom: 4px;
      border-bottom: 1px solid transparent;
      transition: border-color 0.3s ease;
    }
    .section-link:hover { border-bottom-color: var(--sienna); }
    .section-link .arrow { transition: transform 0.3s ease; }
    .section-link:hover .arrow { transform: translateX(4px); }

    /* ── WORK GRID — 3 items ── */
    .work-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 16px;
    }

    .work-item {
      position: relative;
      overflow: hidden;
      background: var(--black);
      cursor: none;
    }

    /* 3-item editorial grid: feature + sidebar on row 1, full-width on row 2 */
    .work-item:nth-child(1) { grid-column: span 7; }
    .work-item:nth-child(2) { grid-column: span 5; }
    .work-item:nth-child(3) { grid-column: span 12; }

    .work-item-inner {
      aspect-ratio: 4/3;
      position: relative;
      overflow: hidden;
    }

    .work-item:nth-child(1) .work-item-inner { aspect-ratio: 16/11; }
    .work-item:nth-child(3) .work-item-inner { aspect-ratio: 21/8; }

    .work-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--black);
      transition: transform 0.7s cubic-bezier(0.16,1,0.3,1);
    }

    .work-item:hover .work-placeholder { transform: scale(1.04); }

    .work-placeholder img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.85;
      transition: opacity 0.5s ease;
    }
    .work-item:hover .work-placeholder img { opacity: 1; }

    .placeholder-swatch {
      width: 100%; height: 100%;
    }

    .swatch-1 { background: #2A2420; }
    .swatch-2 { background: #231F1B; }
    .swatch-3 { background: #1C1815; }

    .work-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(14,13,11,0.88) 0%, transparent 55%);
      padding: 28px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .work-item:hover .work-overlay { opacity: 1; }

    .work-tag {
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--sienna-light);
      margin-bottom: 8px;
    }

    .work-name {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 400;
      color: var(--off-white);
      line-height: 1.1;
    }

    .work-label {
      padding: 16px 0 0;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }

    .work-label-name {
      font-family: var(--font-display);
      font-size: 17px;
      font-weight: 400;
      font-style: italic;
      color: var(--black);
    }

    .work-label-cat {
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* ── ABOUT STRIP ── */
    .about-strip {
      background: var(--black);
      color: var(--off-white);
      padding: 100px 48px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }

    .about-headline {
      font-family: var(--font-display);
      font-size: clamp(32px, 4.5vw, 64px);
      font-weight: 400;
      line-height: 1.08;
      letter-spacing: -0.01em;
    }

    .about-headline em {
      font-style: italic;
      color: #C4734A;
    }

    .about-body {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .about-body p {
      font-size: 15px;
      line-height: 1.8;
      color: rgba(244,240,232,0.72);
      font-weight: 300;
    }

    .about-body p strong {
      color: var(--off-white);
      font-weight: 400;
    }

    .about-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 8px;
    }

    .pill {
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--off-white);
      border: 1px solid rgba(244,240,232,0.18);
      padding: 6px 14px;
      border-radius: 100px;
      font-weight: 400;
    }

    /* ── DISCIPLINES ── */
    .disciplines {
      padding: 80px 48px;
    }

    .discipline-list {
      list-style: none;
    }

    .discipline-item {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding: 26px 0;
      border-bottom: 1px solid var(--border);
      position: relative;
      overflow: hidden;
    }

    .discipline-item::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--black);
      transform: translateX(-100%);
      transition: transform 0.5s cubic-bezier(0.16,1,0.3,1);
      z-index: 0;
    }

    .discipline-item:hover::before { transform: translateX(0); }

    .discipline-item:hover .disc-name,
    .discipline-item:hover .disc-num,
    .discipline-item:hover .disc-desc { color: var(--off-white); }

    .disc-num {
      font-size: 10px;
      letter-spacing: 0.12em;
      color: var(--muted);
      position: relative; z-index: 1;
      transition: color 0.3s ease;
      width: 40px;
    }

    .disc-name {
      font-family: var(--font-display);
      font-size: clamp(26px, 3.8vw, 50px);
      font-weight: 400;
      letter-spacing: -0.01em;
      position: relative; z-index: 1;
      transition: color 0.3s ease;
      flex: 1;
      padding: 0 40px;
    }

    .disc-desc {
      font-size: 12px;
      color: var(--muted);
      position: relative; z-index: 1;
      transition: color 0.3s ease;
      text-align: right;
      max-width: 200px;
      line-height: 1.5;
      letter-spacing: 0.02em;
    }

    /* ── CONTACT ── */
    .contact {
      padding: 120px 48px 80px;
      text-align: center;
    }

    .contact-eyebrow {
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 24px;
    }

    .contact-headline {
      font-family: var(--font-display);
      font-size: clamp(48px, 9vw, 120px);
      font-weight: 400;
      line-height: 0.9;
      letter-spacing: -0.02em;
      margin-bottom: 56px;
    }

    .contact-headline em {
      font-style: italic;
      color: var(--sienna);
      display: block;
    }

    .contact-links {
      display: flex;
      justify-content: center;
      gap: 48px;
    }

    .contact-link {
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: none;
      position: relative;
      padding-bottom: 4px;
    }

    .contact-link::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 100%; height: 1px;
      background: var(--sienna);
      transform: scaleX(0);
      transform-origin: right;
      transition: transform 0.4s ease;
    }

    .contact-link:hover::after {
      transform: scaleX(1);
      transform-origin: left;
    }

    /* ── FOOTER ── */
    footer {
      padding: 28px 48px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    footer p {
      font-size: 11px;
      letter-spacing: 0.08em;
      color: var(--muted);
    }

    /* ── ANIMATIONS ── */
    @keyframes slideUp {
      to { transform: translateY(0); opacity: 1; }
    }

    @keyframes fadeIn {
      to { opacity: 1; }
    }

    @keyframes scaleIn {
      to { transform: scaleX(1); }
    }

    @keyframes marquee {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }

    /* ── SCROLL REVEAL ── */
    .reveal {
      opacity: 0;
      transform: translateY(32px);
      transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.16,1,0.3,1);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      nav { padding: 24px 28px; }
      .hero { padding: 0 28px 48px; }
      .hero-masthead { flex-wrap: wrap; gap: 8px; }
      .hero-masthead-divider { display: none; }
      section { padding: 72px 28px; }
      .about-strip { grid-template-columns: 1fr; gap: 48px; padding: 72px 28px; }
      .disciplines { padding: 60px 28px; }
      .contact { padding: 80px 28px 60px; }
      footer { padding: 24px 28px; flex-direction: column; gap: 12px; text-align: center; }
      .work-grid { grid-template-columns: 1fr; gap: 12px; }
      .work-item:nth-child(n) { grid-column: span 1; }
      .work-item:nth-child(n) .work-item-inner { aspect-ratio: 4/3; }
      .disc-desc { display: none; }
    }
  </style>
</head>
<body>

  <!-- CURSOR -->
  <div class="cursor" id="cursor"></div>
  <div class="cursor-ring" id="cursorRing"></div>

  <!-- NAV -->
  <nav>
    <a href="/" class="nav-logo">Karen Dettmar</a>
    <ul class="nav-links">
      <li><a href="#work">Work</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="/projects">Projects</a></li>
      <li><a href="/illustrations">Illustrations</a></li>
      <li><a href="/karen-dettmar-resume.pdf" target="_blank">Résumé</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero">

    <div class="hero-masthead">
      <span class="hero-masthead-item hero-masthead-accent">No. 01</span>
      <div class="hero-masthead-divider"></div>
      <span class="hero-masthead-item">Creative Technologist</span>
      <div class="hero-masthead-divider"></div>
      <span class="hero-masthead-item">Fashion &amp; Technology</span>
      <div class="hero-masthead-divider"></div>
      <span class="hero-masthead-item">New York City</span>
      <div class="hero-masthead-spacer"></div>
      <span class="hero-masthead-item">2026</span>
    </div>

    <h1 class="hero-name">
      <span class="line"><span class="word first">Karen</span></span>
      <span class="line"><span class="word second">Dettmar</span></span>
    </h1>

    <div class="hero-tagline">
      <span class="tag-text">Fashion, technology &amp; the space between.</span>
      <span class="tag-line"></span>
      <a href="#work" class="tag-cta">View work <span class="arrow">→</span></a>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee-wrapper">
    <div class="marquee-track" aria-hidden="true">
      <div class="marquee-item"><span class="marquee-text">Creative Technology</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Fashion Design</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Interactive Demos</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Parsons School of Design</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Developer Advocacy</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Technical Workshops</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Cultural Institutions</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Textile &amp; Craft</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Front-End Development</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Creative Technology</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Fashion Design</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Interactive Demos</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Parsons School of Design</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Developer Advocacy</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Technical Workshops</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Cultural Institutions</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Textile &amp; Craft</span><span class="marquee-dot"></span></div>
      <div class="marquee-item"><span class="marquee-text">Front-End Development</span><span class="marquee-dot"></span></div>
    </div>
  </div>

  <!-- WORK -->
  <section id="work">
    <div class="section-header reveal">
      <div>
