---
import { getCollection } from 'astro:content';
import TrackSelector from '../components/TrackSelector.astro';
const illustrations = await getCollection('illustrations');
const hasIllustrations = illustrations.length > 0;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Karen Dettmar — Creative Technologist</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Archivo:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <!-- Theme: must run before body renders to prevent flash -->
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('theme');
      const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', stored || preferred);
    })();
  </script>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --black: #2C1A0E;
      --off-white: #faf8f5;
      --warm-white: #F5F0E4;
      --sienna: #B85C38;
      --sienna-light: #D4845C;
      --muted: #9A8872;
      --border: rgba(44,26,14,0.14);
      --font-display: 'Cormorant Garamond', serif;
      --font-body: 'Archivo', sans-serif;
      --text-body: #5A4030;
      --hover-sweep: #3D2B1A;
    }

    html[data-theme="dark"] {
      --black: #faf8f5;
      --off-white: #18100A;
      --warm-white: #241810;
      --sienna: #C4683F;
      --sienna-light: #D4845C;
      --muted: #7A6858;
      --border: rgba(237,229,208,0.09);
      --text-body: rgba(237,229,208,0.62);
      --hover-sweep: #2C1F14;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--off-white);
      color: var(--black);
      font-family: var(--font-body);
      font-weight: 300;
      cursor: none;
      overflow-x: hidden;
      transition: background-color 0.35s ease, color 0.35s ease;
    }

    /* ── CURSOR ── */
    .cursor {
      position: fixed;
      top: 0; left: 0;
      width: 8px; height: 8px;
      background: var(--sienna);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      transform: translate(-50%, -50%);
      transition: width 0.3s ease, height 0.3s ease;
    }
    .cursor-ring {
      position: fixed;
      top: 0; left: 0;
      width: 32px; height: 32px;
      border: 1px solid var(--black);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9998;
      transform: translate(-50%, -50%);
      transition: transform 0.18s ease, width 0.3s ease, height 0.3s ease, opacity 0.3s ease;
      opacity: 0.25;
    }
    body:has(a:hover) .cursor,
    body:has(button:hover) .cursor { width: 14px; height: 14px; }
    body:has(a:hover) .cursor-ring,
    body:has(button:hover) .cursor-ring { width: 48px; height: 48px; opacity: 0.12; }


    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 28px 48px;
    }

    .nav-logo {
      font-family: var(--font-body);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: none;
      opacity: 0;
      animation: fadeIn 0.6s ease 1.6s forwards;
    }

    .nav-links {
      display: flex;
      gap: 36px;
      list-style: none;
      opacity: 0;
      animation: fadeIn 0.6s ease 1.6s forwards;
    }

    .nav-links a {
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: none;
      position: relative;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -2px; left: 0;
      width: 0; height: 1px;
      background: var(--sienna);
      transition: width 0.3s ease;
    }
    .nav-links a:hover::after { width: 100%; }

    .theme-toggle {
      background: none;
      border: none;
      font-size: 15px;
      color: var(--muted);
      cursor: none;
      opacity: 0;
      animation: fadeIn 0.6s ease 1.6s forwards;
    }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 48px 64px;
      position: relative;
    }

    .hero-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 0;
    }


    /* ── FEATURED ── */
    .featured-section {
      padding: 80px 48px 100px;
      border-top: 1px solid var(--border);
    }

    .featured-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 40px;
    }

    .featured-eyebrow {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .featured-see-all {
      font-family: var(--font-display);
      font-size: 14px;
      font-style: italic;
      font-weight: 300;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.3s;
    }
    .featured-see-all:hover { color: var(--black); }

    .featured-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .featured-card {
      display: block;
      text-decoration: none;
      color: inherit;
      border: 1px solid var(--border);
      cursor: none;
      overflow: hidden;
      transition: border-color 0.3s ease;
    }
    .featured-card:hover { border-color: var(--black); }

    .featured-card-preview {
      width: 100%;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background: var(--warm-white);
      position: relative;
    }

    .featured-card-preview img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      display: block;
    }
    .featured-card:hover .featured-card-preview img { transform: scale(1.03); }

    /* CSS pattern preview for textile tool */
    .pattern-preview {
      width: 100%;
      height: 100%;
      background-color: var(--black);
      background-image:
        repeating-linear-gradient(45deg,  transparent, transparent 12px, rgba(180,92,56,0.18) 12px, rgba(180,92,56,0.18) 14px),
        repeating-linear-gradient(-45deg, transparent, transparent 12px, rgba(196,168,130,0.12) 12px, rgba(196,168,130,0.12) 14px),
        repeating-linear-gradient(0deg,   transparent, transparent 24px, rgba(200,190,170,0.06) 24px, rgba(200,190,170,0.06) 25px);
      transition: opacity 0.4s ease;
    }
    .featured-card:hover .pattern-preview { opacity: 0.85; }

    .featured-card-body {
      padding: 24px 28px 28px;
    }

    .featured-card-track {
      font-size: 9px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--sienna);
      margin-bottom: 10px;
      display: block;
    }

    .featured-card-title {
      font-family: var(--font-display);
      font-size: clamp(20px, 2vw, 28px);
      font-weight: 300;
      font-style: italic;
      line-height: 1.1;
      letter-spacing: -0.01em;
      color: var(--black);
      margin-bottom: 8px;
      transition: color 0.3s;
    }
    .featured-card:hover .featured-card-title { color: var(--sienna); }

    .featured-card-desc {
      font-size: 12px;
      line-height: 1.7;
      color: var(--text-body);
      font-weight: 300;
    }

    @media (max-width: 900px) {
      .featured-section { padding: 64px 24px 80px; }
      .featured-grid { grid-template-columns: 1fr; }
    }

    /* ── CONTACT ── */
    .contact-section {
      padding: 100px 48px 120px;
      border-top: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .contact-label {
      font-size: 10px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 32px;
    }

    .contact-email {
      font-family: var(--font-display);
      font-size: clamp(32px, 5vw, 68px);
      font-weight: 300;
      font-style: italic;
      color: var(--black);
      text-decoration: none;
      line-height: 1;
      letter-spacing: -0.01em;
      transition: color 0.35s ease;
      display: block;
      margin-bottom: 48px;
    }
    .contact-email:hover { color: var(--sienna); }

    .contact-sub-links {
      display: flex;
      gap: 32px;
    }

    .contact-sub-link {
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.3s ease;
    }
    .contact-sub-link:hover { color: var(--black); }

    /* ── FOOTER ── */
    footer {
      padding: 24px 48px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    footer p {
      font-size: 11px;
      letter-spacing: 0.08em;
      color: var(--muted);
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeIn {
      to { opacity: 1; }
    }

    /* ── SCROLL REVEAL ── */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.16,1,0.3,1);
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      nav { padding: 20px 24px; }
      .nav-logo { display: none; }
      .nav-links { gap: 20px; }
      .hero { min-height: 100dvh; padding: 0 24px 48px; }
      .contact-section { padding: 72px 24px 96px; }
      footer { padding: 20px 24px; flex-direction: column; gap: 8px; text-align: center; }
    }

    /* hide custom cursor on touch devices */
    @media (pointer: coarse) {
      body { cursor: auto; }
      .cursor, .cursor-ring { display: none; }
    }
  </style>
</head>
<body>

  <div class="cursor" id="cursor"></div>
  <div class="cursor-ring" id="cursorRing"></div>

  <!-- NAV -->
  <nav>
    <a href="/" class="nav-logo">Karen Dettmar</a>
    <ul class="nav-links">
      <li><a href="/projects">Work</a></li>
      <li><a href="/about">About</a></li>
      {hasIllustrations && <li><a href="/illustrations">Illustrations</a></li>}
      <li><a href="/Karen-Dettmar-Resume.pdf" target="_blank">CV</a></li>
    </ul>
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">◐</button>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <canvas id="heroCanvas" class="hero-canvas"></canvas>
  </section>

  <!-- TRACK SELECTOR -->
  <section class="reveal">
    <TrackSelector prompt="What brings you here?" bordered={true} />
  </section>

  <!-- FEATURED PROJECTS -->
  <section class="featured-section reveal">
    <div class="featured-header">
      <span class="featured-eyebrow">Featured Projects</span>
    </div>
    <div class="featured-grid">

      <a href="/projects/traveller" class="featured-card">
        <div class="featured-card-preview">
          <img src="/images/traveller/Traveller-moodboard.png" alt="Traveler collection moodboard" />
        </div>
        <div class="featured-card-body">
          <span class="featured-card-track">Fashion</span>
          <h3 class="featured-card-title">Traveler</h3>
          <p class="featured-card-desc">A wearable collection built for movement and impermanence.</p>
        </div>
      </a>

      <a href="/projects/textile-pattern-generator" class="featured-card">
        <div class="featured-card-preview">
          <div class="pattern-preview"></div>
        </div>
        <div class="featured-card-body">
          <span class="featured-card-track">Technology</span>
          <h3 class="featured-card-title">Generative Textile Pattern Tool</h3>
          <p class="featured-card-desc">Enter a collection concept and generate a living textile pattern. Palette and structure are AI-suggested, then fully adjustable.</p>
        </div>
      </a>

    </div>
  </section>

  <!-- CONTACT -->
  <div class="contact-section reveal">
    <span class="contact-label">Get in touch</span>
    <a href="mailto:karen.dettmar@gmail.com" class="contact-email">
      karen.dettmar@gmail.com
    </a>
    <div class="contact-sub-links">
      <a href="https://linkedin.com/in/kdettmar" target="_blank" class="contact-sub-link">LinkedIn</a>
      <a href="/Karen-Dettmar-resume.pdf" target="_blank" class="contact-sub-link">Résumé</a>
    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <p>© 2026 Karen Dettmar</p>
    <p>Creative Technologist · Fashion Designer · New York City</p>
  </footer>

  <script>
    // CURSOR
    const cursor = document.getElementById('cursor') as HTMLElement | null;
    const ring = document.getElementById('cursorRing') as HTMLElement | null;
    let ringX = 0, ringY = 0, curX = 0, curY = 0;

    document.addEventListener('mousemove', (e) => {
      curX = e.clientX; curY = e.clientY;
      if (cursor) { cursor.style.left = curX + 'px'; cursor.style.top = curY + 'px'; }
    });

    function animateRing() {
      ringX += (curX - ringX) * 0.1;
      ringY += (curY - ringY) * 0.1;
      if (ring) { ring.style.left = ringX + 'px'; ring.style.top = ringY + 'px'; }
      requestAnimationFrame(animateRing);
    }
    animateRing();

    // THEME TOGGLE
    const themeToggle = document.getElementById('themeToggle');
    themeToggle?.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
    });

    // SYSTEM PREFERENCE AUTO-THEME
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      const theme = e.matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
    });

    // T-SHIRT THREAD DRAWING
    (function() {
      const canvas = document.getElementById('heroCanvas') as HTMLCanvasElement | null;
      if (!canvas) return;
      const ctx = canvas.getContext('2d')!;

      const SHIRT_COLORS = ['#faf8f5','#e8dcc8','#c4a882','#8b6f5e','#2C1A0E','#7d8c7c','#B85C38','#5a5550'];
      const THREAD_COLORS = ['#8b6f5e','#5a5550','#c4a882','#7d8c7c','#b8846a','#9b8fa0','#D4845C'];

      // SVG path data extracted from Basic T Shirt.svg (viewBox 0 0 595.28 841.89)
      const SVG_SHIRT        = 'M176.24,594.87l247.9,.32c-1.03,-65.35,-2.07,-130.7,-3.1,-196.05l35.61,15.42,48.03,-62.22,-93.95,-75.82,-80.52,-29.08s-3.95,43.87,-31.85,45.38c-27.9,1.51,-34.43,-43.97,-34.43,-43.97l-70.76,23.49,-102.59,79.4,49.45,62.81,36.02,-17.37c.06,65.89,.12,131.78,.18,197.67Z';
      const SVG_COLLAR_FILL  = 'M265.35,247.58s31.65,10.12,63.76,-.88c.6,3.91,3.03,22.39,-9.15,36.76c-2.92,3.45,-10.21,12.04,-21.59,12.47c-11.08,.42,-18.84,-7.18,-21.61,-9.89c-14.39,-14.08,-11.85,-35.22,-11.42,-38.46Z';

      let shirtColor = SHIRT_COLORS[0];
      let threadColorIdx = 0;

      interface Pt { x: number; y: number; }
      interface Trail { pts: Pt[]; color: string; }

      let trails: Trail[] = [];
      let currentTrail: Trail | null = null;
      let isDrawing = false;
      let W = 0, H = 0;
      let shirtPath: Path2D | null = null;
      let shirtMx: DOMMatrix | null = null;
      let shirtMidY = 0;
      let shirtBottomY = 0;
      let hintOpacity = 1;
      let hasDrawn = false;
      let swatchHits: { x: number; y: number; r: number; color: string }[] = [];

      function isDark() {
        return document.documentElement.getAttribute('data-theme') === 'dark';
      }

      // The shirt's visual bounding box within the SVG coordinate space
      const SVG_SHIRT_LEFT = 91, SVG_SHIRT_TOP = 247, SVG_SHIRT_W = 414, SVG_SHIRT_H = 348;

      function buildShirtPath() {
        // Scale shirt to ~58% of canvas width, capped so it fits vertically
        const targetW = Math.min(W * 0.58, H * 0.68);
        const scale   = targetW / SVG_SHIRT_W;

        // Center horizontally; shirt visual top sits at 5% down
        const offsetX = W / 2 - (SVG_SHIRT_LEFT + SVG_SHIRT_W / 2) * scale;
        const offsetY = H * 0.05 + 50 - SVG_SHIRT_TOP * scale;

        // [a, b, c, d, tx, ty]  →  x' = a·x + tx,  y' = d·y + ty
        shirtMx = new DOMMatrix([scale, 0, 0, scale, offsetX, offsetY]);

        const raw = new Path2D(SVG_SHIRT);
        shirtPath = new Path2D();
        shirtPath.addPath(raw, shirtMx);

        shirtBottomY = offsetY + 595  * scale;
        shirtMidY    = offsetY + (SVG_SHIRT_TOP + SVG_SHIRT_H / 2) * scale;
      }

      function buildSwatchHits() {
        const n = SHIRT_COLORS.length;
        const r = Math.min(12, (W * 0.75) / (n * 3.2));
        const spacing = r * 3.2;
        const startX  = W / 2 - ((n - 1) * spacing) / 2;
        const swY = shirtBottomY + (H * 0.90 - shirtBottomY) * 0.42;
        swatchHits = SHIRT_COLORS.map((color, i) => ({
          x: startX + i * spacing, y: swY, r, color,
        }));
      }

      function resize() {
        W = canvas!.width  = canvas!.offsetWidth;
        H = canvas!.height = canvas!.offsetHeight;
        buildShirtPath();
        buildSwatchHits();
      }

      function hexToRgb(hex: string) {
        return { r: parseInt(hex.slice(1,3),16), g: parseInt(hex.slice(3,5),16), b: parseInt(hex.slice(5,7),16) };
      }

      function txPath(d: string) {
        const p = new Path2D(); p.addPath(new Path2D(d), shirtMx!); return p;
      }

      // ── DRAW ──

      function drawGrid() {
        const dark = isDark();
        ctx.strokeStyle = dark ? 'rgba(200,190,170,0.04)' : 'rgba(160,150,135,0.09)';
        ctx.lineWidth = 0.5;
        const sp = 22;
        for (let x = 0; x < W; x += sp) { ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,H); ctx.stroke(); }
        for (let y = 0; y < H; y += sp) { ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); }
      }

      function drawShirtFill() {
        if (!shirtPath || !shirtMx) return;
        const dark = isDark();
        ctx.save();
        // Drop shadow — drawn with shadow props then cleared before collar fill
        ctx.shadowColor  = dark ? 'rgba(0,0,0,0.70)' : 'rgba(44,26,14,0.28)';
        ctx.shadowBlur   = 38;
        ctx.shadowOffsetX = 6;
        ctx.shadowOffsetY = 16;
        ctx.fillStyle = shirtColor;
        ctx.fill(shirtPath);
        // Reset shadow before collar fill so it doesn't double-shadow inside
        ctx.shadowColor = 'transparent';
        ctx.shadowBlur  = 0;
        ctx.shadowOffsetX = 0;
        ctx.shadowOffsetY = 0;
        // Collar shadow
        ctx.fillStyle = dark ? 'rgba(0,0,0,0.20)' : 'rgba(0,0,0,0.11)';
        ctx.fill(txPath(SVG_COLLAR_FILL));
        ctx.restore();
      }

      function drawThreads() {
        if (!shirtPath || trails.length === 0) return;
        ctx.save();
        ctx.clip(shirtPath);
        trails.forEach(trail => {
          if (trail.pts.length < 2) return;
          const { r, g, b } = hexToRgb(trail.color);
          ctx.lineCap = 'round'; ctx.lineJoin = 'round'; ctx.lineWidth = 1.6;
          for (let i = 1; i < trail.pts.length; i++) {
            const a = trail.pts[i-1], bp = trail.pts[i];
            ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(bp.x,bp.y);
            ctx.strokeStyle = `rgba(${r},${g},${b},0.80)`;
            ctx.stroke();
          }
        });
        ctx.restore();
      }

      function drawShirtOverlay() {
        if (!shirtPath || !shirtMx) return;
        const dark = isDark();
        // Outline
        ctx.save();
        ctx.strokeStyle = dark ? 'rgba(200,190,170,0.38)' : 'rgba(44,26,14,0.30)';
        ctx.lineWidth = 1.5;
        ctx.stroke(shirtPath);
        ctx.restore();
      }

      function drawSwatches() {
        const dark = isDark();
        swatchHits.forEach(sw => {
          ctx.save();
          ctx.beginPath();
          ctx.arc(sw.x, sw.y, sw.r, 0, Math.PI * 2);
          ctx.fillStyle = sw.color;
          ctx.fill();
          ctx.strokeStyle = sw.color === shirtColor
            ? (dark ? 'rgba(250,248,245,0.9)' : 'rgba(44,26,14,0.75)')
            : (dark ? 'rgba(200,190,170,0.18)' : 'rgba(44,26,14,0.12)');
          ctx.lineWidth = sw.color === shirtColor ? 2 : 0.5;
          ctx.stroke();
          ctx.restore();
        });
        const first = swatchHits[0];
        if (!first) return;
        ctx.save();
        ctx.font = '500 8px "Archivo", sans-serif';
        ctx.letterSpacing = '0.16em';
        ctx.fillStyle = isDark() ? 'rgba(220,210,190,0.60)' : 'rgba(44,26,14,0.35)';
        ctx.textAlign = 'center';
        ctx.fillText('SHIRT COLOR', W / 2, first.y - first.r - 8);
        ctx.textAlign = 'left'; ctx.letterSpacing = '0';
        ctx.restore();
      }

      const isTouch = window.matchMedia('(pointer: coarse)').matches;

      function shirtTextColor() {
        // Pick dark or light ink based on current shirt fill luminance
        const hex = shirtColor.replace('#', '');
        const r = parseInt(hex.slice(0,2),16), g = parseInt(hex.slice(2,4),16), b = parseInt(hex.slice(4,6),16);
        const lum = (r * 299 + g * 587 + b * 114) / 1000;
        return lum > 128 ? '44,26,14' : '240,232,220';
      }

      function drawHint() {
        if (hintOpacity <= 0 || !shirtPath) return;
        const base = shirtTextColor();
        const lines = isTouch
          ? ['DRAG INSIDE THE SHIRT TO DRAW', 'DOUBLE-TAP TO ERASE']
          : ['CLICK & DRAG INSIDE THE SHIRT TO DRAW', 'DOUBLE-CLICK TO ERASE'];
        ctx.save();
        ctx.clip(shirtPath);
        ctx.font = '500 9px "Archivo", sans-serif';
        ctx.letterSpacing = '0.14em';
        ctx.fillStyle = `rgba(${base},${hintOpacity * 0.52})`;
        ctx.textAlign = 'center';
        lines.forEach((line, i) => ctx.fillText(line, W / 2, shirtMidY - 8 + i * 17));
        ctx.textAlign = 'left'; ctx.letterSpacing = '0';
        ctx.restore();
      }

      function drawNameplate() {
        const dark = isDark();
        const pad = 44;
        ctx.save();
        ctx.font = '300 22px Georgia, serif';
        ctx.fillStyle = dark ? 'rgba(230,220,200,0.85)' : 'rgba(44,26,14,0.55)';
        ctx.fillText('Karen Dettmar', pad, H - pad - 22);
        ctx.font = '500 9px "Archivo", sans-serif';
        ctx.letterSpacing = '0.18em';
        ctx.fillStyle = dark ? 'rgba(210,200,180,0.65)' : 'rgba(44,26,14,0.32)';
        ctx.fillText('CREATIVE TECHNOLOGIST  ·  FASHION & CULTURE  ·  NEW YORK CITY', pad, H - pad);
        ctx.letterSpacing = '0'; ctx.restore();
      }

      function drawFrame() {
        requestAnimationFrame(drawFrame);
        ctx.clearRect(0, 0, W, H);
        drawGrid();
        drawShirtFill();   // shirt color + collar shadow
        drawThreads();     // user threads, clipped inside shirt
        drawShirtOverlay();// outline + dashed seam details on top
        if (hasDrawn) hintOpacity = Math.max(0, hintOpacity - 0.012);
        drawHint();
        drawSwatches();
        drawNameplate();
      }

      function getXY(e: MouseEvent | Touch) {
        const rect = canvas!.getBoundingClientRect();
        return { x: e.clientX - rect.left, y: e.clientY - rect.top };
      }
      function inShirt(x: number, y: number) {
        return shirtPath ? ctx.isPointInPath(shirtPath, x, y) : false;
      }
      function hitSwatch(x: number, y: number) {
        return swatchHits.find(s => Math.hypot(x - s.x, y - s.y) <= s.r * 1.5);
      }
      function addPoint(x: number, y: number) {
        if (!currentTrail) {
          currentTrail = { pts: [], color: THREAD_COLORS[threadColorIdx % THREAD_COLORS.length] };
          threadColorIdx++;
          trails.push(currentTrail);
        }
        const last = currentTrail.pts[currentTrail.pts.length - 1];
        if (!last || Math.hypot(x - last.x, y - last.y) > 4) {
          currentTrail.pts.push({ x, y });
          hasDrawn = true;
        }
      }

      const hero = canvas!.parentElement!;

      hero.addEventListener('mousedown', (e: MouseEvent) => {
        const { x, y } = getXY(e);
        const sw = hitSwatch(x, y);
        if (sw) { shirtColor = sw.color; return; }
        if (inShirt(x, y)) { isDrawing = true; currentTrail = null; addPoint(x, y); }
      });
      hero.addEventListener('mousemove', (e: MouseEvent) => {
        if (!isDrawing) return;
        const { x, y } = getXY(e);
        if (inShirt(x, y)) addPoint(x, y);
      });
      hero.addEventListener('mouseup',    () => { isDrawing = false; currentTrail = null; });
      hero.addEventListener('mouseleave', () => { isDrawing = false; currentTrail = null; });
      hero.addEventListener('dblclick', (e: MouseEvent) => {
        const { x, y } = getXY(e);
        if (inShirt(x, y)) { trails = []; currentTrail = null; }
      });

      let lastTap = 0;
      hero.addEventListener('touchstart', (e: TouchEvent) => {
        const { x, y } = getXY(e.touches[0]);
        const sw = hitSwatch(x, y);
        if (sw) { shirtColor = sw.color; return; }
        if (inShirt(x, y)) { isDrawing = true; currentTrail = null; addPoint(x, y); }
        const now = Date.now();
        if (now - lastTap < 300 && inShirt(x, y)) { trails = []; currentTrail = null; }
        lastTap = now;
      }, { passive: true });
      hero.addEventListener('touchmove', (e: TouchEvent) => {
        e.preventDefault();
        if (!isDrawing) return;
        const { x, y } = getXY(e.touches[0]);
        if (inShirt(x, y)) addPoint(x, y);
      }, { passive: false });
      hero.addEventListener('touchend', () => { isDrawing = false; currentTrail = null; });

      window.addEventListener('resize', resize);
      resize();
      drawFrame();
    })();

    // SCROLL REVEAL
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => entry.target.classList.add('visible'), i * 60);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });
    reveals.forEach(el => observer.observe(el));
  </script>

</body>
</html>
