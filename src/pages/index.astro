<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Karen Dettmar — Creative Technologist</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Archivo:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <!-- Theme: must run before body renders to prevent flash -->
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('theme');
      const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', stored || preferred);
    })();
  </script>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --black: #2C1A0E;
      --off-white: #EDE5D0;
      --warm-white: #F5F0E4;
      --sienna: #B85C38;
      --sienna-light: #D4845C;
      --muted: #9A8872;
      --border: rgba(44,26,14,0.14);
      --font-display: 'Cormorant Garamond', serif;
      --font-body: 'Archivo', sans-serif;
      --text-body: #5A4030;
      --hover-sweep: #3D2B1A;
    }

    html[data-theme="dark"] {
      --black: #EDE5D0;
      --off-white: #18100A;
      --warm-white: #241810;
      --sienna: #C4683F;
      --sienna-light: #D4845C;
      --muted: #7A6858;
      --border: rgba(237,229,208,0.09);
      --text-body: rgba(237,229,208,0.62);
      --hover-sweep: #2C1F14;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--off-white);
      color: var(--black);
      font-family: var(--font-body);
      font-weight: 300;
      cursor: none;
      overflow-x: hidden;
      transition: background-color 0.35s ease, color 0.35s ease;
    }

    /* ── CURSOR ── */
    .cursor {
      position: fixed;
      top: 0; left: 0;
      width: 8px; height: 8px;
      background: var(--sienna);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      transform: translate(-50%, -50%);
      transition: width 0.3s ease, height 0.3s ease;
    }
    .cursor-ring {
      position: fixed;
      top: 0; left: 0;
      width: 32px; height: 32px;
      border: 1px solid var(--black);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9998;
      transform: translate(-50%, -50%);
      transition: transform 0.18s ease, width 0.3s ease, height 0.3s ease, opacity 0.3s ease;
      opacity: 0.25;
    }
    body:has(a:hover) .cursor,
    body:has(button:hover) .cursor { width: 14px; height: 14px; }
    body:has(a:hover) .cursor-ring,
    body:has(button:hover) .cursor-ring { width: 48px; height: 48px; opacity: 0.12; }


    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 28px 48px;
    }

    .nav-logo {
      font-family: var(--font-body);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: none;
      opacity: 0;
      animation: fadeIn 0.6s ease 1.6s forwards;
    }

    .nav-links {
      display: flex;
      gap: 36px;
      list-style: none;
      opacity: 0;
      animation: fadeIn 0.6s ease 1.6s forwards;
    }

    .nav-links a {
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: none;
      position: relative;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -2px; left: 0;
      width: 0; height: 1px;
      background: var(--sienna);
      transition: width 0.3s ease;
    }
    .nav-links a:hover::after { width: 100%; }

    .theme-toggle {
      background: none;
      border: none;
      font-size: 15px;
      color: var(--muted);
      cursor: none;
      opacity: 0;
      animation: fadeIn 0.6s ease 1.6s forwards;
    }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 48px 64px;
      position: relative;
    }

    .hero-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 0;
      opacity: 0;
      animation: fadeIn 2s ease 0.6s forwards;
      -webkit-mask-image: linear-gradient(to bottom, transparent 1%, black 7%, black 88%, transparent 99%);
      mask-image: linear-gradient(to bottom, transparent 1%, black 7%, black 88%, transparent 99%);
    }

    .hero-name {
      font-family: var(--font-display);
      font-weight: 300;
      font-size: clamp(80px, 14vw, 196px);
      line-height: 0.88;
      letter-spacing: -0.02em;
      color: var(--black);
      position: relative;
      z-index: 1;
    }

    .hero-name .line {
      display: block;
      overflow: hidden;
    }

    .hero-name .word {
      display: inline-block;
      transform: translateY(110%);
      opacity: 0;
    }

    .hero-name .word.first  { animation: slideUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.15s forwards; }
    .hero-name .word.second {
      animation: slideUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.38s forwards;
      font-style: italic;
      color: var(--sienna);
    }

    .hero-phrase {
      position: absolute;
      z-index: 1;
      right: 48px;
      bottom: 68px;
      font-family: var(--font-display);
      font-size: clamp(13px, 1.4vw, 18px);
      font-style: italic;
      font-weight: 300;
      color: var(--muted);
      text-align: right;
      line-height: 1.6;
      max-width: 260px;
      opacity: 0;
      animation: fadeIn 0.9s ease 1.1s forwards;
    }

    /* ── WORK ── */
    .work-section {
      padding: 80px 48px 80px;
      border-top: 1px solid var(--border);
    }

    .work-entry {
      display: block;
      padding: 52px 0;
      border-bottom: 1px solid var(--border);
      text-decoration: none;
      color: var(--black);
      cursor: none;
    }
    .work-entry:first-child { border-top: 1px solid var(--border); }

    .work-entry-title {
      display: block;
      font-family: var(--font-display);
      font-size: clamp(48px, 7vw, 96px);
      font-weight: 300;
      line-height: 1;
      letter-spacing: -0.02em;
      transition: color 0.4s ease, transform 0.5s cubic-bezier(0.16,1,0.3,1);
      margin-bottom: 14px;
    }
    .work-entry:hover .work-entry-title {
      color: var(--sienna);
      transform: translateX(10px);
    }

    .work-entry-meta {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .work-entry-desc {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.5;
      letter-spacing: 0.02em;
      font-weight: 300;
      transition: color 0.3s ease;
    }
    .work-entry:hover .work-entry-desc { color: var(--text-body); }

    .work-entry-tag {
      font-size: 9px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      opacity: 0.6;
      white-space: nowrap;
    }

    .work-more {
      display: inline-block;
      margin-top: 40px;
      font-family: var(--font-display);
      font-size: 18px;
      font-style: italic;
      font-weight: 300;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.3s ease;
    }
    .work-more:hover { color: var(--sienna); }

    /* ── CONTACT ── */
    .contact-section {
      padding: 100px 48px 120px;
      border-top: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .contact-label {
      font-size: 10px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 32px;
    }

    .contact-email {
      font-family: var(--font-display);
      font-size: clamp(32px, 5vw, 68px);
      font-weight: 300;
      font-style: italic;
      color: var(--black);
      text-decoration: none;
      line-height: 1;
      letter-spacing: -0.01em;
      transition: color 0.35s ease;
      display: block;
      margin-bottom: 48px;
    }
    .contact-email:hover { color: var(--sienna); }

    .contact-sub-links {
      display: flex;
      gap: 32px;
    }

    .contact-sub-link {
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.3s ease;
    }
    .contact-sub-link:hover { color: var(--black); }

    /* ── FOOTER ── */
    footer {
      padding: 24px 48px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    footer p {
      font-size: 11px;
      letter-spacing: 0.08em;
      color: var(--muted);
    }

    /* ── ANIMATIONS ── */
    @keyframes slideUp {
      to { transform: translateY(0); opacity: 1; }
    }
    @keyframes fadeIn {
      to { opacity: 1; }
    }

    /* ── SCROLL REVEAL ── */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.16,1,0.3,1);
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      nav { padding: 24px 28px; }
      .hero { padding: 0 28px 56px; }
      .hero-phrase { right: 28px; bottom: 60px; max-width: 200px; }
      .work-section { padding: 60px 28px; }
      .work-entry { padding: 40px 0; }
.contact-section { padding: 72px 28px 96px; }
      footer { padding: 20px 28px; flex-direction: column; gap: 8px; text-align: center; }
    }
  </style>
</head>
<body>

  <div class="cursor" id="cursor"></div>
  <div class="cursor-ring" id="cursorRing"></div>

  <!-- NAV -->
  <nav>
    <a href="/" class="nav-logo">Karen Dettmar</a>
    <ul class="nav-links">
      <li><a href="/projects">Work</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/illustrations">Illustrations</a></li>
      <li><a href="/karen-dettmar-resume.pdf" target="_blank">Résumé</a></li>
    </ul>
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">◐</button>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <canvas id="heroCanvas" class="hero-canvas"></canvas>
    <h1 class="hero-name">
      <span class="line"><span class="word first">Karen</span></span>
      <span class="line"><span class="word second">Dettmar</span></span>
    </h1>
    <p class="hero-phrase">Fashion, technology<br>&amp; the space between.</p>
  </section>

  <!-- WORK -->
  <section id="work" class="work-section">

    <a href="/projects/traveller" class="work-entry reveal">
      <span class="work-entry-title">Traveller</span>
      <div class="work-entry-meta">
        <span class="work-entry-desc">A wearable collection built for movement and impermanence</span>
        <span class="work-entry-tag">Collection Concept</span>
      </div>
    </a>

    <a href="/projects/construction" class="work-entry reveal">
      <span class="work-entry-title">Garment Construction & Flats</span>
      <div class="work-entry-meta">
        <span class="work-entry-desc">Pattern work, draping, construction process and technical flats</span>
        <span class="work-entry-tag">Fashion Design</span>
      </div>
    </a>

    <a href="/projects/tech" class="work-entry reveal">
      <span class="work-entry-title">Creative Technology </span>
      <div class="work-entry-meta">
        <span class="work-entry-desc">Tools and prototypes at the intersection of technology and culture</span>
        <span class="work-entry-tag">Tools · Prototypes</span>
      </div>
    </a>

    <a href="/projects" class="work-more reveal">All projects →</a>
  </section>

  <!-- CONTACT -->
  <div class="contact-section reveal">
    <span class="contact-label">Get in touch</span>
    <a href="mailto:karen.dettmar@gmail.com" class="contact-email">
      karen.dettmar@gmail.com
    </a>
    <div class="contact-sub-links">
      <a href="https://linkedin.com/in/kdettmar" target="_blank" class="contact-sub-link">LinkedIn</a>
      <a href="/karen-dettmar-resume.pdf" target="_blank" class="contact-sub-link">Résumé</a>
    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <p>© 2026 Karen Dettmar</p>
    <p>Creative Technologist · Fashion Designer · New York City</p>
  </footer>

  <script>
    // CURSOR
    const cursor = document.getElementById('cursor') as HTMLElement | null;
    const ring = document.getElementById('cursorRing') as HTMLElement | null;
    let ringX = 0, ringY = 0, curX = 0, curY = 0;

    document.addEventListener('mousemove', (e) => {
      curX = e.clientX; curY = e.clientY;
      if (cursor) { cursor.style.left = curX + 'px'; cursor.style.top = curY + 'px'; }
    });

    function animateRing() {
      ringX += (curX - ringX) * 0.1;
      ringY += (curY - ringY) * 0.1;
      if (ring) { ring.style.left = ringX + 'px'; ring.style.top = ringY + 'px'; }
      requestAnimationFrame(animateRing);
    }
    animateRing();

    // THEME TOGGLE
    const themeToggle = document.getElementById('themeToggle');
    themeToggle?.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
    });

    // FABRIC CANVAS — fashion croquis
    (function() {
      const canvasEl = document.getElementById('heroCanvas') as HTMLCanvasElement | null;
      if (!canvasEl) return;
      const canvas = canvasEl;
      const ctx = canvas.getContext('2d')!;
      let W = 0, H = 0;
      const mouse = { x: -9999, y: -9999 };
      let frame = 0;

      interface BgThread { x: number; phase: number; speed: number; amp: number; opacity: number; }
      interface FigThread { pos: number; phase: number; speed: number; waver: number; }
      let bg: BgThread[] = [];
      let fig: FigThread[] = [];

      // 9-head fashion croquis silhouette: [yNorm, halfWidth as fraction of figW]
      const CROQUIS: [number, number][] = [
        [0.000, 0.00],
        [0.025, 0.12],  // forehead
        [0.060, 0.17],  // widest of head
        [0.095, 0.14],  // jaw
        [0.110, 0.05],  // neck top (narrow)
        [0.162, 0.06],  // neck base
        [0.222, 0.50],  // shoulder
        [0.275, 0.40],  // upper chest
        [0.333, 0.35],  // bust
        [0.400, 0.20],  // waist (narrowest)
        [0.460, 0.34],  // high hip
        [0.520, 0.42],  // hip (widest)
        [0.610, 0.28],  // upper thigh
        [0.660, 0.22],  // mid thigh
        [0.740, 0.16],  // knee
        [0.795, 0.17],  // upper calf
        [0.860, 0.14],  // calf
        [0.920, 0.08],  // ankle
        [0.960, 0.10],  // foot
        [1.000, 0.08],  // toe
      ];

      function getHW(y: number): number {
        if (y <= 0) return 0;
        for (let i = 0; i < CROQUIS.length - 1; i++) {
          if (y >= CROQUIS[i][0] && y <= CROQUIS[i + 1][0]) {
            const t = (y - CROQUIS[i][0]) / (CROQUIS[i + 1][0] - CROQUIS[i][0]);
            return CROQUIS[i][1] + (CROQUIS[i + 1][1] - CROQUIS[i][1]) * t;
          }
        }
        return CROQUIS[CROQUIS.length - 1][1];
      }

      function isDark() {
        return document.documentElement.getAttribute('data-theme') === 'dark';
      }

      function resize() {
        W = canvas.width = canvas.offsetWidth;
        H = canvas.height = canvas.offsetHeight;

        bg = [];
        for (let i = 0; i < 90; i++) {
          bg.push({
            x: (i / 89) * W,
            phase: Math.random() * Math.PI * 2,
            speed: 0.004 + Math.random() * 0.003,
            amp: 5 + Math.random() * 12,
            opacity: 0.035 + Math.random() * 0.035,
          });
        }

        fig = [];
        for (let i = 0; i < 14; i++) {
          fig.push({
            pos: i / 13,
            phase: Math.random() * Math.PI * 2,
            speed: 0.003 + Math.random() * 0.002,
            waver: 1 + Math.random() * 3,
          });
        }
      }

      function drawFrame() {
        ctx.clearRect(0, 0, W, H);
        frame++;
        const dark = isDark();
        const sr = dark ? '196,104,63' : '184,92,56';
        const mr = dark ? '130,110,92' : '154,136,114';
        const PTS = 70;

        const cx    = W * 0.50;
        const figTop = H * 0.05;
        const figH   = H * 0.86;
        const figW   = W * 0.20;  // shoulder half-width = 10% of viewport

        // — background threads (subtle, full height) —
        bg.forEach(t => {
          ctx.beginPath();
          for (let i = 0; i <= PTS; i++) {
            const p = i / PTS;
            const y = p * H;
            const env = Math.sin(p * Math.PI);
            const x = t.x
              + Math.sin(t.phase + frame * t.speed) * t.amp * env
              + Math.sin(t.phase * 1.6 + frame * t.speed * 0.6 + 1.8) * t.amp * 0.4 * env;
            if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
          }
          ctx.strokeStyle = `rgba(${mr},${t.opacity})`;
          ctx.lineWidth = 0.5;
          ctx.stroke();
        });

        // — figure threads (trace croquis silhouette) —
        fig.forEach(t => {
          ctx.beginPath();
          for (let i = 0; i <= PTS; i++) {
            const yNorm = i / PTS;
            const y = figTop + yNorm * figH;
            const hw = getHW(yNorm) * figW;
            // interpolate position across the silhouette width
            const baseX = cx - hw + t.pos * hw * 2;
            const wave = Math.sin(t.phase + frame * t.speed + yNorm * 6) * t.waver;
            let x = baseX + wave;

            // mouse repulsion
            const dx = x - mouse.x;
            const dy = y - mouse.y;
            const d = Math.sqrt(dx * dx + dy * dy);
            if (d < 150 && d > 0) x += (dx / d) * (1 - d / 150) * 55;

            if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
          }
          const isEdge = t.pos < 0.09 || t.pos > 0.91;
          ctx.strokeStyle = `rgba(${sr},${isEdge ? 0.28 : 0.14})`;
          ctx.lineWidth = isEdge ? 0.85 : 0.6;
          ctx.stroke();
        });

        requestAnimationFrame(drawFrame);
      }

      const hero = canvas.parentElement;
      hero?.addEventListener('mousemove', e => {
        const r = canvas.getBoundingClientRect();
        mouse.x = e.clientX - r.left;
        mouse.y = e.clientY - r.top;
      });
      hero?.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

      window.addEventListener('resize', resize);
      resize();
      drawFrame();
    })();

    // SCROLL REVEAL
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => entry.target.classList.add('visible'), i * 60);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });
    reveals.forEach(el => observer.observe(el));
  </script>

</body>
</html>
