---
import { getCollection } from 'astro:content';
import TrackSelector from '../components/TrackSelector.astro';
const illustrations = await getCollection('illustrations');
const hasIllustrations = illustrations.length > 0;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Karen Dettmar — Creative Technologist</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Archivo:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <!-- Theme: must run before body renders to prevent flash -->
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('theme');
      const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', stored || preferred);
    })();
  </script>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --black: #2C1A0E;
      --off-white: #faf8f5;
      --warm-white: #F5F0E4;
      --sienna: #B85C38;
      --sienna-light: #D4845C;
      --muted: #9A8872;
      --border: rgba(44,26,14,0.14);
      --font-display: 'Cormorant Garamond', serif;
      --font-body: 'Archivo', sans-serif;
      --text-body: #5A4030;
      --hover-sweep: #3D2B1A;
    }

    html[data-theme="dark"] {
      --black: #faf8f5;
      --off-white: #18100A;
      --warm-white: #241810;
      --sienna: #C4683F;
      --sienna-light: #D4845C;
      --muted: #7A6858;
      --border: rgba(237,229,208,0.09);
      --text-body: rgba(237,229,208,0.62);
      --hover-sweep: #2C1F14;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--off-white);
      color: var(--black);
      font-family: var(--font-body);
      font-weight: 300;
      cursor: none;
      overflow-x: hidden;
      transition: background-color 0.35s ease, color 0.35s ease;
    }

    /* ── CURSOR ── */
    .cursor {
      position: fixed;
      top: 0; left: 0;
      width: 8px; height: 8px;
      background: var(--sienna);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      transform: translate(-50%, -50%);
      transition: width 0.3s ease, height 0.3s ease;
    }
    .cursor-ring {
      position: fixed;
      top: 0; left: 0;
      width: 32px; height: 32px;
      border: 1px solid var(--black);
      border-radius: 50%;
      pointer-events: none;
      z-index: 9998;
      transform: translate(-50%, -50%);
      transition: transform 0.18s ease, width 0.3s ease, height 0.3s ease, opacity 0.3s ease;
      opacity: 0.25;
    }
    body:has(a:hover) .cursor,
    body:has(button:hover) .cursor { width: 14px; height: 14px; }
    body:has(a:hover) .cursor-ring,
    body:has(button:hover) .cursor-ring { width: 48px; height: 48px; opacity: 0.12; }


    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 28px 48px;
    }

    .nav-logo {
      font-family: var(--font-body);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: none;
      opacity: 0;
      animation: fadeIn 0.6s ease 1.6s forwards;
    }

    .nav-links {
      display: flex;
      gap: 36px;
      list-style: none;
      opacity: 0;
      animation: fadeIn 0.6s ease 1.6s forwards;
    }

    .nav-links a {
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: none;
      position: relative;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -2px; left: 0;
      width: 0; height: 1px;
      background: var(--sienna);
      transition: width 0.3s ease;
    }
    .nav-links a:hover::after { width: 100%; }

    .theme-toggle {
      background: none;
      border: none;
      font-size: 15px;
      color: var(--muted);
      cursor: none;
      opacity: 0;
      animation: fadeIn 0.6s ease 1.6s forwards;
    }

    /* ── FEATURED ── */
    .featured-section {
      padding: 80px 48px 100px;
      border-top: 1px solid var(--border);
    }

    .featured-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 40px;
    }

    .featured-eyebrow {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .featured-see-all {
      font-family: var(--font-display);
      font-size: 14px;
      font-style: italic;
      font-weight: 300;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.3s;
    }
    .featured-see-all:hover { color: var(--black); }

    /* ── CINEMATIC SCENE ── */
    .scene-canvas {
      position: relative;
      width: 100%;
      height: 600px;
       background: #000;
      /* background: #0d0a07; */
      overflow: hidden;
      margin-bottom: 0;
    }

    /* Scarf standalone (overridden when inside .scene-scarf-wrap) */
    .scene-scarf {
      display: block;
    }

    @keyframes suitcase-breathe {
      0%   { transform: translate(-50%, -50%) rotate(-1deg) translateY(0px); }
      100% { transform: translate(-50%, -50%) rotate(1deg)  translateY(3px); }
    }

    /* Suitcase clip wrapper — crops the right-edge seam */
    .scene-suitcase-wrap {
      position: absolute;
      width: 90%;
      left: 25%;
      top: 36%;
      transform: translate(-50%, -50%);
      overflow: hidden;
      z-index: 1;
      cursor: pointer;
      animation: suitcase-breathe 3s ease-in-out infinite alternate;
    }

    /* Suitcase: sits on top, left of center */
    .scene-suitcase {
      display: block;
      width: 80%;
      object-fit: cover;
      object-position: left center;
      clip-path: inset(0 30% 0 0);
      mix-blend-mode: screen;
      border: none; outline: none;
    }

    /* Hover dark overlay — strictly contained within its own wrapper */
    .scene-hover-dark {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.55);
      opacity: 0;
      transition: opacity 0.3s ease;
      pointer-events: none;
      z-index: 0;
   
    }
    .scene-suitcase-wrap:hover .scene-hover-dark,
    .scene-scarf-wrap:hover     .scene-hover-dark { opacity: 1; }
     .scene-suitcase-wrap:hover .scene-hover-dark{    width: 50%;}

    /* Scarf wrapper for hover dark overlay */
    .scene-scarf-wrap {
      position: absolute;
      bottom: 0; right: -25%;
      height: 100%;
      z-index: 1;
      cursor: pointer;
      overflow: hidden;
    }
    /* Move the scarf video styles into the wrapper context */
    .scene-scarf-wrap .scene-scarf {
      position: relative;
      bottom: auto; right: auto;
      height: 100%;
      object-fit: cover;
      mix-blend-mode: screen;
      transform: rotate(180deg);
      border: none; outline: none;
    }

    /* Overlays — position set by JS at hover time */
    .scene-overlay {
      position: absolute;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.4s ease;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 8px;
    }
    .scene-overlay.visible { opacity: 1; }
    .scene-overlay--suitcase { z-index: 2; }
    .scene-overlay--scarf    { z-index: 3; }

    .scene-tag {
      font-family: var(--font-body);
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: rgba(245, 240, 228, 0.5);
    }

    .scene-title {
      font-family: var(--font-display);
      font-size: clamp(18px, 2.2vw, 30px);
      font-style: italic;
      font-weight: 300;
      color: #F5F0E4;
      line-height: 1.1;
      letter-spacing: -0.01em;
    }

    .scene-link {
      font-family: var(--font-body);
      font-size: 9px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(245, 240, 228, 0.55);
    }

    /* ── FEATURED CARD BODIES (below canvas) ── */
    .featured-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0;
    }

    .featured-card-body {
      padding: 20px 28px 24px;
    }

    .featured-card-track {
      font-size: 9px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--sienna);
      margin-bottom: 6px;
      display: block;
    }

    .featured-card-title {
      font-family: var(--font-display);
      font-size: clamp(18px, 1.8vw, 24px);
      font-weight: 300;
      font-style: italic;
      line-height: 1.1;
      letter-spacing: -0.01em;
      color: var(--black);
    }

    @media (max-width: 768px) {
      .scene-canvas { height: auto; }
      .scene-scarf {
        position: relative;
        width: 100%;
        height: 300px;
        object-fit: cover;
      }
      .scene-suitcase {
        position: relative;
        display: block;
        width: 70%;
        left: auto; top: auto;
        transform: none;
        margin: 0 auto;
      }
      .scene-overlay--suitcase {
        left: 50%;
        top: 0%;
        transform: translateX(-50%);
      }
      .scene-overlay--scarf {
        right: auto;
        left: 40%;
        top: 50%;
        transform: translate(-50%, -50%);
      }
    }

    @media (max-width: 900px) {
      .featured-section { padding: 64px 24px 80px; }
      .featured-grid { grid-template-columns: 1fr; }
    }

    /* ── CONTACT ── */
    .contact-section {
      padding: 100px 48px 120px;
      border-top: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .contact-label {
      font-size: 10px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 32px;
    }

    .contact-email {
      font-family: var(--font-display);
      font-size: clamp(32px, 5vw, 68px);
      font-weight: 300;
      font-style: italic;
      color: var(--black);
      text-decoration: none;
      line-height: 1;
      letter-spacing: -0.01em;
      transition: color 0.35s ease;
      display: block;
      margin-bottom: 48px;
    }
    .contact-email:hover { color: var(--sienna); }

    .contact-sub-links {
      display: flex;
      gap: 32px;
    }

    .contact-sub-link {
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.3s ease;
    }
    .contact-sub-link:hover { color: var(--black); }

    /* ── FOOTER ── */
    footer {
      padding: 24px 48px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    footer p {
      font-size: 11px;
      letter-spacing: 0.08em;
      color: var(--muted);
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeIn {
      to { opacity: 1; }
    }
    

    /* ── SCROLL REVEAL ── */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.16,1,0.3,1);
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      nav { padding: 20px 24px; }
      .nav-logo { display: none; }
      .nav-links { gap: 20px; }
      .hero { min-height: 100dvh; padding: 0 24px 48px; }
      .contact-section { padding: 72px 24px 96px; }
      footer { padding: 20px 24px; flex-direction: column; gap: 8px; text-align: center; }
    }

    /* hide custom cursor on touch devices */
    @media (pointer: coarse) {
      body { cursor: auto; }
      .cursor, .cursor-ring { display: none; }
    }
  </style>
</head>
<body>

  <div class="cursor" id="cursor"></div>
  <div class="cursor-ring" id="cursorRing"></div>

  <!-- NAV -->
  <nav>
    <a href="/" class="nav-logo">Karen Dettmar</a>
    <ul class="nav-links">
      <li><a href="/projects">Work</a></li>
      <li><a href="/about">About</a></li>
      {hasIllustrations && <li><a href="/illustrations">Illustrations</a></li>}
      <li><a href="/cv">CV</a></li>
    </ul>
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">◐</button>
  </nav>

  <!-- TRACK SELECTOR -->
  <section class="reveal">
    <TrackSelector prompt="What brings you here?" bordered={true} />
  </section>

  <!-- FEATURED PROJECTS -->
  <section class="featured-section reveal">
    <div class="featured-header">
      <span class="featured-eyebrow">Featured Projects</span>
    </div>
    <!-- cinematic scene -->
    <div class="scene-canvas" id="sceneCanvas">

      <!-- Scarf: full-canvas background, z-index 1 -->
      <div class="scene-scarf-wrap" id="scarfWrap">
        <video class="scene-scarf" id="vidScarf" autoplay muted loop playsinline>
          <source src="/videos/scarf.mp4" type="video/mp4" />
        </video>
        <div class="scene-hover-dark"></div>
      </div>
      <div class="scene-overlay scene-overlay--scarf" id="overlayScarf">
        <span class="scene-tag">Technology</span>
        <span class="scene-title">Generative Textile Pattern Tool</span>
        <span class="scene-link">View project</span>
      </div>

      <!-- Suitcase: on top, left of center, z-index 2 -->
      <div class="scene-suitcase-wrap" id="suitcaseWrap">
        <video class="scene-suitcase" id="vidSuitcase" autoplay muted loop playsinline>
          <source src="/videos/suitcase.mp4" type="video/mp4" />
        </video>
        <div class="scene-hover-dark"></div>
      </div>
      <div class="scene-overlay scene-overlay--suitcase" id="overlaySuitcase">
        <span class="scene-tag">Fashion</span>
        <span class="scene-title">Traveller</span>
        <span class="scene-link">View project</span>
      </div>

    </div>

  </section>

  <!-- CONTACT -->
  <div class="contact-section reveal">
    <span class="contact-label">Get in touch</span>
    <a href="mailto:karen.dettmar@gmail.com" class="contact-email">
      karen.dettmar@gmail.com
    </a>
    <div class="contact-sub-links">
      <a href="https://linkedin.com/in/kdettmar" target="_blank" class="contact-sub-link">LinkedIn</a>
      <a href="/Karen_Dettmar_CV.pdf" target="_blank" class="contact-sub-link">CV</a>
    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <p>© 2026 Karen Dettmar</p>
    <p>Creative Technologist · Fashion Designer · New York City</p>
  </footer>

  <script>
    // CINEMATIC SCENE — hover on wrapper divs, overlay centered over wrapper
    const sceneCanvas     = document.getElementById('sceneCanvas')    as HTMLElement | null;
    const vidSuitcase     = document.getElementById('vidSuitcase')    as HTMLVideoElement | null;
    const vidScarf        = document.getElementById('vidScarf')       as HTMLVideoElement | null;
    const suitcaseWrap    = document.getElementById('suitcaseWrap')   as HTMLElement | null;
    const scarfWrap       = document.getElementById('scarfWrap')      as HTMLElement | null;
    const overlaySuitcase = document.getElementById('overlaySuitcase') as HTMLElement | null;
    const overlayScarf    = document.getElementById('overlayScarf')    as HTMLElement | null;

    function centerOverlay(el: HTMLElement, overlay: HTMLElement) {
      if (!sceneCanvas) return;
      const er = el.getBoundingClientRect();
      const cr = sceneCanvas.getBoundingClientRect();
      overlay.style.left      = (er.left - cr.left + er.width  / 2) + 'px';
      overlay.style.top       = (er.top  - cr.top  + er.height / 2) + 'px';
      overlay.style.transform = 'translate(-50%, -50%)';
    }

    suitcaseWrap?.addEventListener('mouseenter', () => {
      vidSuitcase?.pause();
      if (overlaySuitcase && suitcaseWrap) { centerOverlay(suitcaseWrap, overlaySuitcase); overlaySuitcase.classList.add('visible'); }
    });
    suitcaseWrap?.addEventListener('mouseleave', () => {
      vidSuitcase?.play();
      overlaySuitcase?.classList.remove('visible');
    });
    suitcaseWrap?.addEventListener('click', () => { window.location.href = '/projects/traveller'; });

    scarfWrap?.addEventListener('mouseenter', () => {
      vidScarf?.pause();
      if (overlayScarf && scarfWrap) { centerOverlay(scarfWrap, overlayScarf); overlayScarf.classList.add('visible'); }
    });
    scarfWrap?.addEventListener('mouseleave', () => {
      vidScarf?.play();
      overlayScarf?.classList.remove('visible');
    });
    scarfWrap?.addEventListener('click', () => { window.location.href = '/projects/textile-pattern-generator'; });

    // CURSOR
    const cursor = document.getElementById('cursor') as HTMLElement | null;
    const ring = document.getElementById('cursorRing') as HTMLElement | null;
    let ringX = 0, ringY = 0, curX = 0, curY = 0;

    document.addEventListener('mousemove', (e) => {
      curX = e.clientX; curY = e.clientY;
      if (cursor) { cursor.style.left = curX + 'px'; cursor.style.top = curY + 'px'; }
    });

    function animateRing() {
      ringX += (curX - ringX) * 0.1;
      ringY += (curY - ringY) * 0.1;
      if (ring) { ring.style.left = ringX + 'px'; ring.style.top = ringY + 'px'; }
      requestAnimationFrame(animateRing);
    }
    animateRing();

    // THEME TOGGLE
    const themeToggle = document.getElementById('themeToggle');
    themeToggle?.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
    });

    // SYSTEM PREFERENCE AUTO-THEME
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      const theme = e.matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
    });

    // SCROLL REVEAL
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => entry.target.classList.add('visible'), i * 60);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });
    reveals.forEach(el => observer.observe(el));
  </script>

</body>
</html>
