---
import MainLayout from '../layouts/MainLayout.astro';
import styles from './cv.module.css';
---

<MainLayout title="CV — Karen Dettmar">

  <div class={styles['cv-wrapper']}>

    <!-- Download button -->
    <div class={styles['cv-actions']}>
      <a href="/Karen_Dettmar_CV.pdf" download class={styles['cv-dl-btn']}>↓ &nbsp;Download PDF</a>
    </div>

    <!-- Name & identity -->
    <header class={styles['cv-header']}>
      <h1 class={styles['cv-name']}>Karen Dettmar</h1>
      <p class={styles['cv-subtitle']}>Creative Technologist &nbsp;·&nbsp; Fashion &amp; Culture &nbsp;·&nbsp; New York City</p>
      <p class={styles['cv-contact']}>
        <a href="mailto:karen.dettmar@gmail.com">karen.dettmar@gmail.com</a>
        <span class={styles['cv-sep']}>·</span>
        <a href="https://linkedin.com/in/kdettmar" target="_blank">linkedin.com/in/kdettmar</a>
      </p>
    </header>

    <!-- Summary -->
    <p class={styles['cv-summary']}>
      Designer and front-end engineer who builds things that work and feel considered. Background in interactive systems, AI-powered tools, developer experience research, and shipping products used by real audiences. Drawn to immersive, culturally resonant work at the intersection of technology and craft.
    </p>

    <!-- Skills & Tools -->
    <section class={styles['cv-section']}>
      <h2 class={styles['cv-section-heading']}>Skills &amp; Tools</h2>
      <div class={styles['cv-skills']}>
        <div class={styles['cv-skill-row']}>
          <span class={styles['cv-skill-cat']}>Technology</span>
          <span class={styles['cv-skill-val']}>Midjourney, Nanobanana, Runway, Claude API &amp; Generative AI, LLM integration, Cursor, ChatGPT, React, JavaScript, Typescript, HTML/CSS, APIs, Git, Astro, VueJS, AI-assisted prototyping, Design Systems, Figma, REST APIs, NodeJS, Next.js, Vue</span>
        </div>
        <div class={styles['cv-skill-row']}>
          <span class={styles['cv-skill-cat']}>Creative &amp; Design</span>
          <span class={styles['cv-skill-val']}>Adobe Illustrator, Brand Identity, Visual Systems, UX/UI</span>
        </div>
        <div class={styles['cv-skill-row']}>
          <span class={styles['cv-skill-cat']}>Collaboration</span>
          <span class={styles['cv-skill-val']}>Cross-functional teams, Workshop facilitation, Keynote presentations, Beta testing, QA, SDLC</span>
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section class={styles['cv-section']}>
      <h2 class={styles['cv-section-heading']}>Experience</h2>

      <div class={styles['cv-role']}>
        <div class={styles['cv-role-meta']}>
          <span class={styles['cv-role-title']}>Creative Technologist / Developer Advocate</span>
          <span class={styles['cv-role-company']}>Intuit</span>
          <span class={styles['cv-role-date']}>Nov 2022 – Sept 2024</span>
        </div>
        <ul class={styles['cv-bullets']}>
          <li>Built and shipped engineer-facing tools and interactive learning experiences used by 7,000+ global employees, managing the full development lifecycle from prototype through public deployment.</li>
          <li>Maintained and evolved design systems and documentation standards across multiple business units, ensuring visual and functional consistency across teams.</li>
          <li>Designed and led the InnerSource Tournament — a company-wide creative challenge that built community and modernized collaborative tooling across AI &amp; Data teams.</li>
          <li>Presented new platform capabilities to 7,000+ global employees; rebuilt Intuit's open-source website to better reflect engineering culture externally.</li>
        </ul>
      </div>

      <div class={styles['cv-role']}>
        <div class={styles['cv-role-meta']}>
          <span class={styles['cv-role-title']}>Creative Technologist / Developer Advocate</span>
          <span class={styles['cv-role-company']}>Wix</span>
          <span class={styles['cv-role-date']}>Feb 2020 – Oct 2022</span>
        </div>
        <ul class={styles['cv-bullets']}>
          <li>Prototyped, tested, and shipped the full keynote demo experience for Wix DevCon. A live, high-exposure public application built for a global developer audience.</li>
          <li>Conducted user research and beta testing with external users to validate UX decisions and inform product development.</li>
          <li>Led NYC meetups and workshops on JavaScript and design-to-code transitions, building a community bridge between designers and developers.</li>
        </ul>
      </div>

      <div class={styles['cv-role']}>
        <div class={styles['cv-role-meta']}>
          <span class={styles['cv-role-title']}>Front-End Developer &amp; Designer</span>
          <span class={styles['cv-role-company']}>WET &nbsp;·&nbsp; Pixomondo &nbsp;·&nbsp; CIBT</span>
          <span class={styles['cv-role-date']}>2017 – 2019</span>
        </div>
        <ul class={styles['cv-bullets']}>
          <li>Built web applications, marketing sites, and internal tools across entertainment, travel, and corporate sectors using VueJS, WordPress, and custom front-end stacks.</li>
        </ul>
      </div>
    </section>

    <!-- Speaking & Community -->
    <section class={styles['cv-section']}>
      <h2 class={styles['cv-section-heading']}>Speaking &amp; Community</h2>
      <p class={styles['cv-speaking']}>
        Keynote Speaker — Wix DevCon
        <span class={styles['cv-sep']}>·</span>
        Organizer &amp; Host — NYC Developer Meetups
        <span class={styles['cv-sep']}>·</span>
        Technical Workshop Leader — JavaScript, Design Systems, React Security
      </p>
    </section>

    <!-- Education -->
    <section class={`${styles['cv-section']} ${styles['cv-section-last']}`}>
      <h2 class={styles['cv-section-heading']}>Education</h2>
      <div class={styles['cv-edu-list']}>
        <div class={styles['cv-edu-item']}>
          <span class={styles['cv-edu-degree']}>Certification in Fashion Design</span>
          <span class={styles['cv-edu-school']}>Parsons School of Design – The New School</span>
        </div>
        <div class={styles['cv-edu-item']}>
          <span class={styles['cv-edu-degree']}>Sewing &amp; Garment Construction</span>
          <span class={styles['cv-edu-school']}>Fashion Institute of Technology (FIT)</span>
        </div>
        <div class={styles['cv-edu-item']}>
          <span class={styles['cv-edu-degree']}>B.A. International Relations &nbsp;·&nbsp; Studio Art (Printmaking)</span>
          <span class={styles['cv-edu-school']}>University of Virginia</span>
        </div>
      </div>
    </section>

  </div>

</MainLayout>
